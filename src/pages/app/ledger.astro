---
// src/pages/app/ledger.astro
import { supabase } from "@/lib/supabase/client";
import AppLayout from "../../layouts/AppLayout.astro";

const { profile, user } = Astro.locals;

if (!profile || !user) {
    return Astro.redirect("/login");
}

const now = new Date();
const currentYear = parseInt(Astro.url.searchParams.get("year") || now.getFullYear().toString());
const currentMonth = Astro.url.searchParams.get("month") ? parseInt(Astro.url.searchParams.get("month")!) : null;
const searchQuery = Astro.url.searchParams.get("search") || "";

/**
 * 🎯 LOGIQUE SÉCURISÉE (BACKEND SSR)
 */

// 1. Récupérer le résumé fiscal (Mensuel ou Annuel)
let summaryQuery = supabase
    .from("tenant_accounting_ledger" as any)
    .select("*")
    .eq("tenant_id", profile.tenant_id as string)
    .eq("year", currentYear);

if (currentMonth !== null) {
    summaryQuery = summaryQuery.eq("month", currentMonth);
}

const { data: summaryData } = await summaryQuery as any;

// Calcul des totaux pour le bandeau KPI
const totals = (summaryData as any[])?.reduce((acc, curr) => ({
    gross: acc.gross + (curr.gross_revenue || 0),
    net: acc.net + (curr.net_revenue || 0),
    vat: acc.vat + (curr.vat_collected || 0),
    bookings: acc.bookings + (curr.booking_count || 0)
}), { gross: 0, net: 0, vat: 0, bookings: 0 }) || { gross: 0, net: 0, vat: 0, bookings: 0 };

// 2. Récupérer le détail des mouvements financiers
let movementsQuery = supabase
    .from("financial_movements")
    .select(`
        *,
        bookings!inner (
            id,
            pickup_time,
            customers!inner (
                first_name,
                last_name,
                company_name,
                email
            )
        )
    `)
    .eq("tenant_id", profile.tenant_id as string)
    .order("created_at", { ascending: false });

if (currentMonth !== null) {
    const startOfMonth = new Date(currentYear, currentMonth - 1, 1).toISOString();
    const endOfMonth = new Date(currentYear, currentMonth, 0, 23, 59, 59).toISOString();
    movementsQuery = movementsQuery.gte("created_at", startOfMonth).lte("created_at", endOfMonth);
} else {
    const startOfYear = new Date(currentYear, 0, 1).toISOString();
    const endOfYear = new Date(currentYear, 11, 31, 23, 59, 59).toISOString();
    movementsQuery = movementsQuery.gte("created_at", startOfYear).lte("created_at", endOfYear);
}

// Filtre par recherche (Nom client ou Compagnie)
// Note: Supabase doesn't support complex OR across joined tables easily in a single string,
// so we'll do literal filter if possible or just fetch and filter in memory if volume is low.
// Given it's a ledger, volume might grow. We'll try to use the !inner join for filtering.
if (searchQuery) {
    // This will filter bookings where customer matches
    // Note: This might need adjustment based on how PostgREST handles nested filters
    movementsQuery = movementsQuery.or(`first_name.ilike.%${searchQuery}%,last_name.ilike.%${searchQuery}%,company_name.ilike.%${searchQuery}%`, { foreignTable: 'bookings.customers' });
}

const { data: movements, error: mError } = await movementsQuery;
if (mError) console.error("Error fetching movements:", mError);

const months = [
    "Janvier", "Février", "Mars", "Avril", "Mai", "Juin",
    "Juillet", "Août", "Septembre", "Octobre", "Novembre", "Décembre"
];

const getFilterUrl = (params: Record<string, string | number | null>) => {
    const url = new URL(Astro.url.href);
    Object.entries(params).forEach(([key, value]) => {
        if (value === null || value === 'all') {
            url.searchParams.delete(key);
        } else {
            url.searchParams.set(key, value.toString());
        }
    });
    return url.pathname + url.search;
};
---

<AppLayout title="Suivi Fiscal">
    <div class="flex-1 flex flex-col p-12 overflow-hidden h-full">
        <!-- HEADER -->
        <div class="flex-shrink-0 border-b border-white/5 pb-8 mb-6">
            <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <span class="px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-[10px] font-black tracking-widest text-indigo-400 uppercase">
                        Comptabilité & Fiscalité
                    </span>
                    <h1 class="text-4xl font-black mt-4 uppercase tracking-tighter text-white">
                        Suivi Global
                    </h1>
                </div>

                <!-- FILTERS -->
                <div class="flex flex-wrap items-center gap-4">
                    <!-- Search -->
                    <form method="GET" class="relative">
                        <input
                            type="text"
                            name="search"
                            placeholder="Rechercher un client..."
                            value={searchQuery}
                            class="bg-white/5 border border-white/10 rounded-xl px-12 py-3 text-[11px] font-bold text-white uppercase tracking-widest focus:outline-none focus:border-indigo-500/50 transition-all min-w-[250px]"
                        />
                        <svg class="w-4 h-4 text-slate-500 absolute left-4 top-1/2 -translate-y-1/2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                        {currentMonth && <input type="hidden" name="month" value={currentMonth} />}
                        <input type="hidden" name="year" value={currentYear} />
                    </form>

                    <!-- Month Dropdown -->
                    <div class="relative group" id="month-dropdown-container">
                        <button
                            id="month-dropdown-button"
                            class="px-6 py-3 bg-white/5 hover:bg-white/10 text-white text-[10px] font-black uppercase tracking-widest rounded-xl transition-all border border-white/10 flex items-center gap-3 min-w-[160px] justify-between group-focus-within:border-indigo-500/50"
                        >
                            <span>{currentMonth ? months[currentMonth - 1] : "Toute l'année"}</span>
                            <svg class="w-3 h-3 text-slate-500 group-focus-within:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>

                        <div
                            id="month-dropdown-menu"
                            class="absolute top-full right-0 mt-2 bg-[#0A0B10] border border-white/10 rounded-2xl p-2 shadow-2xl opacity-0 scale-95 pointer-events-none group-focus-within:opacity-100 group-focus-within:scale-100 group-focus-within:pointer-events-auto transition-all z-50 min-w-[160px] max-h-[300px] overflow-y-auto no-scrollbar backdrop-blur-xl"
                        >
                            <div class="flex flex-col gap-1">
                                <a
                                    href={getFilterUrl({ month: null })}
                                    class={`px-4 py-3 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all ${
                                        currentMonth === null
                                        ? "bg-indigo-600 text-white"
                                        : "text-slate-500 hover:bg-white/5 hover:text-white"
                                    }`}
                                >
                                    Toute l'année
                                </a>
                                {months.map((m, i) => (
                                    <a
                                        href={getFilterUrl({ month: i + 1 })}
                                        class={`px-4 py-3 rounded-xl text-[9px] font-black uppercase tracking-widest transition-all ${
                                            currentMonth === i + 1
                                            ? "bg-indigo-600 text-white"
                                            : "text-slate-500 hover:bg-white/5 hover:text-white"
                                        }`}
                                    >
                                        {m}
                                    </a>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- KPIs -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <!-- 1. Volume Missions -->
            <div class="glass p-6 rounded-3xl border border-white/5 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-5">
                    <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                </div>
                <div class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-2">Volume Missions</div>
                <div class="text-3xl font-black text-white tabular-nums tracking-tighter">
                    {totals.bookings}
                </div>
            </div>

            <!-- 2. HT -->
            <div class="glass p-6 rounded-3xl border border-white/5 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-5">
                    <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-2">Chiffre d'Affaire HT</div>
                <div class="text-3xl font-black text-white tabular-nums tracking-tighter">
                    {totals.net.toLocaleString('fr-FR', { minimumFractionDigits: 2 })} €
                </div>
            </div>

            <!-- 3. TTC -->
            <div class="glass p-6 rounded-3xl border border-white/10 bg-white shadow-2xl shadow-indigo-500/10 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-10">
                    <svg class="w-12 h-12 text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                </div>
                <div class="text-[10px] font-black text-slate-400 uppercase tracking-[0.2em] mb-2">Total TTC</div>
                <div class="text-3xl font-black text-slate-900 tabular-nums tracking-tighter">
                    {totals.gross.toLocaleString('fr-FR', { minimumFractionDigits: 2 })} €
                </div>
            </div>

            <!-- 4. TVA -->
            <div class="glass p-6 rounded-3xl border border-white/5 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-5">
                    <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </div>
                <div class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-2">TVA Collectée (Impôts)</div>
                <div class="text-3xl font-black text-emerald-400 tabular-nums tracking-tighter">
                    {totals.vat.toLocaleString('fr-FR', { minimumFractionDigits: 2 })} €
                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="flex-1 overflow-y-auto pr-2 custom-scrollbar">
            {movements && movements.length > 0 ? (
                <div class="glass rounded-3xl overflow-hidden border border-white/5 bg-white/[0.01]">
                    <table class="w-full text-left border-collapse">
                        <thead class="bg-white/5 sticky top-0 z-10">
                            <tr class="border-b border-white/5">
                                <th class="px-8 py-3 text-[10px] font-black uppercase tracking-widest text-slate-500">Date</th>
                                <th class="px-8 py-3 text-[10px] font-black uppercase tracking-widest text-slate-500">Client / Course</th>
                                <th class="px-8 py-3 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">HT</th>
                                <th class="px-8 py-3 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">TVA</th>
                                <th class="px-8 py-3 text-right text-[10px] font-black uppercase tracking-widest text-slate-500">TTC</th>
                                <th class="px-8 py-3 text-center text-[10px] font-black uppercase tracking-widest text-slate-500">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5">
                            {movements.map((m) => (
                                <tr class="hover:bg-white/5 transition-colors group">
                                    <td class="px-8 py-4">
                                        <div class="text-sm text-white font-black tabular-nums">
                                            {new Date(m.created_at).toLocaleDateString("fr-FR", { day: "2-digit", month: "short" })}
                                        </div>
                                        <div class="text-[10px] text-slate-500 font-bold uppercase mt-1">
                                            {new Date(m.created_at).toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" })}
                                        </div>
                                    </td>
                                    <td class="px-8 py-4">
                                        <div class="font-black text-white uppercase italic tracking-tighter text-md leading-tight">
                                            {m.bookings.customers.company_name || `${m.bookings.customers.first_name} ${m.bookings.customers.last_name}`}
                                        </div>
                                        <div class="text-[9px] text-slate-500 font-bold uppercase mt-1 tracking-widest">
                                            ID: #{m.booking_id.substring(0, 8)}
                                        </div>
                                    </td>
                                    <td class="px-8 py-4 text-right">
                                        <div class="text-sm font-black text-slate-300 tabular-nums">
                                            {(m.net_amount || 0).toFixed(2)} €
                                        </div>
                                    </td>
                                    <td class="px-8 py-4 text-right">
                                        <div class="text-sm font-black text-emerald-500/80 tabular-nums">
                                            {(m.vat_amount || 0).toFixed(2)} €
                                        </div>
                                    </td>
                                    <td class="px-8 py-4 text-right">
                                        <div class="text-lg font-black text-white tabular-nums italic tracking-tighter">
                                            {(m.gross_amount || 0).toFixed(2)} €
                                        </div>
                                    </td>
                                    <td class="px-8 py-4 text-center">
                                        <button
                                            class="p-2 bg-white/5 hover:bg-white/10 border border-white/10 rounded-xl transition-all text-slate-400 hover:text-white"
                                            title="Imprimer Facture"
                                        >
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                                            </svg>
                                        </button>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            ) : (
                <div class="h-full flex flex-col items-center justify-center text-center pb-20">
                    <div class="w-20 h-20 bg-white/5 rounded-3xl flex items-center justify-center mb-8 border border-white/5">
                        <svg class="w-10 h-10 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-black uppercase italic tracking-wider text-slate-100 mb-2">Aucun mouvement</h3>
                    <p class="text-slate-500 max-w-xs font-medium leading-relaxed">
                        Aucune transaction n'a été enregistrée pour cette période.
                    </p>
                </div>
            )}
        </div>
    </div>
</AppLayout>

<style>
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }
    .no-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }
</style>
