---
// src/pages/app/setup.astro
import AppLayout from "../../layouts/AppLayout.astro";

const { profile, supabase: supabaseAdmin } = Astro.locals;

if (!profile) return Astro.redirect("/login");

// Fetch current tenant data
const { data: tenant } = await supabaseAdmin
    .from("tenants")
    .select("*")
    .eq("id", profile.tenant_id!)
    .maybeSingle();

if (!tenant) return Astro.redirect("/login");
if (tenant.setup_completed) return Astro.redirect("/app/dashboard");

// Handling POST request on the same page
if (Astro.request.method === "POST") {
    try {
        const body = await Astro.request.json();
        const { error } = await supabaseAdmin
            .from("tenants")
            .update({
                ...body,
                setup_completed: true
            })
            .eq("id", profile.tenant_id!);

        if (error) throw error;
        return new Response(JSON.stringify({ success: true }), { status: 200 });
    } catch (err: any) {
        return new Response(JSON.stringify({ error: err.message }), { status: 500 });
    }
}

// Initial values based on company_type from onboarding
const initialLegalForm = tenant.company_type === 'auto_entrepreneur' ? 'AUTO_ENTREPRENEUR' : 'SASU';
const initialVatExempt = tenant.company_type === 'auto_entrepreneur';
---

<AppLayout title="Configuration Légale | VTC HUB">
    <div class="min-h-screen bg-[#050505] text-white flex items-center justify-center p-4">
        <div class="w-full max-w-xl">
            <!-- Header -->
            <div class="text-center mb-8">
                <div class="inline-flex p-3 bg-indigo-500/10 rounded-2xl border border-indigo-500/20 mb-4">
                    <svg class="w-8 h-8 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                    </svg>
                </div>
                <h1 class="text-3xl font-black uppercase tracking-tighter mb-2">Configuration Légale</h1>
                <p class="text-slate-400 text-sm">Complétez votre profil pour activer la facturation et le dashboard.</p>
            </div>

            <!-- Form -->
            <form id="setup-form" class="bg-white/5 border border-white/10 rounded-3xl p-8 backdrop-blur-xl shadow-2xl space-y-6">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Forme Juridique -->
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Forme Juridique</label>
                        <div class="relative group">
                            <select name="legal_form" id="legal_form" required class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50 outline-none appearance-none transition-all cursor-pointer">
                                <option value="AUTO_ENTREPRENEUR" selected={initialLegalForm === 'AUTO_ENTREPRENEUR'}>Auto-entrepreneur</option>
                                <option value="SASU" selected={initialLegalForm === 'SASU'}>SASU</option>
                                <option value="EURL">EURL</option>
                                <option value="SARL">SARL</option>
                                <option value="SAS">SAS</option>
                                <option value="EI">Entreprise Individuelle</option>
                            </select>
                            <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-slate-500 group-hover:text-white transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </div>
                        </div>
                    </div>

                    <!-- SIRET -->
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">SIRET (14 chiffres)</label>
                        <input type="text" name="siret" id="siret_input" required value={tenant.siret} placeholder="123 456 789 00012" inputmode="numeric" maxlength="18" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50" />
                    </div>

                    <!-- RCS -->
                    <div class="space-y-2">
                        <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">RCS (Ville + N°)</label>
                        <input type="text" name="rcs_number" required placeholder="ex: Paris B 123 456 789" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50" />
                    </div>
                </div>

                <!-- Franchise TVA Toggle -->
                <div class="p-4 bg-white/5 rounded-2xl border border-white/10 flex items-center justify-between">
                    <div>
                        <p class="text-sm font-bold text-white">Franchise en base de TVA</p>
                        <p class="text-[10px] text-slate-500">Activé pour les Auto-entrepreneurs (Art. 293 B du CGI)</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                        <input type="checkbox" name="is_vat_exempt" id="is_vat_exempt" class="sr-only peer" checked={initialVatExempt}>
                        <div class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-indigo-600"></div>
                    </label>
                </div>

                <!-- TVA Number (Conditional) -->
                <div id="vat-container" class={initialVatExempt ? "hidden space-y-2" : "space-y-2"}>
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Numéro de TVA Intracommunautaire</label>
                    <input type="text" name="vat_number" placeholder="ex: FR12345678901" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50" />
                </div>

                <!-- Capital Social (Conditional) -->
                <div id="capital-container" class={initialLegalForm === 'AUTO_ENTREPRENEUR' ? "hidden space-y-2" : "space-y-2"}>
                    <label class="text-[10px] font-bold text-slate-500 uppercase tracking-widest px-1">Capital Social (€)</label>
                    <input type="number" name="capital_social" placeholder="ex: 1000" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white focus:outline-none focus:ring-2 focus:ring-indigo-500/50" />
                </div>

                <!-- Submit Button -->
                <button type="submit" id="submit-btn" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-black uppercase tracking-widest py-4 rounded-2xl shadow-xl shadow-indigo-600/20 transition-all flex items-center justify-center gap-3 group">
                    <span>Finaliser mon profil</span>
                    <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                </button>
            </form>

            <!-- Footer info -->
            <p class="mt-6 text-center text-[10px] text-slate-500 uppercase tracking-widest font-bold">
                Données sécurisées & conformité VTC HUB 2026
            </p>
        </div>
    </div>

    <script>
        const form = document.getElementById('setup-form') as HTMLFormElement;
        const vatToggle = document.getElementById('is_vat_exempt') as HTMLInputElement;
        const vatContainer = document.getElementById('vat-container');
        const legalFormSelect = document.getElementById('legal_form') as HTMLSelectElement;
        const capitalContainer = document.getElementById('capital-container');
        const siretInput = document.getElementById('siret_input') as HTMLInputElement;
        const vatInput = document.getElementsByName('vat_number')[0] as HTMLInputElement;

        // Visual Formatter Logic
        const formatInput = (input: HTMLInputElement, spacing: number) => {
            if (!input) return;
            const handler = (e: any) => {
                let cursorPosition = e.target.selectionStart;
                let value = e.target.value.replace(/[^0-9]/g, "");
                let formatted = "";

                // Special case for VAT (starts with FR)
                const isVat = input.name === 'vat_number';
                if (isVat) {
                    formatted = "FR ";
                }

                for (let i = 0; i < value.length; i++) {
                    if (i > 0 && i % spacing === 0) formatted += " ";
                    formatted += value[i];
                }

                const oldLength = e.target.value.length;
                e.target.value = formatted;
                const newLength = formatted.length;

                if (cursorPosition) {
                    cursorPosition += (newLength - oldLength);
                    e.target.setSelectionRange(cursorPosition, cursorPosition);
                }
            };
            input.addEventListener("input", handler);
            // Trigger once for initial values
            input.dispatchEvent(new Event('input'));
        };

        formatInput(siretInput, 3);
        formatInput(vatInput, 3);

        // Logic for VAT Toggle
        vatToggle?.addEventListener('change', () => {
            if (vatToggle.checked) {
                vatContainer?.classList.add('hidden');
            } else {
                vatContainer?.classList.remove('hidden');
            }
        });

        // Logic for Capital Social based on Legal Form
        legalFormSelect?.addEventListener('change', () => {
            if (legalFormSelect.value === 'AUTO_ENTREPRENEUR') {
                capitalContainer?.classList.add('hidden');
                vatToggle.checked = true;
                vatContainer?.classList.add('hidden');
            } else {
                capitalContainer?.classList.remove('hidden');
                // Societies usually have VAT
                vatToggle.checked = false;
                vatContainer?.classList.remove('hidden');
            }
        });

        form?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submit-btn') as HTMLButtonElement;
            btn.disabled = true;
            btn.innerHTML = 'Traitement...';

            const formData = new FormData(form);
            const isVatExempt = vatToggle.checked;

            const payload = {
                legal_form: formData.get('legal_form'),
                is_vat_exempt: isVatExempt,
                siret: (formData.get('siret') as string).replace(/[^0-9]/g, ""),
                rcs_number: formData.get('rcs_number'),
                vat_number: isVatExempt ? null : (formData.get('vat_number') as string).replace(/[^0-9]/g, ""),
                capital_social: formData.get('capital_social') ? parseFloat(formData.get('capital_social') as string) : null,
                setup_completed: true
            };

            try {
                // We use update on tenants table via supabase client
                // Note: Astro.locals.supabase is restricted to server side,
                // so we use the client from window if available or
                // we call an API route. Better to handle it with a fetch to current page
                const response = await fetch(window.location.pathname, {
                    method: 'POST',
                    body: JSON.stringify(payload),
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.ok) {
                    window.location.href = '/app/dashboard';
                } else {
                    alert('Erreur lors de la sauvegarde. Veuillez vérifier les champs.');
                    btn.disabled = false;
                    btn.innerHTML = 'Finaliser mon profil';
                }
            } catch (err) {
                console.error(err);
                alert('Erreur réseau.');
                btn.disabled = false;
                btn.innerHTML = 'Finaliser mon profil';
            }
        });
    </script>
</AppLayout>
