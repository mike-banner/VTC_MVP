---
// src/pages/app/profile.astro
import { DriverList } from "@/components/drivers/DriverList";
import AppLayout from "../../layouts/AppLayout.astro";

const { profile, supabase: supabaseAdmin } = Astro.locals;

if (!profile) return Astro.redirect("/login");

// 1. Récupérer les infos du tenant
const { data: tenant } = await supabaseAdmin
    .from("tenants")
    .select("*")
    .eq("id", profile.tenant_id!)
    .maybeSingle();

if (!tenant) return Astro.redirect("/login");

// 2. Récupérer les infos du chauffeur principal (l'utilisateur connecté)
const { data: driverFull } = await supabaseAdmin
    .from("drivers")
    .select("*, vehicles(*)")
    .eq("user_id", profile.id)
    .maybeSingle();

const vtcLicense = (driverFull as any)?.license_number || "---";
const isAuto = tenant.legal_form === 'auto_entrepreneur';

const tenantName = tenant?.name || "VTC HUB";
const logoUrl = tenant?.logo_url;
---

<AppLayout title="Profil">
    <div class="flex-1 flex flex-col p-8 md:p-12 overflow-y-auto h-full relative custom-scrollbar bg-brand-dark">

        <!-- HEADER -->
        <div class="mb-10 flex-shrink-0">
             <span class="px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-[10px] font-black tracking-widest text-indigo-400 uppercase">Mon Compte</span>
             <h1 class="text-4xl font-black mt-4 uppercase tracking-tighter text-white italic">Profil <span class="text-indigo-500">Business</span></h1>
        </div>

        <!-- 🏢 CARD 1: PROFIL ENTREPRISE (FULL WIDTH) -->
        <div class="glass p-8 md:p-12 rounded-[3rem] border border-white/10 bg-white/[0.02] mb-10 relative z-10 group shadow-2xl shadow-indigo-500/5">
            <div class="absolute top-0 right-0 p-10 opacity-[0.03] pointer-events-none group-hover:opacity-[0.05] transition-opacity">
                <svg class="w-64 h-64" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>

            <div class="relative z-20 flex flex-row items-center md:items-start gap-6 md:gap-12 text-left">
                <!-- Logo -->
                {logoUrl ? (
                    <div class="w-20 h-20 md:w-32 md:h-32 bg-white rounded-2xl md:rounded-3xl p-3 md:p-4 shadow-2xl flex items-center justify-center border border-white/10 flex-shrink-0">
                        <img src={logoUrl} alt={tenantName} class="w-full h-full object-contain" />
                    </div>
                ) : (
                    <div class="w-20 h-20 md:w-32 md:h-32 bg-indigo-600 rounded-2xl md:rounded-3xl flex items-center justify-center shadow-2xl text-white font-black text-4xl md:text-6xl italic border border-white/10 flex-shrink-0">
                        {tenantName.charAt(0).toUpperCase()}
                    </div>
                )}

                <div class="flex-1">
                    <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-4 mb-4 md:mb-6">
                        <h2 class="text-2xl md:text-5xl font-black text-white uppercase tracking-tighter italic leading-tight md:leading-none">{tenantName}</h2>
                        <span class="inline-flex items-center px-2 py-0.5 md:px-3 md:py-1 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-[7px] md:text-[8px] font-black text-emerald-400 uppercase tracking-widest self-start md:self-center">
                            Compte Vérifié
                        </span>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 text-left">
                        <div>
                            <p class="text-[10px] font-bold uppercase text-slate-500 tracking-widest mb-1">SIRET</p>
                            <p class="text-base font-semibold text-white tabular-nums">{tenant.siret?.trim() || "---"}</p>
                        </div>

                        {isAuto ? (
                            <div>
                                <p class="text-[10px] font-bold uppercase text-slate-500 tracking-widest mb-1">Fiscalité</p>
                                <p class="text-base font-semibold text-indigo-400 uppercase tracking-tighter">Exonéré (Art. 293 B)</p>
                            </div>
                        ) : (
                            <>
                                <div>
                                    <p class="text-[10px] font-bold uppercase text-slate-500 tracking-widest mb-1">RCS</p>
                                    <p class="text-base font-semibold text-white truncate">{tenant.rcs_number?.trim() || "---"}</p>
                                </div>
                                <div>
                                    <p class="text-[10px] font-bold uppercase text-slate-500 tracking-widest mb-1">TVA</p>
                                    <p class="text-base font-semibold text-white tabular-nums">{tenant.vat_number?.trim() || "---"}</p>
                                </div>
                            </>
                        )}
                    </div>
                </div>
            </div>
        </div>

        <!-- 👤 SECTION 2: CHAUFFEUR PRINCIPAL -->
        <div class="mb-12 relative z-10">
            <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-indigo-400 mb-6 flex items-center gap-3">
                <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
                Chauffeur Principal
            </h3>

            <div class="glass p-5 md:p-8 rounded-[2.5rem] border border-white/10 bg-white/[0.02] flex flex-row items-center gap-4 md:gap-10 relative overflow-hidden">
                <!-- Icon -->
                <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl md:rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 flex-shrink-0">
                    <svg class="w-6 h-6 md:w-8 md:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                </div>

                <!-- Info -->
                <div class="flex-1 min-w-0">
                    <p class="text-[9px] md:text-[10px] font-bold uppercase text-slate-500 tracking-widest mb-0.5">Identité</p>
                    <p class="text-lg md:text-2xl font-black text-white uppercase tracking-tighter mb-1 truncate">{profile.first_name} {profile.last_name}</p>
                    <div class="text-[10px] md:text-[11px] font-medium text-slate-400 uppercase tracking-widest flex items-center gap-2">
                        <svg class="w-3 h-3 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                        {(driverFull as any)?.phone || "---"}
                    </div>
                </div>

                <!-- Carte VTC (Desktop & Mobile horizontal) -->
                <div class="px-4 md:px-8 py-3 md:py-4 bg-indigo-500/5 rounded-xl md:rounded-2xl border border-indigo-500/10 flex-shrink-0 text-right">
                    <p class="text-[9px] md:text-[10px] font-bold uppercase text-slate-500 tracking-widest mb-0.5">Carte VTC</p>
                    <p class="text-sm md:text-xl font-black text-indigo-400 tabular-nums uppercase">{vtcLicense}</p>
                </div>
            </div>
        </div>

        <!-- 👥 SECTION 3: COLLABORATEURS -->
            <div class="pb-20">
                <DriverList client:only="react" tenantId={profile.tenant_id!} userId={profile.id} hidePrimary={true} />
            </div>

    </div>
</AppLayout>
