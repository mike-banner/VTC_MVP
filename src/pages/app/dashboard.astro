---
import { MissionCockpit } from "@/components/dashboard/MissionCockpit";
import { ImmediateActions } from "@/components/dashboard/ImmediateActions";
import { StripeConnectionCard } from "@/components/dashboard/StripeConnectionCard";
import { supabase } from "@/lib/supabase/client";
import AppLayout from "../../layouts/AppLayout.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import Card from "../../components/ui/Card.astro";

const { profile, supabase: supabaseAdmin } = Astro.locals;

if (!profile) return Astro.redirect("/login");

// 📅 Calcul des dates pour les KPIs
const now = new Date();
const startOfToday = new Date(
    now.getFullYear(),
    now.getMonth(),
    now.getDate(),
).toISOString();
const startOfMonth = new Date(
    now.getFullYear(),
    now.getMonth(),
    1,
).toISOString();

// 1️⃣ Courses du mois (Métier)
const { count: monthlyCount } = await supabaseAdmin
    .from("bookings")
    .select("*", { count: "exact", head: true })
    .eq("current_tenant_id", profile.tenant_id!)
    .gte("pickup_time", startOfMonth);

// 1bis️⃣ Total Missions (All-time)
const { count: totalCount } = await supabaseAdmin
    .from("bookings")
    .select("*", { count: "exact", head: true })
    .eq("current_tenant_id", profile.tenant_id!);

// 🎯 Ratings Dynamiques & Driver ID
const { data: driverInfo } = await supabaseAdmin
    .from("drivers")
    .select("id")
    .eq("user_id", profile.id)
    .maybeSingle();

const driverId = driverInfo?.id;

const { data: ratingData } = await supabaseAdmin
    .from("driver_ratings")
    .select("average_rating")
    .eq("driver_id", driverId)
    .maybeSingle();

const rating = ratingData?.average_rating || 5.0;

// 2️⃣ Données Financières & KPIs (Source: Vue Ledger & Bookings)
const { data: kpi } = await supabaseAdmin
    .from("tenant_dashboard_kpi")
    .select("*")
    .eq("tenant_id", profile.tenant_id!)
    .limit(1)
    .maybeSingle();

const monthlyRevenue = kpi?.monthly_net_revenue || 0;

// 3️⃣ Missions (Mise en avant et Focus)
// Garde : pickup_time dans les dernières 24h pour ignorer les missions bloquées en test
const twentyFourHoursAgo = new Date(now.getTime() - 24 * 60 * 60 * 1000).toISOString();
const { data: ongoingMissions } = await supabaseAdmin
    .from("bookings")
    .select("*, customers!inner(*)")
    .eq("current_tenant_id", profile.tenant_id!)
    .eq("mission_status", "in_progress")
    .gte("pickup_time", twentyFourHoursAgo)
    .limit(1);

const fiveMinAgo = new Date(now.getTime() - 5 * 60 * 1000).toISOString();
const { data: overdueData } = await supabaseAdmin
    .from("bookings")
    .select("*, customers!inner(*)")
    .eq("current_tenant_id", profile.tenant_id!)
    .eq("mission_status", "not_started")
    .lt("pickup_time", fiveMinAgo)
    .not("status", "in", "(cancelled,cancelled_no_refund,cancelled_pending_refund,cancelled_refunded)")
    .order("pickup_time", { ascending: true })
    .limit(1);

const overdueBooking = overdueData?.[0] ?? null;

const { data: allUpcoming } = await supabaseAdmin
    .from("bookings")
    .select("*, customers!inner(*)")
    .eq("current_tenant_id", profile.tenant_id!)
    .gte("pickup_time", now.toISOString())
    .not("mission_status", "in", "(in_progress,completed)")
    .not("status", "in", "(cancelled,cancelled_no_refund,cancelled_pending_refund,cancelled_refunded)")
    .order("pickup_time", { ascending: true })
    .limit(3);

const upcomingBookings = allUpcoming ?? [];
const immediateMission = ongoingMissions?.[0] ?? null;

// 4️⃣ Courses en attente de validation (Mise à dispo)
const { data: validatingBookings } = await supabaseAdmin
    .from("bookings")
    .select("*, customers!inner(*)")
    .eq("current_tenant_id", profile.tenant_id!)
    .eq("status", "pending")
    .order("created_at", { ascending: true });

// 5️⃣ Dernières courses (Historique court)
const { data: pastBookings } = await supabaseAdmin
    .from("bookings")
    .select("*, customers!inner(*)")
    .eq("current_tenant_id", profile.tenant_id!)
    .lt("pickup_time", now.toISOString())
    .neq("status", "cancelled")
    .order("pickup_time", { ascending: false })
    .limit(2);


// 7️⃣ Récupérer les infos du tenant (Logo, SIRET, Setup Status)
const { data: tenant } = await supabaseAdmin
    .from("tenants")
    .select("name, logo_url, siret, setup_completed, legal_form, rcs_number, vat_number, is_vat_exempt")
    .eq("id", profile.tenant_id!)
    .maybeSingle();

// 🚀 Blocage si Setup non terminé
if (tenant && !tenant.setup_completed) {
    return Astro.redirect("/app/setup");
}

const tenantName = tenant?.name || "VTC HUB";
const logoUrl = tenant?.logo_url;
const siret = tenant?.siret || "Non renseigné";

// 8️⃣ Récupérer les infos du chauffeur complet (VTC License)
const { data: driverFull } = await supabaseAdmin
    .from("drivers")
    .select("*, vehicles(*)")
    .eq("user_id", profile.id)
    .maybeSingle();

const vtcLicense = (driverFull as any)?.license_number || "---";

// 9️⃣ Récupérer le véhicule (Assigné au chauffeur OU Premier du tenant)
let activeVehicle = Array.isArray((driverFull as any)?.vehicles)
    ? (driverFull as any)?.vehicles[0]
    : (driverFull as any)?.vehicles;

if (!activeVehicle) {
    const { data: tenantVehicle } = await supabaseAdmin
        .from("vehicles")
        .select("*")
        .eq("tenant_id", profile.tenant_id!)
        .limit(1)
        .maybeSingle();
    activeVehicle = tenantVehicle;
}

// 10️⃣ Données Comptables (Ledger)
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1;

const { data: ledgerMonth } = await supabaseAdmin
    .from("tenant_accounting_ledger")
    .select("*")
    .eq("tenant_id", profile.tenant_id!)
    .eq("year", currentYear)
    .eq("month", currentMonth)
    .maybeSingle();

const { data: fiscalYearData } = await supabaseAdmin
    .rpc("get_fiscal_summary", {
        t_id: profile.tenant_id!,
        f_year: currentYear
    });

const fiscalYear = fiscalYearData as any;
---

<AppLayout title="Accueil">
    <div class={`flex flex-col p-4 sm:p-8 bg-brand-dark selection:bg-indigo-500/30 ${immediateMission ? 'pb-20' : 'pb-[calc(7rem+env(safe-area-inset-bottom,0px))] md:pb-28'}`}>
        <div class="flex flex-col gap-5">

            {/* MISSION EN COURS — priorité maximale, seul contenu affiché */}
            {immediateMission && (
                <div class="animate-in fade-in slide-in-from-top-2 duration-500">
                    <Card padding="none" rounded="2xl" class="border-emerald-500/30 bg-emerald-500/[0.03] shadow-2xl shadow-emerald-500/10 group overflow-hidden booking-row cursor-pointer active:scale-[0.99] transition-transform" data-booking={JSON.stringify(immediateMission)}>
                        <div class="flex items-center gap-3 px-4 py-2 bg-emerald-500/10 border-b border-emerald-500/15">
                            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse flex-shrink-0"></span>
                            <p class="text-[10px] font-black uppercase tracking-widest text-emerald-400">Mission en cours</p>
                        </div>
                        <div class="flex flex-col lg:flex-row lg:items-center">
                            <div class="flex items-center gap-4 p-5 lg:p-6 lg:border-r border-white/5 min-w-[200px]">
                                <div class="w-12 h-12 rounded-xl bg-emerald-500/20 border border-emerald-500/30 flex flex-col items-center justify-center text-emerald-400 shadow-lg">
                                    <span class="text-[10px] font-black uppercase leading-none opacity-70">{new Date(immediateMission.pickup_time).toLocaleDateString('fr-FR', { month: 'short' })}</span>
                                    <span class="text-lg font-black leading-none">{new Date(immediateMission.pickup_time).toLocaleDateString('fr-FR', { day: '2-digit' })}</span>
                                </div>
                                <div>
                                    <p class="text-2xl font-black text-white tracking-tighter tabular-nums leading-none mb-1">
                                        {new Date(immediateMission.pickup_time).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
                                    </p>
                                    <p class="text-[10px] font-black text-emerald-400/70 uppercase tracking-widest">Démarrée</p>
                                </div>
                            </div>
                            <div class="flex-1 p-5 lg:p-6">
                                <p class="text-base font-black text-white uppercase tracking-tighter truncate mb-1">
                                    {immediateMission.customers.first_name} {immediateMission.customers.last_name}
                                </p>
                                <div class="space-y-1">
                                    <div class="flex items-center gap-2 text-[11px] text-slate-400 truncate">
                                        <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></div>
                                        {immediateMission.pickup_address}
                                    </div>
                                    <div class="flex items-center gap-2 text-[11px] text-slate-500 truncate">
                                        <div class="w-1.5 h-1.5 rounded-full bg-rose-500 shrink-0"></div>
                                        {immediateMission.dropoff_address || 'Destination à confirmer'}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </Card>
                </div>
            )}

            {/* COURSE EN RETARD — masquée pendant une mission active */}
            {!immediateMission && overdueBooking && (
                <div class="animate-in fade-in slide-in-from-top-2 duration-[400ms]">
                    <div class="rounded-2xl border border-rose-500/40 bg-rose-500/[0.04] shadow-2xl shadow-rose-500/10 overflow-hidden">
                        <div class="flex items-center gap-3 px-4 py-2 bg-rose-500/10 border-b border-rose-500/20">
                            <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse flex-shrink-0"></span>
                            <p class="text-[10px] font-black uppercase tracking-widest text-rose-400">Course non démarrée — en retard</p>
                        </div>
                        <div class="flex flex-col lg:flex-row lg:items-center">
                            <div class="flex items-center gap-4 p-5 lg:border-r border-rose-500/10 min-w-[200px]">
                                <div class="w-12 h-12 rounded-xl bg-rose-500/20 border border-rose-500/30 flex flex-col items-center justify-center text-rose-400 shadow-lg">
                                    <span class="text-[10px] font-black uppercase leading-none opacity-70">{new Date(overdueBooking.pickup_time).toLocaleDateString('fr-FR', { month: 'short' })}</span>
                                    <span class="text-lg font-black leading-none">{new Date(overdueBooking.pickup_time).toLocaleDateString('fr-FR', { day: '2-digit' })}</span>
                                </div>
                                <div>
                                    <p class="text-2xl font-black text-rose-300 tracking-tighter tabular-nums leading-none mb-1">
                                        {new Date(overdueBooking.pickup_time).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
                                    </p>
                                    <p class="text-[10px] font-black text-rose-400/70 uppercase tracking-widest">Heure dépassée</p>
                                </div>
                            </div>
                            <div class="flex-1 p-5 space-y-1">
                                <p class="text-base font-black text-white uppercase tracking-tighter truncate">
                                    {overdueBooking.customers.first_name} {overdueBooking.customers.last_name}
                                </p>
                                <p class="text-[11px] text-rose-400/60 truncate">{overdueBooking.pickup_address}</p>
                                <a href="/app/bookings" class="inline-flex items-center gap-1.5 mt-3 px-4 py-2.5 bg-rose-600 hover:bg-rose-500 text-white text-[11px] font-black uppercase tracking-widest rounded-xl transition-all active:scale-95">
                                    Démarrer maintenant →
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            )}

            {/* KPIs — masqués pendant une mission active */}
            {!immediateMission && (
                <StripeConnectionCard
                    client:only="react"
                    tenantId={profile.tenant_id!}
                    monthlyRevenue={monthlyRevenue}
                    totalCount={totalCount || 0}
                    rating={rating}
                />
            )}

            {/* À VALIDER (MODALITÉ MISE À DISPO) — masqué pendant une mission active */}
            {!immediateMission && validatingBookings && validatingBookings.length > 0 && (
                <div class="animate-in fade-in duration-500">
                    <h3 class="text-[11px] font-black uppercase tracking-[0.2em] flex items-center gap-3 text-amber-500 mb-3">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" />
                        Actions Requises
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
                        {validatingBookings.map((booking) => (
                            <Card padding="sm" rounded="xl" class="border-amber-500/10 bg-amber-500/[0.02] hover:border-amber-500/20 group">
                                <div class="flex justify-between items-center mb-3">
                                    <Badge variant="amber">Mise à Disposition</Badge>
                                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none">
                                        {new Date(booking.pickup_time).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' })}
                                    </span>
                                </div>
                                <div class="mb-3">
                                    <p class="text-base font-black text-white uppercase tracking-tighter truncate">
                                        {booking.customers.first_name} {booking.customers.last_name}
                                    </p>
                                </div>
                                <div class="flex justify-between items-center bg-black/20 p-2 rounded-lg border border-white/5 mb-3">
                                    <span class="text-[11px] font-black uppercase text-slate-400">Estimation</span>
                                    <span class="text-lg font-black text-white tabular-nums">{Number(booking.total_amount).toFixed(0)}€</span>
                                </div>
                                <Button href={`/app/bookings?status=pending`} variant="amber" class="w-full">
                                    Finaliser
                                </Button>
                            </Card>
                        ))}
                    </div>
                </div>
            )}

        </div>
    </div>

            {/* AGENDA DOCK */}
    <div id="upcoming-dock" class="fixed bottom-16 md:bottom-0 left-0 md:left-72 right-0 z-[80] bg-black/80 backdrop-blur-2xl border-t border-white/[0.08] shadow-[0_-8px_32px_rgba(0,0,0,0.4)] animate-in slide-in-from-bottom duration-700">

        {/* MOBILE: slim 44px strip */}
        <div class="md:hidden" style="height:44px">
            {upcomingBookings.length > 0 ? (
                <div class="flex items-center h-full px-4 gap-3">
                    <div class="flex items-center gap-2.5 flex-1 min-w-0 booking-row cursor-pointer active:opacity-60 transition-opacity"
                         data-booking={JSON.stringify(upcomingBookings[0])}>
                        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0 animate-pulse"></span>
                        <p class="text-[11px] font-black text-white uppercase tracking-tight truncate flex-1">
                            {upcomingBookings[0].customers.first_name} {upcomingBookings[0].customers.last_name}
                        </p>
                        <span class="text-[11px] font-black tabular-nums text-indigo-400 shrink-0">
                            {new Date(upcomingBookings[0].pickup_time).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
                        </span>
                    </div>
                    <div class="flex items-center gap-2 shrink-0">
                        {upcomingBookings.length > 1 && (
                            <span class="text-[10px] font-black text-slate-400 bg-white/[0.06] px-1.5 py-0.5 rounded border border-white/5 tabular-nums">
                                +{upcomingBookings.length - 1}
                            </span>
                        )}
                        <a href="/app/bookings" class="text-[10px] font-black text-slate-500 hover:text-white uppercase tracking-widest transition-colors shrink-0">
                            Agenda →
                        </a>
                    </div>
                </div>
            ) : (
                <div class="flex items-center h-full px-4 gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-slate-700 shrink-0"></span>
                    <p class="text-[10px] font-black uppercase text-slate-500 tracking-widest flex-1">Agenda libre</p>
                    <a href="/app/bookings" class="text-[10px] font-black text-slate-500 hover:text-white uppercase tracking-widest transition-colors">Gérer →</a>
                </div>
            )}
        </div>

        {/* DESKTOP: full card layout */}
        <div class="hidden md:block max-w-5xl mx-auto p-4">
            <div class="flex items-center justify-between mb-3 px-1">
                <div class="flex items-center gap-2">
                    <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
                    <h3 class="text-[10px] font-black uppercase tracking-[0.2em] text-indigo-400">Prochaines Missions</h3>
                </div>
                <a href="/app/bookings" class="text-[10px] font-black uppercase text-slate-500 hover:text-white transition-colors">Voir tout →</a>
            </div>
            <div class="flex gap-3 overflow-x-auto no-scrollbar pb-1">
                {upcomingBookings.length > 0 ? (
                    upcomingBookings.map((booking) => (
                        <div class="flex-shrink-0 w-[220px] glass p-3 rounded-2xl border border-white/5 bg-white/[0.02] flex items-center gap-3 booking-row cursor-pointer active:scale-95 transition-all"
                             data-booking={JSON.stringify(booking)}>
                            <div class="w-9 h-9 bg-indigo-600 rounded-xl flex flex-col items-center justify-center shadow-lg shadow-indigo-600/20 shrink-0">
                                <span class="text-[9px] font-black text-white/50 uppercase leading-none mb-0.5">{new Date(booking.pickup_time).toLocaleDateString('fr-FR', { month: 'short' })}</span>
                                <span class="text-sm font-black text-white leading-none">{new Date(booking.pickup_time).toLocaleDateString('fr-FR', { day: '2-digit' })}</span>
                            </div>
                            <div class="min-w-0">
                                <p class="text-[10px] font-black text-white uppercase tracking-tighter truncate">
                                    {booking.customers.first_name} {booking.customers.last_name}
                                </p>
                                <p class="text-[10px] font-bold text-slate-500 uppercase tabular-nums">
                                    {new Date(booking.pickup_time).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
                                </p>
                            </div>
                        </div>
                    ))
                ) : (
                    <div class="flex-grow glass p-4 rounded-xl border border-dashed border-white/5 bg-white/[0.01] flex items-center justify-center">
                        <p class="text-[10px] font-black uppercase text-slate-500 tracking-widest">Aucune mission</p>
                    </div>
                )}
            </div>
        </div>
    </div>
</AppLayout>

<!-- 🎭 MODAL: DÉTAILS MISSION ELITE -->
<div id="booking-modal" data-driver-id={driverId} class="fixed inset-0 z-[100] flex items-center justify-center p-4 sm:p-6 opacity-0 pointer-events-none transition-all duration-500 overflow-hidden">
    <div class="absolute inset-0 bg-black/90 backdrop-blur-md modal-overlay"></div>
    <div class="relative glass max-w-2xl w-full max-h-[90vh] rounded-[3rem] border border-white/10 shadow-[0_0_100px_rgba(79,70,229,0.1)] overflow-y-auto custom-scrollbar transform scale-95 transition-all duration-500 bg-[#0A0A0B]">
        <div class="p-8 sm:p-12">
            <!-- Header Modal -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-10 pb-10 border-b border-white/5">
                <div class="flex items-center gap-5">
                    <div class="w-14 h-14 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-2xl shadow-indigo-600/40 transform -rotate-3">
                        <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                    </div>
                    <div>
                        <h2 class="text-3xl font-black uppercase text-white tracking-tighter leading-none mb-2">Détails <span class="text-indigo-500">Mission</span></h2>
                        <div class="flex items-center gap-2">
                            <p id="modal-booking-ref" class="text-slate-600 text-[10px] font-black uppercase tracking-widest leading-none">REF: #---</p>
                            <span id="modal-booking-type" class="px-2 py-0.5 rounded-[4px] text-[10px] font-black uppercase tracking-widest border border-white/10 text-slate-500 leading-none">---</span>
                        </div>
                    </div>
                </div>
                <div id="modal-status-badge" class="px-4 py-2 bg-indigo-500/10 rounded-xl border border-indigo-500/20 text-[10px] font-black uppercase tracking-widest text-indigo-400 text-center">
                    ---
                </div>
            </div>

            <div class="space-y-12">
                <!-- CLIENT INFO -->
                <div class="relative">
                    <div class="absolute -left-6 top-0 bottom-0 w-1 bg-indigo-500 rounded-full opacity-50"></div>
                    <p class="text-[10px] font-black uppercase text-slate-500 tracking-[0.2em] mb-4">Client</p>
                    <div class="flex items-center justify-between gap-6">
                        <h3 id="modal-client-name" class="text-2xl font-black text-white uppercase tracking-tighter leading-none">---</h3>
                        <div class="flex gap-2">
                            <a id="modal-client-phone-link" href="#" class="w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-500 hover:bg-emerald-500/20 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- ITINÉRAIRE -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                    <div class="space-y-8">
                        <div class="relative pl-6 space-y-8">
                             <div class="absolute left-1 top-2 bottom-2 w-0.5 border-l-2 border-dashed border-white/10"></div>
                             <div class="relative">
                                <div class="absolute -left-[23px] top-1 w-3 h-3 rounded-full bg-indigo-500 shadow-[0_0_10px_rgba(79,70,229,0.5)]"></div>
                                <p class="text-[10px] font-black uppercase text-slate-500 tracking-widest mb-1">Point de Prise en charge</p>
                                <p id="modal-pickup" class="text-sm font-bold text-slate-200 leading-tight">---</p>
                             </div>
                             <div class="relative">
                                <div class="absolute -left-[23px] top-1 w-3 h-3 rounded-full bg-rose-500 shadow-[0_0_100px_rgba(244,63,94,0.5)]"></div>
                                <p class="text-[10px] font-black uppercase text-slate-500 tracking-widest mb-1">Destination Finale</p>
                                <p id="modal-dropoff" class="text-sm font-bold text-slate-200 leading-tight">---</p>
                             </div>
                        </div>
                        <a id="modal-map-link" href="#" target="_blank" class="flex items-center justify-center gap-3 px-6 py-4 bg-white/5 border border-white/5 rounded-2xl text-[10px] font-black uppercase tracking-widest text-slate-400 hover:text-white hover:bg-white/10 transition-all">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A2 2 0 013 15.382V5.618a2 2 0 011.106-1.789L9 1.118l6 3 5.447-2.724A2 2 0 0121 3.236v9.764a2 2 0 01-1.106 1.789L15 17.382l-6 2.618z" /></svg>
                            Ouvrir dans Google Maps
                        </a>
                    </div>

                    <div class="glass p-8 rounded-[2.5rem] border border-white/5 bg-indigo-500/[0.03] flex flex-col items-center justify-center text-center">
                        <p class="text-[10px] font-black uppercase text-indigo-400 tracking-[0.2em] mb-2">Heure du RDV</p>
                        <h4 id="modal-time" class="text-5xl font-black text-white tracking-tighter leading-none mb-2 tabular-nums">---</h4>
                        <p id="modal-date" class="text-[10px] font-black uppercase text-slate-500 tracking-widest underline decoration-indigo-500/30 underline-offset-4">---</p>
                    </div>
                </div>

                <!-- CARACTÉRISTIQUES -->
                <div class="grid grid-cols-2 gap-4">
                    <div class="glass p-5 rounded-[2rem] border border-white/5 flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-indigo-400">
                             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
                        </div>
                        <div>
                            <p class="text-[10px] font-black uppercase text-slate-500 mb-0.5">Passagers</p>
                            <span id="modal-passengers" class="text-lg font-black text-white">---</span>
                        </div>
                    </div>
                    <div class="glass p-5 rounded-[2rem] border border-white/5 flex items-center gap-4">
                        <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-indigo-400">
                             <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" /></svg>
                        </div>
                        <div>
                            <p class="text-[10px] font-black uppercase text-slate-500 mb-0.5">Valises</p>
                            <span id="modal-luggage" class="text-lg font-black text-white">---</span>
                        </div>
                    </div>
                </div>

                <!-- 🕹️ MISSION COCKPIT CONTAINER -->
                <div id="mission-cockpit-root"></div>

                <!-- NOTES -->
                <div class="glass p-6 rounded-[2rem] border border-white/5">
                    <p class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-3">Instructions Chauffeur</p>
                    <p id="modal-notes" class="text-xs text-slate-500 font-medium leading-relaxed">---</p>
                </div>

                <!-- FINANCES & ACTION -->
                <div class="flex flex-col gap-4">
                    <div class="flex items-center justify-between p-6 bg-indigo-600 rounded-[2rem] shadow-2xl shadow-indigo-600/20">
                        <div>
                            <p class="text-[10px] font-black uppercase text-white/50 mb-0.5">Montant Mission</p>
                            <h4 id="modal-amount" class="text-3xl font-black text-white leading-none tabular-nums">---€</h4>
                        </div>
                        <div class="text-white/30">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                        </div>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-3 mt-4">
                        <button id="modal-accept-btn" class="hidden flex-1 py-5 bg-white text-slate-950 text-[10px] font-black uppercase tracking-widest rounded-2xl transition-all shadow-xl active:scale-95 disabled:opacity-50">
                            Prendre la main sur la course
                        </button>
                        <button class="close-modal flex-1 py-5 bg-white/5 hover:bg-white/10 text-white text-[10px] font-black uppercase tracking-widest rounded-2xl transition-all border border-white/5 active:scale-95">
                            Fermer
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    import { supabase } from "@/lib/supabase/client";
    import { showToast } from "@/scripts/toast";

    const modal = document.getElementById('booking-modal');
    const driverId = modal?.getAttribute('data-driver-id');
    const closeBtns = document.querySelectorAll('.close-modal');
    const overlay = document.querySelector('.modal-overlay');

    // 🕹️ LOGIQUE TERRAIN (JS PUR)
    const updateTerrainUI = (booking: any) => {
        const root = document.getElementById('mission-cockpit-root');
        if (!root) return;

        const notes = booking.notes || '';
        const status = booking.status;
        const hasTag = (tag: string) => notes.includes(`[terrain] ${tag}_at=`);

        // Fallback sur mission_status si les tags notes sont absents
        const isEnRoute = hasTag('en_route') || booking.mission_status === 'not_started' || booking.mission_status === 'in_progress';
        const isOnBoard = hasTag('on_board') || booking.mission_status === 'in_progress';
        const isCompleted = status === 'completed' || booking.mission_status === 'completed';

        if (isCompleted || status === 'cancelled') {
            root.innerHTML = '';
            return;
        }

        const pickupDate = new Date(booking.pickup_time);
        const availableAtMs = pickupDate.getTime() - 15 * 60 * 1000;
        const canStart = Date.now() >= availableAtMs;

        const stepDone = `w-7 h-7 rounded-xl bg-slate-800 border border-white/5 flex items-center justify-center shrink-0`;
        const checkIcon = `<svg class="w-3.5 h-3.5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>`;
        const connector = `<div class="ml-3.5 w-px h-2 bg-white/5"></div>`;

        root.innerHTML = `
            <div class="flex flex-col gap-1 p-5 bg-black/20 rounded-[2rem] border border-white/5 mt-6 animate-in fade-in duration-500">
                <div class="flex items-center justify-between mb-3">
                    <h4 class="text-[10px] font-black uppercase tracking-[0.2em] text-slate-500">Pilotage Mission</h4>
                    ${!canStart && !isEnRoute ? `
                        <div class="px-2 py-1 bg-amber-500/5 rounded-lg border border-amber-500/20 text-[10px] font-black text-amber-500 tabular-nums">
                            Dispo à ${new Date(availableAtMs).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
                        </div>
                    ` : ''}
                </div>

                ${isEnRoute ? `
                    <div class="flex items-center gap-3 px-1 py-1 opacity-40">
                        <div class="${stepDone}">${checkIcon}</div>
                        <p class="text-[11px] font-black uppercase text-slate-600 tracking-tight line-through">En route</p>
                    </div>
                ` : `
                    <button id="btn-en-route" ${!canStart ? 'disabled' : ''} class="flex items-center gap-3 p-3 rounded-2xl border transition-all bg-indigo-600 border-indigo-500/50 text-white hover:bg-indigo-500 active:scale-95 disabled:opacity-40 disabled:cursor-not-allowed">
                        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
                        <span class="text-[11px] font-black uppercase tracking-tighter flex-1">En route</span>
                        <svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </button>
                `}

                ${connector}

                ${isOnBoard ? `
                    <div class="flex items-center gap-3 px-1 py-1 opacity-40">
                        <div class="${stepDone}">${checkIcon}</div>
                        <p class="text-[11px] font-black uppercase text-slate-600 tracking-tight line-through">Client à bord</p>
                    </div>
                ` : `
                    <button id="btn-on-board" ${!isEnRoute ? 'disabled' : ''} class="flex items-center gap-3 p-3 rounded-2xl border transition-all ${isEnRoute ? 'bg-amber-500 border-amber-400/50 text-white hover:bg-amber-400 active:scale-95' : 'bg-white/5 border-white/5 text-slate-600'} disabled:opacity-40 disabled:cursor-not-allowed">
                        <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                        <span class="text-[11px] font-black uppercase tracking-tighter flex-1">Client à bord</span>
                        ${isEnRoute ? `<svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>` : ''}
                    </button>
                `}

                ${connector}

                <button id="btn-complete" ${!isOnBoard ? 'disabled' : ''} class="flex items-center gap-3 p-4 rounded-2xl border transition-all ${isOnBoard ? 'bg-rose-600 border-rose-500/50 text-white hover:bg-rose-500 active:scale-95 shadow-lg shadow-rose-600/20' : 'bg-white/5 border-white/5 text-slate-700'} disabled:opacity-40 disabled:cursor-not-allowed">
                    <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    <span class="text-[11px] font-black uppercase tracking-tighter flex-1">${isOnBoard ? 'Terminer la course' : 'Terminée'}</span>
                    ${isOnBoard ? `<svg class="w-4 h-4 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>` : ''}
                </button>

                <div id="cockpit-error" class="hidden mt-2 px-3 py-2 bg-rose-500/10 border border-rose-500/20 rounded-xl text-[11px] font-semibold text-rose-400"></div>
            </div>
        `;

        const showCockpitError = (msg: string) => {
            const el = document.getElementById('cockpit-error');
            if (!el) return;
            el.textContent = msg;
            el.classList.remove('hidden');
            setTimeout(() => el.classList.add('hidden'), 4000);
        };

        const runAction = async (action: string) => {
            const btn = document.getElementById(`btn-${action === 'en_route' ? 'en-route' : action === 'on_board' ? 'on-board' : 'complete'}`);
            if (btn) (btn as HTMLButtonElement).disabled = true;

            try {
                const res = await fetch('/api/missions/terrain-transition', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ booking_id: booking.id, action })
                });
                const data = await res.json();
                if (data.success) {
                    booking.notes = data.notes;
                    if (action === 'completed') {
                        booking.status = 'completed';
                        showToast('Course terminée', 'success', 2000);
                        setTimeout(() => window.location.reload(), 1800);
                    } else {
                        updateTerrainUI(booking);
                    }
                } else {
                    showCockpitError(data.error || 'Une erreur est survenue');
                    updateTerrainUI(booking);
                }
            } catch (err) {
                showCockpitError('Erreur réseau — vérifie ta connexion');
                updateTerrainUI(booking);
            }
        };

        document.getElementById('btn-en-route')?.addEventListener('click', () => runAction('en_route'));
        document.getElementById('btn-on-board')?.addEventListener('click', () => runAction('on_board'));
        document.getElementById('btn-complete')?.addEventListener('click', () => runAction('completed'));
    };

    const toggleModal = () => {
        modal?.classList.toggle('opacity-0');
        modal?.classList.toggle('pointer-events-none');
        modal?.querySelector('.relative')?.classList.toggle('scale-95');
        document.body.classList.toggle('overflow-hidden');
    };

    document.querySelectorAll('.booking-row').forEach(row => {
        row.addEventListener('click', () => {
            const booking = JSON.parse(row.getAttribute('data-booking') || '{}');
            updateTerrainUI(booking);

            // Populate Modal
            const nameEl = document.getElementById('modal-client-name');
            const emailEl = document.getElementById('modal-client-email');
            const emailLinkEl = document.getElementById('modal-client-email-link') as HTMLAnchorElement;
            const phoneEl = document.getElementById('modal-client-phone');
            const phoneLinkEl = document.getElementById('modal-client-phone-link') as HTMLAnchorElement;
            const pickupEl = document.getElementById('modal-pickup');
            const dropoffEl = document.getElementById('modal-dropoff');
            const passengersEl = document.getElementById('modal-passengers');
            const luggageEl = document.getElementById('modal-luggage');
            const notesEl = document.getElementById('modal-notes');
            const timeEl = document.getElementById('modal-time');
            const mapLinkEl = document.getElementById('modal-map-link') as HTMLAnchorElement;
            const dateEl = document.getElementById('modal-date');
            const amountEl = document.getElementById('modal-amount');
            const refEl = document.getElementById('modal-booking-ref');
            const typeEl = document.getElementById('modal-booking-type');
            const statusEl = document.getElementById('modal-status-badge');

            const STATUS_LABELS_FR: Record<string, string> = {
                pending: "En attente",
                accepted: "Confirmée",
                accepted_pending_payment: "En attente de paiement",
                paid: "Payée",
                completed: "Terminée",
                cancelled: "Annulée",
                cancelled_pending_refund: "Remboursement en cours",
                cancelled_refunded: "Remboursée",
                cancelled_no_refund: "Annulée",
                deprecated_refunded: "Remboursée",
                no_show: "Non présentation",
                expired_payment: "Paiement expiré",
                refund_failed: "Échec remboursement"
            };

            if (nameEl) nameEl.innerText = `${booking.customers.first_name} ${booking.customers.last_name}`;

            if (emailEl) emailEl.innerText = booking.customers.email;
            if (emailLinkEl) emailLinkEl.href = `mailto:${booking.customers.email}`;

            if (phoneEl) phoneEl.innerText = booking.customers.phone || 'Non renseigné';
            if (phoneLinkEl) {
                if (booking.customers.phone) {
                    phoneLinkEl.href = `tel:${booking.customers.phone}`;
                    phoneLinkEl.style.display = 'flex';
                } else {
                    phoneLinkEl.style.display = 'none';
                }
            }

            if (pickupEl) pickupEl.innerText = booking.pickup_address;
            if (dropoffEl) dropoffEl.innerText = booking.dropoff_address || 'Non spécifiée';
            if (passengersEl) passengersEl.innerText = booking.passenger_count?.toString() || '1';
            if (luggageEl) luggageEl.innerText = booking.luggage_count?.toString() || '0';
            if (notesEl) notesEl.innerText = booking.notes || 'Aucune note particulière.';
            if (refEl) refEl.innerText = `REF: #${booking.id.split('-')[0].toUpperCase()}`;
            if (statusEl) {
                const status = booking.status;
                statusEl.innerText = STATUS_LABELS_FR[status] || status;

                // Optionnel: Couleur dynamique du badge status
                const statusColors: Record<string, string> = {
                    pending: 'bg-amber-500/10 text-amber-500 border-amber-500/20',
                    accepted: 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20',
                    paid: 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20',
                    completed: 'bg-slate-500/10 text-slate-400 border-slate-500/20',
                    cancelled: 'bg-rose-500/10 text-rose-500 border-rose-500/20'
                };
                const colorClass = statusColors[status] || 'bg-white/10 text-white border-white/10';
                statusEl.className = `px-4 py-2 rounded-xl border text-[10px] font-black uppercase tracking-widest text-center ${colorClass}`;

                const financeStatusEl = document.getElementById('modal-status-finance');
                if (financeStatusEl) {
                    financeStatusEl.innerText = STATUS_LABELS_FR[status] || status;
                    financeStatusEl.className = `px-3 py-1.5 backdrop-blur-md rounded-lg border text-[10px] font-black uppercase tracking-widest ${colorClass}`;
                }

                // --- LOGIQUE BOUTON ACCEPTER ---
                const acceptBtn = document.getElementById('modal-accept-btn');
                if (acceptBtn) {
                    if (status === 'paid') {
                        acceptBtn.classList.remove('hidden');

                        if (!driverId) {
                            acceptBtn.classList.add('opacity-50');
                            acceptBtn.setAttribute('disabled', 'true');
                            acceptBtn.title = "Créez d'abord votre profil chauffeur";
                            acceptBtn.innerText = "Profil chauffeur requis";
                            acceptBtn.onclick = null;
                        } else {
                            acceptBtn.classList.remove('opacity-50');
                            acceptBtn.onclick = async () => {
                                try {
                                    acceptBtn.innerText = "Traitement...";
                                    acceptBtn.setAttribute('disabled', 'true');

                                    // Appel de la fonction Edge Supabase accept-booking
                                    const { error } = await supabase.functions.invoke('accept-booking', {
                                        body: { booking_id: booking.id, driver_id: driverId }
                                    });

                                    if (error) throw error;

                                    // Si OK, on reload
                                    window.location.reload();
                                } catch (err) {
                                    console.error("Erreur Accept Booking:", err);
                                    acceptBtn.innerText = "Erreur — réessayer";
                                    acceptBtn.removeAttribute('disabled');
                                    setTimeout(() => { acceptBtn.innerText = "Prendre la main sur la course"; }, 3000);
                                }
                            };
                        }
                    } else {
                        acceptBtn.classList.add('hidden');
                    }
                }
            }
            if (amountEl) amountEl.innerText = `${Number(booking.total_amount).toFixed(2)}€`;
            if (mapLinkEl) mapLinkEl.href = `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(booking.pickup_address)}&destination=${encodeURIComponent(booking.dropoff_address || '')}`;

            if (typeEl) {
                const isHourly = (booking.booking_type as any) === 'hourly';
                typeEl.innerText = isHourly ? 'MISE À DISPOSITION' : 'TRANSFERT';
                typeEl.className = `px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-widest border ${
                    isHourly
                    ? 'bg-amber-500/10 text-amber-500 border-amber-500/20'
                    : 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20'
                }`;
            }

            const dateObj = new Date(booking.pickup_time);
            if (timeEl) timeEl.innerText = dateObj.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
            if (dateEl) dateEl.innerText = dateObj.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });

            toggleModal();
        });
    });

    closeBtns.forEach(btn => btn.addEventListener('click', toggleModal));
    overlay?.addEventListener('click', toggleModal);

    // Masquer le dock "Prochaines Missions" quand le banner mission est actif
    const syncDockVisibility = () => {
        const banner = document.getElementById('mission-banner');
        const dock = document.getElementById('upcoming-dock');
        if (!dock) return;
        const bannerVisible = banner && !banner.classList.contains('hidden');
        dock.style.display = bannerVisible ? 'none' : '';
    };
    syncDockVisibility();
    new MutationObserver(syncDockVisibility).observe(
        document.getElementById('mission-banner') ?? document.body,
        { attributes: true, attributeFilter: ['class'] }
    );
</script>
