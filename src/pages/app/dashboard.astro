---
// src/pages/app/dashboard.astro
import { ImmediateActions } from "@/components/dashboard/ImmediateActions";
import { StripeConnectionCard } from "@/components/dashboard/StripeConnectionCard";
import { supabase } from "@/lib/supabase/client";
import AppLayout from "../../layouts/AppLayout.astro";

const { profile, supabase: supabaseAdmin } = Astro.locals;

if (!profile) return Astro.redirect("/login");

// 📅 Calcul des dates pour les KPIs
const now = new Date();
const startOfToday = new Date(
    now.getFullYear(),
    now.getMonth(),
    now.getDate(),
).toISOString();
const startOfMonth = new Date(
    now.getFullYear(),
    now.getMonth(),
    1,
).toISOString();

// 1️⃣ Courses du mois (Métier)
const { count: monthlyCount } = await supabaseAdmin
    .from("bookings")
    .select("*", { count: "exact", head: true })
    .eq("current_tenant_id", profile.tenant_id!)
    .gte("pickup_time", startOfMonth);

// 1bis️⃣ Total Missions (All-time)
const { count: totalCount } = await supabaseAdmin
    .from("bookings")
    .select("*", { count: "exact", head: true })
    .eq("current_tenant_id", profile.tenant_id!);

// 🎯 Ratings Dynamiques
const { data: ratingData } = await supabaseAdmin
    .from("driver_ratings")
    .select("average_rating")
    .eq("driver_id", profile.id)
    .maybeSingle();

const rating = ratingData?.average_rating || 5.0;

// 2️⃣ Données Financières & KPIs (Source: Vue Ledger & Bookings)
const { data: kpi } = await supabaseAdmin
    .from("tenant_dashboard_kpi")
    .select("*")
    .eq("tenant_id", profile.tenant_id!)
    .limit(1)
    .maybeSingle();

const monthlyRevenue = kpi?.monthly_net_revenue || 0;

// 3️⃣ Missions (Mise en avant et Focus)
const { data: allUpcoming } = await supabaseAdmin
    .from("bookings")
    .select("*, customers!inner(*)")
    .eq("current_tenant_id", profile.tenant_id!)
    .gte("pickup_time", now.toISOString())
    .order("pickup_time", { ascending: true });

const upcomingBookings = allUpcoming?.slice(0, 3) || [];
const immediateMission = allUpcoming?.find(b => {
    const pickTime = new Date(b.pickup_time).getTime();
    const diff = (pickTime - now.getTime()) / (1000 * 60); // minutes
    return diff > 0 && diff < 120; // Dans les 2 prochaines heures
});

// 4️⃣ Courses en attente de validation (Mise à dispo)
const { data: validatingBookings } = await supabaseAdmin
    .from("bookings")
    .select("*, customers!inner(*)")
    .eq("current_tenant_id", profile.tenant_id!)
    .eq("status", "pending")
    .order("created_at", { ascending: true });

// 5️⃣ Dernières courses (Historique court)
const { data: pastBookings } = await supabaseAdmin
    .from("bookings")
    .select("*, customers!inner(*)")
    .eq("current_tenant_id", profile.tenant_id!)
    .lt("pickup_time", now.toISOString())
    .neq("status", "cancelled")
    .order("pickup_time", { ascending: false })
    .limit(2);

// 6️⃣ Récupérer l'ID driver du profil actuel
const { data: driver } = await supabaseAdmin
    .from("drivers")
    .select("id")
    .eq("user_id", profile.id)
    .maybeSingle();

const driverId = driver?.id;

// 7️⃣ Récupérer les infos du tenant (Logo, SIRET, Setup Status)
const { data: tenant } = await supabaseAdmin
    .from("tenants")
    .select("name, logo_url, siret, setup_completed, company_type, rcs_number, vat_number, is_vat_exempt")
    .eq("id", profile.tenant_id!)
    .maybeSingle();

// 🚀 Blocage si Setup non terminé
if (tenant && !tenant.setup_completed) {
    return Astro.redirect("/app/setup");
}

const tenantName = tenant?.name || "VTC HUB";
const logoUrl = tenant?.logo_url;
const siret = tenant?.siret || "Non renseigné";

// 8️⃣ Récupérer les infos du chauffeur complet (VTC License)
const { data: driverFull } = await supabaseAdmin
    .from("drivers")
    .select("*, vehicles(*)")
    .eq("user_id", profile.id)
    .maybeSingle();

const vtcLicense = (driverFull as any)?.license_number || "---";

// 9️⃣ Récupérer le véhicule (Assigné au chauffeur OU Premier du tenant)
let activeVehicle = Array.isArray((driverFull as any)?.vehicles)
    ? (driverFull as any)?.vehicles[0]
    : (driverFull as any)?.vehicles;

if (!activeVehicle) {
    const { data: tenantVehicle } = await supabaseAdmin
        .from("vehicles")
        .select("*")
        .eq("tenant_id", profile.tenant_id!)
        .limit(1)
        .maybeSingle();
    activeVehicle = tenantVehicle;
}

// 10️⃣ Données Comptables (Ledger)
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1;

const { data: ledgerMonth } = await supabaseAdmin
    .from("tenant_accounting_ledger")
    .select("*")
    .eq("tenant_id", profile.tenant_id!)
    .eq("year", currentYear)
    .eq("month", currentMonth)
    .maybeSingle();

const { data: fiscalYearData } = await supabaseAdmin
    .rpc("get_fiscal_summary", {
        t_id: profile.tenant_id!,
        f_year: currentYear
    });

const fiscalYear = fiscalYearData as any;
---

<AppLayout title="Dashboard">
    <div class="flex-1 flex flex-col p-5 sm:p-10 overflow-y-auto custom-scrollbar bg-brand-dark selection:bg-indigo-500/30">
        <!-- 🚀 HEADER: COMMAND CENTER v5.1 -->
        <div class="flex-shrink-0 mb-8 animate-in fade-in slide-in-from-top-4 duration-1000">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6">
                <div class="flex items-center gap-4">
                    {logoUrl ? (
                        <div class="w-12 h-12 bg-white/5 rounded-2xl border border-white/10 flex items-center justify-center overflow-hidden">
                             <img src={logoUrl} alt={tenantName} class="w-full h-full object-contain" />
                        </div>
                    ) : (
                        <div class="w-12 h-12 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-2xl shadow-indigo-600/20 text-white font-black text-fluid-2xl">
                            {tenantName.charAt(0).toUpperCase()}
                        </div>
                    )}
                    <div>
                        <h1 class="text-fluid-3xl font-black tracking-tighter italic uppercase text-white leading-tight">
                            {tenantName}
                        </h1>
                        <p class="text-fluid-xs font-black text-slate-500 uppercase tracking-widest opacity-60">
                            Elite Driver — {profile?.first_name} {profile?.last_name}
                        </p>
                    </div>
                </div>

                <div class="flex items-center gap-3">
                    <!-- 💰 STRIPE CONNECTION ONLY -->
                    <StripeConnectionCard
                        client:only="react"
                        tenantId={profile.tenant_id!}
                        monthlyRevenue={monthlyRevenue}
                        totalCount={totalCount || 0}
                        rating={rating}
                    />
                </div>
            </div>
        </div>

        <!-- 🌟 PRO CARDS: INFO LÉGALE, VÉHICULE & COMPTABILITÉ -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
            <!-- Card 1: Profil Légal -->
            <div class="glass p-5 rounded-[2rem] border border-white/5 bg-white/[0.01] flex flex-col gap-4">
                <div class="flex items-center justify-between">
                    <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest">Informations Légales</span>
                    <span class="px-2 py-0.5 bg-emerald-500/10 border border-emerald-500/20 rounded-full text-[7px] font-black text-emerald-400 uppercase tracking-widest">
                        Compte Vérifié
                    </span>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[7px] font-black uppercase text-slate-600 mb-0.5 tracking-widest">SIRET</p>
                        <p class="text-xs font-black text-white tabular-nums">{siret}</p>
                    </div>
                    <div>
                        <p class="text-[7px] font-black uppercase text-slate-600 mb-0.5 tracking-widest">Carte VTC</p>
                        <p class="text-xs font-black text-white tabular-nums">{vtcLicense}</p>
                    </div>
                </div>
            </div>

            <!-- Card 2: Véhicule -->
            <div class="glass p-5 rounded-[2rem] border border-white/5 bg-white/[0.01] flex items-center justify-between">
                <div class="flex items-center gap-4">
                    <div class="w-10 h-10 rounded-xl bg-white/5 flex items-center justify-center text-indigo-400">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                    </div>
                    <div>
                        <p class="text-[8px] font-black text-slate-500 uppercase tracking-widest mb-0.5">Véhicule Actif</p>
                        <p class="text-xs font-black text-white truncate max-w-[120px]">
                            {activeVehicle ? `${activeVehicle.brand} ${activeVehicle.model}` : 'Non assigné'}
                        </p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="text-[7px] font-black text-slate-600 uppercase tracking-widest mb-0.5">Plaque</p>
                    <p class="text-[10px] font-black text-rose-500 tabular-nums uppercase tracking-tighter">
                        {activeVehicle?.plate_number || '---'}
                    </p>
                </div>
            </div>

            <!-- Card 3: Comptabilité & Fiscalité -->
            <div class="glass p-5 rounded-[2rem] border border-white/5 bg-white/[0.01] flex flex-col gap-4">
                <div class="flex items-center justify-between">
                    <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest">Comptabilité & Fiscalité</span>
                    <span class="px-2 py-0.5 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-[7px] font-black text-indigo-400 uppercase tracking-widest">
                        {currentYear}
                    </span>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <p class="text-[7px] font-black uppercase text-slate-600 mb-0.5 tracking-widest">Ce Mois (Net)</p>
                        <p class="text-xs font-black text-emerald-400 tabular-nums">
                            {ledgerMonth?.net_revenue || 0} €
                        </p>
                    </div>
                    <div>
                        <p class="text-[7px] font-black uppercase text-slate-600 mb-0.5 tracking-widest">Année (Net)</p>
                        <p class="text-xs font-black text-white tabular-nums">
                            {fiscalYear?.total_net || 0} €
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- 🌟 QUICK STATS (MOBILE ONLY) -->
        <div class="mb-10 md:hidden">
            <div class="inline-flex items-center glass px-6 py-4 rounded-2xl border border-white/5 bg-white/[0.02] gap-8">
                <div class="flex flex-col">
                    <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest mb-1 leading-none">Note</span>
                    <span class="text-xl font-black text-rose-500 tracking-tighter leading-none flex items-center gap-2">
                        {rating.toFixed(1)}
                        <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                    </span>
                </div>
                <div class="w-px h-6 bg-white/5"></div>
                <div class="flex flex-col">
                    <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest mb-1 leading-none">Missions Total</span>
                    <span class="text-xl font-black text-indigo-400 tracking-tighter leading-none tabular-nums">{totalCount || 0}</span>
                </div>
            </div>
        </div>


        <!-- 🚥 DYNAMIC CONTENT SECTION -->
        <div class="flex flex-col gap-12">

            {/* 🎯 FOCUS: MISSION IMMÉDIATE */}
            {immediateMission && (
                <div class="animate-in fade-in zoom-in duration-700">
                    <h3 class="text-[9px] font-black uppercase tracking-[0.2em] text-indigo-400 mb-3 flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-ping"></span>
                        Mission Prioritaire
                    </h3>
                    <div class="relative overflow-hidden glass p-6 sm:p-8 rounded-[2.5rem] border border-indigo-500/30 bg-indigo-500/[0.03] shadow-2xl shadow-indigo-500/10 group">
                        <div class="absolute top-0 right-0 p-6 opacity-20">
                            <span class="text-4xl font-black text-white/10 tracking-tighter uppercase select-none">NOW</span>
                        </div>

                        <div class="relative z-10 flex flex-col lg:flex-row lg:items-center justify-between gap-8">
                            <div class="flex-1">
                                <div class="flex items-center gap-4 mb-5">
                                    <div class="w-14 h-14 rounded-2xl bg-indigo-500 flex flex-col items-center justify-center text-white shadow-xl shadow-indigo-500/20">
                                        <span class="text-[9px] font-black uppercase leading-none opacity-60">{new Date(immediateMission.pickup_time).toLocaleDateString('fr-FR', { month: 'short' })}</span>
                                        <span class="text-xl font-black leading-none">{new Date(immediateMission.pickup_time).toLocaleDateString('fr-FR', { day: '2-digit' })}</span>
                                    </div>
                                    <div>
                                        <p class="text-3xl font-black text-white tracking-tighter tabular-nums leading-none mb-1">
                                            {new Date(immediateMission.pickup_time).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}
                                        </p>
                                        <p class="text-[9px] font-black uppercase text-indigo-400 tracking-widest">Décollage imminent</p>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <div class="flex items-start gap-2">
                                        <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 mt-1.5 shrink-0"></div>
                                        <p class="text-base font-bold text-white leading-tight">{immediateMission.pickup_address}</p>
                                    </div>
                                    <div class="flex items-start gap-2 opacity-50">
                                        <div class="w-1.5 h-1.5 rounded-full bg-rose-500 mt-1.5 shrink-0"></div>
                                        <p class="text-xs font-medium text-slate-400 leading-tight">{immediateMission.dropoff_address || 'Destination à confirmer'}</p>
                                    </div>
                                </div>
                            </div>

                            <ImmediateActions
                                client:load
                                bookingId={immediateMission.id}
                                customerPhone={immediateMission.customers.phone}
                                pickupAddress={immediateMission.pickup_address}
                                tenantName={tenantName}
                                pickupTime={immediateMission.pickup_time}
                                invoiceUrl={immediateMission.invoice_url}
                            />
                        </div>
                    </div>
                </div>
            )}

            {/* 🚥 À VALIDER (MODALITÉ MISE À DISPO) */}
            {validatingBookings && validatingBookings.length > 0 && (
                <div class="animate-in fade-in slide-in-from-bottom-4 duration-700 delay-200">
                    <h3 class="text-[9px] font-black uppercase tracking-[0.2em] flex items-center gap-3 text-amber-500 mb-4">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse" />
                        Actions Requises
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                        {validatingBookings.map((booking) => (
                            <div class="glass p-5 rounded-[2rem] border border-amber-500/10 bg-amber-500/[0.02] hover:border-amber-500/20 transition-all group">
                                <div class="flex justify-between items-start mb-4">
                                    <div class="px-2 py-0.5 bg-amber-500/10 border border-amber-500/20 rounded-md text-[7px] font-black tracking-widest text-amber-500 uppercase">
                                        Mise à Disposition
                                    </div>
                                    <span class="text-[9px] font-black text-slate-600 uppercase tracking-widest leading-none">
                                        {new Date(booking.pickup_time).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short' })}
                                    </span>
                                </div>
                                <div class="mb-4">
                                    <p class="text-[8px] font-black uppercase text-slate-500 tracking-widest mb-0.5">Contact</p>
                                    <p class="text-lg font-black text-white uppercase tracking-tighter">
                                        {booking.customers.first_name} {booking.customers.last_name}
                                    </p>
                                </div>
                                <div class="flex justify-between items-center bg-black/20 p-3 rounded-xl border border-white/5 mb-4">
                                    <span class="text-[8px] font-black uppercase text-slate-500">Est.</span>
                                    <span class="text-xl font-black text-white tabular-nums">{Number(booking.total_amount).toFixed(0)}€</span>
                                </div>
                                <a href={`/app/bookings?status=pending`} class="block w-full py-3 bg-amber-500 hover:bg-amber-400 text-slate-950 text-[9px] font-black uppercase tracking-widest text-center rounded-xl transition-all active:scale-95 shadow-xl shadow-amber-500/10">
                                    Finaliser le prix
                                </a>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            {/* ⚡️ PROCHAINES MISSIONS (AGENDA) */}
            <div>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-[9px] font-black uppercase tracking-[0.2em] flex items-center gap-3 text-white leading-none">
                        <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse" />
                        Agenda à Venir
                    </h3>
                    <a href="/app/bookings" class="text-[8px] font-black uppercase tracking-widest text-indigo-400 hover:text-white transition-colors">Tout voir →</a>
                </div>

                {upcomingBookings && upcomingBookings.length > 0 ? (
                    <div class="flex flex-col gap-3">
                        {upcomingBookings.map((booking) => (
                            <div
                                class="glass p-4 rounded-[1.5rem] border border-white/5 bg-white/[0.01] hover:border-indigo-500/20 hover:bg-indigo-500/[0.02] transition-all cursor-pointer group booking-row relative overflow-hidden"
                                data-booking={JSON.stringify(booking)}
                            >
                                <div class="relative z-10 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                    <div class="flex items-center gap-4">
                                        <div class="flex flex-col items-center justify-center p-2 py-3 bg-white/5 rounded-xl border border-white/5 min-w-[60px]">
                                            <span class="text-[7px] font-black uppercase text-slate-500 mb-0.5 leading-none">{new Date(booking.pickup_time).toLocaleDateString('fr-FR', { month: 'short' })}</span>
                                            <span class="text-lg font-black text-white leading-none">{new Date(booking.pickup_time).toLocaleDateString('fr-FR', { day: '2-digit' })}</span>
                                            <span class="text-[8px] font-black text-indigo-400 mt-1.5 tracking-tighter">{new Date(booking.pickup_time).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' })}</span>
                                        </div>

                                        <div class="min-w-0">
                                            <div class="flex items-center gap-2 mb-1.5">
                                                <span class={`text-[6px] font-black uppercase tracking-widest px-1 py-0.5 rounded-[3px] border ${
                                                    (booking.booking_type as any) === 'hourly'
                                                    ? 'bg-amber-500/10 text-amber-500 border-amber-500/20'
                                                    : 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20'
                                                }`}>
                                                    {(booking.booking_type as any) === 'hourly' ? 'Mise à Dispo' : 'Transfert'}
                                                </span>
                                                <span class="text-[11px] font-black text-white uppercase tracking-tighter truncate max-w-[120px]">
                                                    {booking.customers.first_name} {booking.customers.last_name}
                                                </span>
                                            </div>
                                            <div class="space-y-1">
                                                <div class="flex items-center gap-1.5">
                                                    <div class="w-1 h-1 rounded-full bg-indigo-500 shrink-0" />
                                                    <p class="text-[9px] font-bold text-slate-300 truncate max-w-[180px]">{booking.pickup_address}</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="flex items-center justify-between sm:justify-end gap-3 sm:ml-auto border-t sm:border-0 border-white/5 pt-3 sm:pt-0">
                                        <div class="text-lg font-black text-white sm:mr-2 tabular-nums">
                                            {Number(booking.total_amount).toFixed(0)}€
                                        </div>
                                        <div class="flex items-center gap-1.5">
                                            <button class="stop-propagation w-8 h-8 rounded-lg bg-white/5 border border-white/5 flex items-center justify-center text-slate-500 hover:text-emerald-400 hover:bg-emerald-500/10 transition-all" onclick={`event.stopPropagation(); window.location.href='tel:${booking.customers.phone}'`}>
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                                            </button>
                                            <button class="stop-propagation w-8 h-8 rounded-lg bg-white/5 border border-white/5 flex items-center justify-center text-slate-500 hover:text-indigo-400 hover:bg-indigo-500/10 transition-all" onclick={`event.stopPropagation(); window.open('https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(booking.pickup_address)}', '_blank')`}>
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                ) : (
                    <div class="glass p-10 rounded-[2rem] border border-white/5 bg-white/[0.01] text-center flex flex-col items-center gap-3">
                        <p class="text-[9px] font-black uppercase text-slate-600 tracking-widest">Aucune mission programmée</p>
                    </div>
                )}
            </div>

            {/* 📜 DERNIÈRES ACTIVITÉS (PAST) */}
            <div>
                <h3 class="text-[9px] font-black uppercase tracking-[0.2em] flex items-center gap-3 text-slate-600 mb-4 opacity-40">
                    Historique Récent
                </h3>

                {pastBookings && pastBookings.length > 0 ? (
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        {pastBookings.map((booking) => (
                            <div
                                class="glass p-4 rounded-xl border border-white/5 bg-white/[0.01] hover:bg-white/[0.03] transition-all cursor-pointer group booking-row flex items-center justify-between"
                                data-booking={JSON.stringify(booking)}
                            >
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-600 group-hover:text-white transition-colors">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                                    </div>
                                    <div>
                                        <p class="text-[10px] font-black text-white uppercase tracking-tighter truncate max-w-[100px]">
                                            {booking.customers.first_name} {booking.customers.last_name}
                                        </p>
                                        <p class="text-[7px] font-bold text-slate-600 uppercase tracking-widest">{new Date(booking.pickup_time).toLocaleDateString('fr-FR')}</p>
                                    </div>
                                </div>
                                <div class="text-[11px] font-black text-slate-500 tabular-nums">
                                    {Number(booking.total_amount).toFixed(0)}€
                                </div>
                            </div>
                        ))}
                    </div>
                ) : (
                    <p class="text-slate-800 text-[8px] font-black uppercase tracking-widest">Aucun historique.</p>
                )}

                {/* Informations Légales */}
                <div class="bg-white/5 border border-white/10 rounded-2xl p-6 backdrop-blur-md mt-6">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="p-2 bg-indigo-500/20 rounded-lg">
                            <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                            </svg>
                        </div>
                        <h3 class="text-sm font-bold text-white uppercase tracking-wider">Identité Légale</h3>
                    </div>
                    <div class="space-y-4">
                        <div>
                            <p class="text-[10px] text-slate-500 uppercase font-black mb-1">SIRET</p>
                            <p class="text-sm text-white font-mono">{tenant?.siret || "---"}</p>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase font-black mb-1">RCS</p>
                                <p class="text-xs text-white truncate">{tenant?.rcs_number || "---"}</p>
                            </div>
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase font-black mb-1">TVA</p>
                                <p class="text-xs text-white">
                                    {tenant?.is_vat_exempt ? "Exonéré (Art. 293 B)" : (tenant?.vat_number || "---")}
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</AppLayout>

<!-- 🎭 MODAL: DÉTAILS MISSION ELITE -->
