---
// src/pages/admin/dashboard.astro
import KPIGrid from "../../components/admin/KPIGrid.astro";
import MonthlyChart from "../../components/admin/MonthlyChart.astro";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requirePlatformAdmin } from "../../lib/guards/platform";
import { createAdminClient } from "../../lib/supabase/server";

const { profile } = Astro.locals;

// Protection d'accès plateforme
try {
  await requirePlatformAdmin(profile);
} catch {
  return Astro.redirect("/login");
}

const supabaseAdmin = createAdminClient();

// Récupération des données financières
const { data: globalKpi } = await supabaseAdmin.from("finance_global_kpi").select("*").single();
const { data: currentYearKpi } = await supabaseAdmin.from("finance_current_year_kpi").select("*").single();
const { data: monthlySummary } = await supabaseAdmin.from("finance_monthly_summary").select("*").order("month", { ascending: true });
const { data: yearlySummary } = await supabaseAdmin.from("finance_yearly_summary").select("*").order("year", { ascending: true });

const kpiItems = [
    {
        label: "Total Encaissé (Global)",
        value: new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(globalKpi?.total_collected || 0),
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />',
        trend: "Historique Brut",
        trendColor: "text-slate-400"
    },
    {
        label: "Net Année En Cours",
        value: new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(currentYearKpi?.net_revenue || 0),
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />',
        trend: `${new Date().getFullYear()}`,
        trendColor: "text-indigo-400"
    },
    {
        label: "Net Plateforme (Total)",
        value: new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'EUR' }).format(globalKpi?.net_revenue || 0),
        icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />',
        trend: "Revenu Réel Cumulé",
        trendColor: "text-green-400"
    }
];

const monthlyChartData = (monthlySummary || []).map(d => ({
    month: new Date(d.month).toLocaleDateString('fr-FR', { month: 'short', year: '2-digit' }),
    total_net: Number(d.net_revenue)
}));

const yearlyChartData = (yearlySummary || []).map(d => ({
    month: new Date(d.year).toLocaleDateString('fr-FR', { year: 'numeric' }),
    total_net: Number(d.net_revenue)
}));
---


<AdminLayout title="Tableau de Bord">
    <KPIGrid title="Indicateurs Financiers" items={kpiItems} />

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mt-12">
        <MonthlyChart title="Performance Mensuelle" data={monthlyChartData} />
        <MonthlyChart title="Performance Annuelle" data={yearlyChartData} />
    </div>
</AdminLayout>

