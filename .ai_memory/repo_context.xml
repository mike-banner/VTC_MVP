16540: const { profile, user } = Astro.locals;
16541: 
16542: if (!profile || !user) {
16543:     return Astro.redirect("/login");
16544: }
16545: 
16546: const safeProfile = profile;
16547: 
16548: const currentStatus = Astro.url.searchParams.get("status") || "all";
16549: const currentType = Astro.url.searchParams.get("type") || "all";
16550: 
16551: /**
16552:  * 🎯 LOGIQUE SÉCURISÉE (BACKEND SSR)
16553:  */
16554: let query = supabase
16555:     .from("bookings")
16556:     .select("*, customers!inner(*)")
16557:     .eq("current_tenant_id", profile.tenant_id as string);
16558: 
16559: if (currentStatus !== "all") {
16560:     if (currentStatus === "completed") {
16561:         query = query.in("status", ["completed", "paid"]);
16562:     } else {
16563:         query = query.eq("status", currentStatus as any);
16564:     }
16565: }
16566: 
16567: if (currentType !== "all") {
16568:     query = query.eq("booking_type", currentType as any);
16569: }
16570: 
16571: if (profile.tenant_role === "driver") {
16572:     const { data: driver } = await supabase
16573:         .from("drivers")
16574:         .select("id")
16575:         .eq("user_id", user.id)
16576:         .eq("tenant_id", profile.tenant_id!)
16577:         .limit(1)
16578:         .maybeSingle();
16579: 
16580:     if (driver) {
16581:         query = query.eq("driver_id", driver.id);
16582:     } else {
16583:         query = query.eq("id", "00000000-0000-0000-0000-000000000000");
16584:     }
16585: }
16586: 
