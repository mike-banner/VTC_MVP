 4207:             WHEN ("movement_type" = 'payment'::"public"."movement_type_enum") THEN "net_amount"
 4208:             ELSE (0)::numeric
 4209:         END), (0)::numeric) - COALESCE("sum"(
 4210:         CASE
 4211:             WHEN ("movement_type" = 'refund'::"public"."movement_type_enum") THEN "net_amount"
 4212:             ELSE (0)::numeric
 4213:         END), (0)::numeric)) AS "total_net_revenue",
 4214:     "count"(DISTINCT "booking_id") AS "total_bookings",
 4215:     (COALESCE("sum"(
 4216:         CASE
 4217:             WHEN (("movement_type" = 'payment'::"public"."movement_type_enum") AND ("date_trunc"('month'::"text", "created_at") = "date_trunc"('month'::"text", "now"()))) THEN "net_amount"
 4218:             ELSE (0)::numeric
