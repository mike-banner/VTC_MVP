 8967: <file path="supabase/functions/stripe_webhook/index.ts">
 8968: import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
 8969: import Stripe from "https://esm.sh/stripe@12.18.0?target=deno&no-check";
 8970: 
 8971: const stripe = new Stripe(Deno.env.get("STRIPE_SECRET_KEY")!, {
 8972:   apiVersion: "2024-06-20",
 8973: });
 8974: 
 8975: const supabase = createClient(
 8976:   Deno.env.get("SUPABASE_URL")!,
 8977:   Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!,
 8978: );
 8979: 
 8980: Deno.serve(async (req) => {
 8981:   const signature = req.headers.get("stripe-signature");
 8982: 
 8983:   if (!signature) {
 8984:     return new Response("Missing signature", { status: 400 });
 8985:   }
 8986: 
 8987:   const rawBody = await req.arrayBuffer();
 8988:   const body = new TextDecoder().decode(rawBody);
 8989: 
 8990:   let event: Stripe.Event;
 8991: 
 8992:   try {
 8993:     event = await stripe.webhooks.constructEventAsync(
 8994:       body,
 8995:       signature,
 8996:       Deno.env.get("STRIPE_WEBHOOK_SECRET")!,
 8997:     );
 8998:   } catch (err) {
 8999:     console.log("SIGNATURE ERROR", err);
 9000:     return new Response("Invalid signature", { status: 400 });
 9001:   }
 9002: 
 9003:   const obj: any = event.data.object;
 9004: 
 9005:   const sessionId =
 9006:     obj?.id && obj?.object === "checkout.session"
 9007:       ? obj.id
 9008:       : (obj?.checkout_session ?? null);
 9009: 
 9010:   const paymentIntent = obj?.payment_intent ?? obj?.id ?? null;
 9011: 
 9012:   const tenantId = obj?.metadata?.tenant_id ?? null;
 9013: 
 9014:   const amount = obj?.amount_total
 9015:     ? obj.amount_total / 100
 9016:     : obj?.amount_received
 9017:       ? obj.amount_received / 100
 9018:       : null;
 9019: 
 9020:   // --------------------------
 9021:   // STATUS
 9022:   // --------------------------
 9023: 
 9024:   let status = "received";
 9025: 
 9026:   if (event.type === "checkout.session.completed") {
 9027:     status = "session_completed";
 9028:   }
 9029: 
 9030:   if (event.type === "payment_intent.succeeded") {
 9031:     status = "paid";
 9032:   }
 9033: 
 9034:   if (event.type === "payment_intent.payment_failed") {
 9035:     status = "failed";
 9036:   }
 9037: 
 9038:   // --------------------------
 9039:   // UPSERT stripe_events
 9040:   // --------------------------
 9041: 
 9042:   const { data: existing } = await supabase
 9043:     .from("stripe_events")
 9044:     .select("id")
 9045:     .eq("stripe_event_id", event.id)
 9046:     .maybeSingle();
 9047: 
 9048:   if (!existing) {
 9049:     await supabase.from("stripe_events").insert({
 9050:       stripe_event_id: event.id,
 9051:       session_id: sessionId,
 9052:       payment_intent_id: paymentIntent,
 9053:       event_type: event.type,
 9054:       status,
 9055:       tenant_id: tenantId,
 9056:       amount,
 9057:       metadata: event,
 9058:     });
 9059:   } else {
 9060:     await supabase
 9061:       .from("stripe_events")
 9062:       .update({
 9063:         status,
 9064:         metadata: event,
 9065:       })
 9066:       .eq("stripe_event_id", event.id);
 9067:   }
 9068: 
 9069:   // --------------------------
 9070:   // CREATE BOOKING V1
 9071:   // --------------------------
 9072: 
 9073:   if (event.type === "checkout.session.completed") {
 9074:     const session = obj as any;
 9075: 
 9076:     if (session?.metadata) {
 9077:       const m = session.metadata;
 9078: 
 9079:       const subtotal = Number(m.subtotal_amount ?? 0);
 9080:       const vat = Number(m.vat_amount ?? 0);
 9081:       const total = Number(m.total_amount ?? amount ?? 0);
 9082: 
 9083:       const { data: booking, error } = await supabase
 9084:         .from("bookings")
 9085:         .insert({
 9086:           original_tenant_id: tenantId,
 9087:           current_tenant_id: tenantId,
 9088: 
 9089:           pickup_address: m.pickup_address,
 9090:           dropoff_address: m.dropoff_address,
 9091: 
 9092:           pickup_time: m.pickup_time,
 9093: 
 9094:           total_amount: total,
 9095:           subtotal_amount: subtotal,
 9096:           vat_amount: vat,
 9097: 
 9098:           status: "paid",
 9099:           payment_mode: "stripe",
 9100: 
 9101:           customer_id: m.customer_id,
 9102: 
 9103:           stripe_payment_intent_id: session.payment_intent,
 9104: 
 9105:           passenger_count: Number(m.passenger_count ?? 1),
 9106:           luggage_count: Number(m.luggage_count ?? 0),
 9107: 
 9108:           booking_type: m.booking_type,
 9109: 
 9110:           vehicle_id: m.vehicle_id ?? null,
 9111:         })
 9112:         .select()
 9113:         .single();
 9114: 
 9115:       if (!error && booking) {
 9116:         await supabase
 9117:           .from("stripe_events")
 9118:           .update({
 9119:             status: "booking_created",
 9120:             booking_id: booking.id,
 9121:           })
 9122:           .eq("stripe_event_id", event.id);
 9123:       } else {
 9124:         console.log("BOOKING ERROR", error);
 9125:       }
 9126:     }
 9127:   }
 9128: 
 9129:   return new Response("OK");
 9130: });
 9131: </file>
