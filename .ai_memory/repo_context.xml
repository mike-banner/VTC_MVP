234:                 <div class="text-xs font-bold text-slate-500 uppercase tracking-widest">
235:                     Page <span class="text-white">{page}</span> sur <span class="text-white">{totalPages}</span>
236:                 </div>
237:                 <div class="flex gap-2">
238:                     {page > 1 && (
239:                         <a
240:                             href={getPaginationUrl(page - 1)}
241:                             class="px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-[10px] font-black uppercase tracking-widest text-slate-400 hover:bg-white/10 transition-all"
242:                         > Précédent </a>
243:                     )}
244: 
245:                     <div class="flex gap-1">
246:                         {[...Array(Math.min(5, totalPages))].map((_, i) => {
247:                             let pageNum = page;
248:                             if (page < 3) pageNum = i + 1;
249:                             else if (page > totalPages - 2) pageNum = totalPages - 4 + i;
250:                             else pageNum = page - 2 + i;
251: 
252:                             if (pageNum < 1 || pageNum > totalPages) return null;
253: 
254:                             return (
255:                                 <a
256:                                     href={getPaginationUrl(pageNum)}
257:                                     class={`w-10 h-10 flex items-center justify-center rounded-xl text-[10px] font-black transition-all border ${page === pageNum ? 'bg-indigo-600 border-indigo-500 text-white' : 'bg-white/5 border-white/10 text-slate-500 hover:bg-white/10'}`}
258:                                 >
259:                                     {pageNum}
260:                                 </a>
261:                             );
262:                         })}
263:                     </div>
264: 
265:                     {page < totalPages && (
266:                         <a
267:                             href={getPaginationUrl(page + 1)}
268:                             class="px-4 py-2 bg-white/5 border border-white/10 rounded-xl text-[10px] font-black uppercase tracking-widest text-slate-400 hover:bg-white/10 transition-all"
269:                         > Suivant </a>
270:                     )}
271:                 </div>
272:             </div>
273:         )}
274:     </div>
275: </AdminLayout>
