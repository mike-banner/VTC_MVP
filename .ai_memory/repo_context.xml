 1054: <file path="src/components/common/InactivityTimeout.astro">
 1055: ---
 1056: // src/components/common/InactivityTimeout.astro
 1057: /**
 1058:  * Ce composant gère la déconnexion automatique en cas d'inactivité.
 1059:  * Il surveille les mouvements de souris, clics, touches clavier et scroll.
 1060:  */
 1061: interface Props {
 1062:     timeoutMinutes?: number;
 1063: }
 1064: 
 1065: const { timeoutMinutes = 30 } = Astro.props;
 1066: const timeoutMs = timeoutMinutes * 60 * 1000;
 1067: ---
 1068: 
 1069: <script define:vars={{ timeoutMs }}>
 1070:     import { supabase } from "@/lib/supabase/client";
 1071: 
 1072:     let inactivityTimer;
 1073: 
 1074:     const logout = async () => {
 1075:         console.log("Inactivité détectée. Déconnexion automatique...");
 1076:         await supabase.auth.signOut();
 1077:         window.location.href = "/login?reason=inactivity";
 1078:     };
 1079: 
 1080:     const resetTimer = () => {
 1081:         clearTimeout(inactivityTimer);
 1082:         inactivityTimer = setTimeout(logout, timeoutMs);
 1083:     };
 1084: 
 1085:     // Liste des événements à surveiller pour réinitialiser le timer
 1086:     const activityEvents = [
 1087:         'mousedown',
 1088:         'mousemove',
 1089:         'keypress',
 1090:         'scroll',
 1091:         'touchstart',
 1092:         'click'
 1093:     ];
 1094: 
 1095:     // Initialisation
 1096:     const initInactivityTracker = () => {
 1097:         // Ne pas tracker si on est sur la page de login ou d'accueil publique
 1098:         const currentPath = window.location.pathname;
 1099:         if (currentPath === '/login' || currentPath === '/') return;
 1100: 
 1101:         // Démarrer le premier timer
 1102:         resetTimer();
 1103: 
 1104:         // Ajouter les écouteurs d'événements
 1105:         activityEvents.forEach(event => {
 1106:             document.addEventListener(event, resetTimer, { passive: true });
 1107:         });
 1108:     };
 1109: 
 1110:     // Support Astro View Transitions
 1111:     document.addEventListener('astro:page-load', initInactivityTracker);
 1112: 
 1113:     // Initialisation standard au cas où View Transitions n'est pas utilisé activement
 1114:     initInactivityTracker();
 1115: </script>
 1116: </file>
