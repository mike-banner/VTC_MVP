 11:   const signature = req.headers.get("stripe-signature");
 12:   if (!signature) {
 13:     return new Response("Missing signature", { status: 400 });
 14:   }
 15:   const rawBody = await req.arrayBuffer();
 16:   const body = new TextDecoder().decode(rawBody);
 17:   let event: Stripe.Event;
 18:   try {
 19:     event = await stripe.webhooks.constructEventAsync(
 20:       body,
 21:       signature,
 22:       Deno.env.get("STRIPE_WEBHOOK_SECRET")!,
 23:     );
 24:   } catch (err) {
 25:     console.log("SIGNATURE ERROR", err);
 26:     return new Response("Invalid signature", { status: 400 });
 27:   }
