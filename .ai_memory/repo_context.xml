 8363: <file path="src/pages/api/admin/approve.ts">
 8364: import type { APIRoute } from "astro";
 8365: import { createClient } from "@supabase/supabase-js";
 8366: import { isPlatform } from "../../../lib/guards";
 8367: 
 8368: export const POST: APIRoute = async ({ request, locals }) => {
 8369:     try {
 8370:         const { profile } = locals as any;
 8371: 
 8372:         // Double vérification de sécurité (Shield)
 8373:         if (!isPlatform(profile)) {
 8374:             return new Response(JSON.stringify({ error: "Unauthorized" }), { status: 403 });
 8375:         }
 8376: 
 8377:         const { onboarding_id } = await request.json();
 8378: 
 8379:         if (!onboarding_id) {
 8380:             return new Response(JSON.stringify({ error: "Missing ID" }), { status: 400 });
 8381:         }
 8382: 
 8383:         const supabase = createClient(
 8384:             import.meta.env.PUBLIC_SUPABASE_URL,
 8385:             import.meta.env.SUPABASE_SERVICE_ROLE_KEY
 8386:         );
 8387: 
 8388:         const { error } = await supabase.rpc("approve_onboarding_tx", {
 8389:             onboarding_uuid: onboarding_id
 8390:         });
 8391: 
 8392:         if (error) {
 8393:             console.error("RPC Error:", error);
 8394:             return new Response(JSON.stringify({ error: error.message }), { status: 500 });
 8395:         }
 8396: 
 8397:         return new Response(JSON.stringify({ message: "Approved successfully" }), { status: 200 });
 8398:     } catch (err: any) {
 8399:         return new Response(JSON.stringify({ error: err.message }), { status: 500 });
 8400:     }
 8401: };
 8402: </file>
