 8494: export const initializePrimaryDriver = async (
 8495:   tenantId: string,
 8496:   userId: string,
 8497: ) => {
 8498:   try {
 8499:     // 1. Vérifier si un chauffeur existe déjà pour ce tenant
 8500: 
 8501:     const { count, error: countError } = await supabase
 8502:       .from("drivers")
 8503:       .select("*", { count: "exact", head: true })
 8504:       .eq("tenant_id", tenantId);
 8505: 
 8506:     if (countError) throw countError;
 8507:     if (count && count > 0)
 8508:       return { success: false, message: "Un chauffeur existe déjà." };
 8509: 
 8510:     // 2. Récupérer les infos de l'onboarding pour avoir la licence Pro et le phone
 8511:     const { data: onboarding, error: onboardingError } = await supabase
 8512:       .from("onboarding")
 8513:       .select("*")
 8514:       .eq("profile_id", userId)
 8515:       .order("created_at", { ascending: false })
 8516:       .limit(1)
 8517:       .maybeSingle();
 8518: 
 8519:     if (onboardingError) throw onboardingError;
 8520:     if (!onboarding)
 8521:       throw new Error(
 8522:         "Données d'onboarding introuvables. Veuillez compléter votre profil.",
 8523:       );
 8524: 
 8525:     // 3. Créer le chauffeur principal
 8526:     const primaryDriver = {
 8527:       tenant_id: tenantId,
 8528:       first_name: onboarding.first_name,
 8529:       last_name: onboarding.last_name,
 8530:       phone: onboarding.phone,
 8531:       license_number: onboarding.vtc_license_number,
 8532:       user_id: userId,
 8533:     };
 8534: 
 8535:     const { data, error: insertError } = await supabase
 8536:       .from("drivers")
 8537:       .insert([primaryDriver])
 8538:       .select()
 8539:       .limit(1)
 8540:       .maybeSingle();
 8541: 
 8542:     if (insertError) throw insertError;
 8543: 
 8544:     return { success: true, data };
 8545:   } catch (err: any) {
 8546:     console.error("Error in initializePrimaryDriver:", err);
 8547:     return { success: false, error: err.message };
 8548:   }
 8549: };
