 8190: <script>
 8191:     // --- GESTION DES ONGLETS / FILTRES ---
 8192:     const tabs = document.querySelectorAll('.filter-tab');
 8193:     const rows = document.querySelectorAll('.onboarding-row');
 8194:     const emptyState = document.getElementById('empty-state');
 8195:     const countBadge = document.getElementById('count-badge');
 8196: 
 8197:     function filterTable(status: string) {
 8198:         let count = 0;
 8199:         rows.forEach(row => {
 8200:             const rowStatus = (row as HTMLElement).dataset.status;
 8201:             if (rowStatus === status) {
 8202:                 (row as HTMLElement).style.display = 'table-row';
 8203:                 count++;
 8204:             } else {
 8205:                 (row as HTMLElement).style.display = 'none';
 8206:             }
 8207:         });
 8208: 
 8209:         // Toggle empty state
 8210:         if (count === 0) {
 8211:             emptyState?.classList.remove('hidden');
 8212:         } else {
 8213:             emptyState?.classList.add('hidden');
 8214:         }
 8215: 
 8216:         // Update badge
 8217:         if (countBadge) {
 8218:             countBadge.textContent = `${count} Dossier${count > 1 ? 's' : ''}`;
 8219:         }
 8220: 
 8221:         // Update tabs style
 8222:         tabs.forEach(t => {
 8223:             if (t.getAttribute('data-target') === status) {
 8224:                 t.classList.add('bg-indigo-600/20', 'text-white');
 8225:                 t.classList.remove('text-slate-400');
 8226:             } else {
 8227:                 t.classList.remove('bg-indigo-600/20', 'text-white');
 8228:                 t.classList.add('text-slate-400');
 8229:             }
 8230:         });
 8231:     }
 8232: 
 8233:     tabs.forEach(tab => {
 8234:         tab.addEventListener('click', () => {
 8235:             const target = tab.getAttribute('data-target')!;
 8236:             filterTable(target);
 8237:         });
 8238:     });
 8239: 
 8240:     // Filtre par défaut au chargement
 8241:     filterTable('pending');
 8242: 
 8243:     // --- GESTION DES DÉTAILS ---
 8244:     const detModal = document.getElementById('details-modal');
 8245:     const closeDet = document.getElementById('close-details');
 8246:     const detailsBtns = document.querySelectorAll('.details-btn');
 8247: 
 8248:     detailsBtns.forEach(btn => {
 8249:         btn.addEventListener('click', () => {
 8250:             const ob = JSON.parse(btn.getAttribute('data-ob') || '{}');
