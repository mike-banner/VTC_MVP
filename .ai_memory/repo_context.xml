## File: supabase/functions/cancel-booking/index.ts
````typescript
  1: import { serve } from "https://deno.land/std@0.224.0/http/server.ts";
  2: import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
  3: import Stripe from "https://esm.sh/stripe@12.18.0?target=deno&no-check";
  4: const stripe = new Stripe(Deno.env.get("STRIPE_SECRET_KEY")!, {
  5:   apiVersion: "2024-06-20",
  6: });
  7: serve(async (req) => {
  8:   try {
  9:     const { booking_id, reason } = await req.json();
 10:     if (!booking_id || !reason) {
 11:       return new Response("Missing params", { status: 400 });
 12:     }
 13:     const supabase = createClient(
 14:       Deno.env.get("SUPABASE_URL")!,
 15:       Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!,
 16:     );
 17:     const { data: booking } = await supabase
 18:       .from("bookings")
 19:       .select("*")
 20:       .eq("id", booking_id)
 21:       .limit(1)
 22:       .maybeSingle();
 23:     if (!booking) {
 24:       return new Response("Booking not found", { status: 404 });
 25:     }
 26:     const { data: policy } = await supabase
 27:       .from("cancellation_policies")
 28:       .select("*")
 29:       .eq("id", booking.cancellation_policy_id)
 30:       .limit(1)
 31:       .maybeSingle();
 32:     if (!policy) {
 33:       return new Response("Policy not found", { status: 400 });
 34:     }
 35:     const now = new Date();
 36:     const pickup = new Date(booking.pickup_time);
 37:     const deltaHours = (pickup.getTime() - now.getTime()) / (1000 * 60 * 60);
 38:     let refundRate = 0;
 39:     if (reason === "driver_fault") {
 40:       refundRate = policy.driver_fault_refund_rate;
 41:     } else if (reason === "no_show") {
 42:       refundRate = policy.no_show_refund_rate;
 43:     } else if (deltaHours >= policy.hours_before_full_refund) {
 44:       refundRate = 1;
 45:     } else if (deltaHours >= policy.hours_before_partial_refund) {
 46:       refundRate = policy.partial_refund_rate;
 47:     }
 48:     const refundAmount = booking.total_amount * refundRate;
 49:     if (refundAmount <= 0) {
 50:       const { error } = await supabase
 51:         .from("bookings")
 52:         .update({
 53:           status: "cancelled_no_refund",
 54:           cancellation_reason: reason,
 55:           cancelled_at: now.toISOString(),
 56:         })
 57:         .eq("id", booking_id)
 58:         .eq("status", "paid");
 59:       if (error) {
 60:         return new Response("Cancellation failed", { status: 400 });
 61:       }
 62:       return new Response(JSON.stringify({ refund: 0 }), {
 63:         headers: { "Content-Type": "application/json" },
 64:       });
 65:     }
 66:     const { data: lockData, error: lockError } = await supabase.rpc(
 67:       "initiate_refund",
 68:       {
 69:         p_booking_id: booking_id,
 70:         p_reason: reason,
 71:       },
 72:     );
 73:     if (lockError || !lockData || !lockData[0]?.refund_allowed) {
 74:       return new Response("Refund not allowed", { status: 400 });
 75:     }
 76:     const paymentIntentId = lockData[0].payment_intent_id;
 77:     try {
 78:       await stripe.refunds.create({
 79:         payment_intent: paymentIntentId,
 80:         amount: Math.round(refundAmount * 100),
 81:       });
 82:       return new Response(
 83:         JSON.stringify({ success: true, refund: refundAmount }),
 84:         {
 85:           headers: { "Content-Type": "application/json" },
 86:         },
 87:       );
 88:     } catch (err) {
 89:       await supabase
 90:         .from("bookings")
 91:         .update({ status: "refund_failed" })
 92:         .eq("id", booking_id);
 93:       console.error("Stripe refund error:", err);
 94:       return new Response("Stripe refund failed", { status: 500 });
 95:     }
 96:   } catch (err) {
 97:     console.error("Handler error:", err);
 98:     return new Response(String(err), { status: 500 });
 99:   }
100: });
````

