 4198:             ELSE (0)::numeric
 4199:         END), (0)::numeric) AS "total_gross_revenue",
 4200:     COALESCE("sum"(
 4201:         CASE
 4202:             WHEN ("movement_type" = 'refund'::"public"."movement_type_enum") THEN "gross_amount"
 4203:             ELSE (0)::numeric
