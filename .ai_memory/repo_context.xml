13930: <script>
13931: 	import { supabase } from "@/lib/supabase/client";
13932: 
13933: 	const form = document.querySelector("#signup-form") as HTMLFormElement;
13934: 	const messageEl = document.querySelector("#message") as HTMLDivElement;
13935: 	const submitBtn = document.querySelector(
13936: 		"#submit-btn",
13937: 	) as HTMLButtonElement;
13938: 	const loader = document.querySelector(
13939: 		".loader-container",
13940: 	) as HTMLDivElement;
13941: 	const btnText = document.querySelector(".btn-text") as HTMLSpanElement;
13942: 
13943: 	form?.addEventListener("submit", async (e) => {
13944: 		e.preventDefault();
13945: 
13946: 		const formData = new FormData(form);
13947: 		const email = formData.get("email") as string;
13948: 		const password = formData.get("password") as string;
13949: 
13950: 		// UI State: Loading
13951: 		submitBtn.disabled = true;
13952: 		loader.classList.remove("hidden");
13953: 		btnText.style.opacity = "0";
13954: 		messageEl.textContent = "";
13955: 
13956: 		try {
13957: 			const { data, error } = await supabase.auth.signUp({
13958: 				email,
13959: 				password,
13960: 			});
13961: 
13962: 			if (error) {
13963: 				if (
13964: 					error.status === 400 ||
13965: 					error.message.toLowerCase().includes("already registered")
13966: 				) {
13967: 					messageEl.innerHTML = `Utilisateur déjà inscrit. <a href="/login" class="text-indigo-400 font-bold underline">Connecte-toi ici</a>`;
13968: 					messageEl.className =
13969: 						"mt-6 p-4 rounded-xl bg-amber-500/10 border border-amber-500/20 text-center text-sm font-medium text-amber-400";
13970: 				} else {
13971: 					messageEl.textContent = "Erreur : " + error.message;
13972: 					messageEl.className =
13973: 						"mt-6 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-center text-sm font-medium text-red-400";
13974: 				}
13975: 				submitBtn.disabled = false;
13976: 				loader.classList.add("hidden");
13977: 				btnText.style.opacity = "1";
13978: 			} else {
13979: 				// 📧 Envoi email de bienvenue (Non bloquant pour l'UX utilisateur)
13980: 				try {
13981: 					await supabase.functions.invoke("send-email", {
13982: 						body: {
13983: 							to: email,
13984: 							subject: "Bienvenue sur VTC MVP ! 🚀",
13985: 							html: `
13986: 								<div style="font-family: sans-serif; max-width: 600px; margin: auto; padding: 20px;">
13987: 									<h1 style="color: #4f46e5;">Bienvenue sur VTC MVP !</h1>
13988: 									<p>Salut,</p>
