10733: <file path="supabase/functions/cancel-booking/index.ts">
10734: import { serve } from "https://deno.land/std@0.224.0/http/server.ts";
10735: import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
10736: import Stripe from "https://esm.sh/stripe@12.18.0?target=deno&no-check";
10737: 
10738: const stripe = new Stripe(Deno.env.get("STRIPE_SECRET_KEY")!, {
10739:   apiVersion: "2024-06-20",
10740: });
10741: 
10742: serve(async (req) => {
10743:   try {
10744:     const { booking_id, reason } = await req.json();
10745: 
10746:     if (!booking_id || !reason) {
10747:       return new Response("Missing params", { status: 400 });
10748:     }
10749: 
10750:     const supabase = createClient(
10751:       Deno.env.get("SUPABASE_URL")!,
10752:       Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!,
10753:     );
10754: 
10755:     // 1️⃣ Load booking
10756:     const { data: booking } = await supabase
10757:       .from("bookings")
10758:       .select("*")
10759:       .eq("id", booking_id)
10760:       .limit(1)
10761:       .maybeSingle();
10762: 
10763:     if (!booking) {
10764:       return new Response("Booking not found", { status: 404 });
10765:     }
10766: 
10767:     // 2️⃣ Load cancellation policy
10768:     const { data: policy } = await supabase
10769:       .from("cancellation_policies")
10770:       .select("*")
10771:       .eq("id", booking.cancellation_policy_id)
10772:       .limit(1)
10773:       .maybeSingle();
10774: 
10775:     if (!policy) {
10776:       return new Response("Policy not found", { status: 400 });
10777:     }
10778: 
10779:     const now = new Date();
10780:     const pickup = new Date(booking.pickup_time);
10781:     const deltaHours = (pickup.getTime() - now.getTime()) / (1000 * 60 * 60);
10782: 
10783:     let refundRate = 0;
10784: 
10785:     if (reason === "driver_fault") {
10786:       refundRate = policy.driver_fault_refund_rate;
10787:     } else if (reason === "no_show") {
10788:       refundRate = policy.no_show_refund_rate;
10789:     } else if (deltaHours >= policy.hours_before_full_refund) {
10790:       refundRate = 1;
10791:     } else if (deltaHours >= policy.hours_before_partial_refund) {
10792:       refundRate = policy.partial_refund_rate;
10793:     }
10794: 
10795:     const refundAmount = booking.total_amount * refundRate;
10796: 
10797:     // 3️⃣ Cas sans remboursement
10798:     if (refundAmount <= 0) {
10799:       const { error } = await supabase
10800:         .from("bookings")
10801:         .update({
10802:           status: "cancelled_no_refund",
10803:           cancellation_reason: reason,
10804:           cancelled_at: now.toISOString(),
10805:         })
10806:         .eq("id", booking_id)
10807:         .eq("status", "paid");
10808: 
10809:       if (error) {
10810:         return new Response("Cancellation failed", { status: 400 });
10811:       }
10812: 
10813:       return new Response(JSON.stringify({ refund: 0 }), {
10814:         headers: { "Content-Type": "application/json" },
10815:       });
10816:     }
10817: 
10818:     // 4️⃣ 🔒 Verrou transactionnel via RPC
10819:     const { data: lockData, error: lockError } = await supabase.rpc(
10820:       "initiate_refund",
10821:       {
10822:         p_booking_id: booking_id,
10823:         p_reason: reason,
10824:       },
10825:     );
10826: 
10827:     if (lockError || !lockData || !lockData[0]?.refund_allowed) {
10828:       return new Response("Refund not allowed", { status: 400 });
10829:     }
10830: 
10831:     const paymentIntentId = lockData[0].payment_intent_id;
10832: 
10833:     // 5️⃣ Appel Stripe sécurisé
10834:     try {
10835:       await stripe.refunds.create({
10836:         payment_intent: paymentIntentId,
10837:         amount: Math.round(refundAmount * 100),
10838:       });
10839: 
10840:       return new Response(
10841:         JSON.stringify({ success: true, refund: refundAmount }),
10842:         {
10843:           headers: { "Content-Type": "application/json" },
10844:         },
10845:       );
10846:     } catch (err) {
10847:       await supabase
10848:         .from("bookings")
10849:         .update({ status: "refund_failed" })
10850:         .eq("id", booking_id);
10851: 
10852:       console.error("Stripe refund error:", err);
10853:       return new Response("Stripe refund failed", { status: 500 });
10854:     }
10855:   } catch (err) {
10856:     console.error("Handler error:", err);
10857:     return new Response(String(err), { status: 500 });
10858:   }
10859: });
10860: </file>
