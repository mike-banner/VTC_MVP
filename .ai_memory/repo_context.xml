 2099: export async function requirePlatformAdmin(profile: any) {
 2100:   if (!profile?.id) {
 2101:     throw new Error("Unauthorized");
 2102:   }
 2103: 
 2104:   const supabaseAdmin = createAdminClient();
 2105: 
 2106:   const { data, error } = await supabaseAdmin
 2107:     .from("profiles")
 2108:     .select("platform_role")
 2109:     .eq("id", profile.id)
 2110:     .maybeSingle();
 2111: 
 2112:   if (error || !data || !PLATFORM_ROLES.includes(data.platform_role)) {
 2113:     throw new Error("Unauthorized");
 2114:   }
 2115: 
 2116:   return true;
 2117: }
