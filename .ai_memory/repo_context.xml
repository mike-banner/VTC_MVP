 3325: CREATE OR REPLACE FUNCTION "public"."approve_onboarding_tx"("onboarding_uuid" "uuid") RETURNS "void"
 3326:     LANGUAGE "plpgsql" SECURITY DEFINER
 3327:     SET "search_path" TO 'public'
 3328:     AS $$
 3329: declare
 3330:   new_tenant_id uuid := gen_random_uuid();
 3331: begin
 3332: 
 3333:   -- 1️⃣ Vérifier que le dossier existe et est pending
 3334:   if not exists (
 3335:     select 1 from onboarding
 3336:     where id = onboarding_uuid
 3337:       and status = 'pending'
 3338:   ) then
 3339:     raise exception 'Onboarding not found or already processed';
 3340:   end if;
 3341: 
 3342:   -- 2️⃣ Créer le tenant avec email (auth.users) + phone (onboarding)
 3343:   insert into tenants (
 3344:     id,
 3345:     name,
 3346:     primary_domain,
 3347:     email,
 3348:     phone
 3349:   )
 3350:   select
 3351:     new_tenant_id,
 3352:     o.company_name,
 3353:     o.primary_domain,
 3354:     u.email,
 3355:     o.phone
 3356:   from onboarding o
 3357:   join profiles p on p.id = o.profile_id
 3358:   join auth.users u on u.id = p.id
 3359:   where o.id = onboarding_uuid;
 3360: 
 3361:   -- 3️⃣ Mettre à jour le profile
 3362:   update profiles p
 3363:   set
 3364:     tenant_id = new_tenant_id,
 3365:     tenant_role = 'owner',
 3366:     first_name = o.first_name,
 3367:     last_name = o.last_name
 3368:   from onboarding o
 3369:   where o.id = onboarding_uuid
 3370:     and p.id = o.profile_id;
 3371: 
 3372:   -- 4️⃣ Marquer onboarding validé
 3373:   update onboarding
 3374:   set
 3375:     status = 'approved',
 3376:     validated_at = now()
 3377:   where id = onboarding_uuid;
 3378: 
 3379: end;
 3380: $$;
