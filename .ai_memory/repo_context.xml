 30:     obj?.id && obj?.object === "checkout.session"
 31:       ? obj.id
 32:       : (obj?.checkout_session ?? null);
 33:   const paymentIntent = obj?.payment_intent ?? obj?.id ?? null;
 34:   const tenantId = obj?.metadata?.tenant_id ?? null;
 35:   const amount = obj?.amount_total
 36:     ? obj.amount_total / 100
