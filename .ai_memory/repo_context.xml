308:         btn.addEventListener('click', () => {
309:             const rule = JSON.parse(btn.getAttribute('data-rule') || '{}');
310:             if (modalTitle) modalTitle.innerText = "Édition Tarif";
311:             if (ruleIdInput) ruleIdInput.value = rule.id;
312:             if (serviceInput) serviceInput.value = rule.service_category;
313:             if (baseInput) baseInput.value = rule.base_price;
314:             if (kmInput) kmInput.value = rule.price_per_km;
315:             if (hourInput) hourInput.value = rule.price_per_hour || "0";
316:             if (minInput) minInput.value = rule.minimum_fare;
317:             if (activeInput) activeInput.checked = rule.active;
