 8776: <file path="supabase/functions/calculate-refund/index.ts">
 8777: import { serve } from "https://deno.land/std@0.224.0/http/server.ts";
 8778: import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
 8779: 
 8780: serve(async (req) => {
 8781:   const { booking_id, cancelled_at, reason } = await req.json();
 8782: 
 8783:   if (!booking_id || !cancelled_at || !reason) {
 8784:     return new Response("Missing params", { status: 400 });
 8785:   }
 8786: 
 8787:   const supabase = createClient(
 8788:     Deno.env.get("SUPABASE_URL")!,
 8789:     Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!,
 8790:   );
 8791: 
 8792:   // 1️⃣ Load booking
 8793:   const { data: booking, error: bookingError } = await supabase
 8794:     .from("bookings")
 8795:     .select("*")
 8796:     .eq("id", booking_id)
 8797:     .maybeSingle();
 8798: 
 8799:   if (bookingError || !booking) {
 8800:     return new Response("Booking not found", { status: 404 });
 8801:   }
 8802: 
 8803:   // 🔒 Only calculable if paid or refund_failed
 8804:   if (!["paid", "refund_failed"].includes(booking.status)) {
 8805:     return new Response("Refund not allowed for this status", { status: 400 });
 8806:   }
 8807: 
 8808:   if (!booking.cancellation_policy_id) {
 8809:     return new Response("Missing cancellation policy", { status: 400 });
 8810:   }
 8811: 
 8812:   // 2️⃣ Load policy
 8813:   const { data: policy, error: policyError } = await supabase
 8814:     .from("cancellation_policies")
 8815:     .select("*")
 8816:     .eq("id", booking.cancellation_policy_id)
 8817:     .maybeSingle();
 8818: 
 8819:   if (policyError || !policy) {
 8820:     return new Response("Policy not found", { status: 400 });
 8821:   }
 8822: 
 8823:   const pickupTime = new Date(booking.pickup_time);
 8824:   const cancelTime = new Date(cancelled_at);
 8825: 
 8826:   if (isNaN(cancelTime.getTime())) {
 8827:     return new Response("Invalid cancellation date", { status: 400 });
 8828:   }
 8829: 
 8830:   const deltaHours =
 8831:     (pickupTime.getTime() - cancelTime.getTime()) / (1000 * 60 * 60);
 8832: 
 8833:   let refundRate = 0;
 8834: 
 8835:   if (reason === "driver_fault") {
 8836:     refundRate = policy.driver_fault_refund_rate;
 8837:   } else if (reason === "no_show") {
 8838:     refundRate = policy.no_show_refund_rate;
 8839:   } else if (deltaHours >= policy.hours_before_full_refund) {
 8840:     refundRate = 1;
 8841:   } else if (deltaHours >= policy.hours_before_partial_refund) {
 8842:     refundRate = policy.partial_refund_rate;
 8843:   }
 8844: 
 8845:   // Clamp sécurité
 8846:   if (refundRate < 0) refundRate = 0;
 8847:   if (refundRate > 1) refundRate = 1;
 8848: 
 8849:   const refundAmount = Number(booking.total_amount) * refundRate;
 8850: 
 8851:   return new Response(
 8852:     JSON.stringify({
 8853:       refund_rate: refundRate,
 8854:       refund_amount: refundAmount,
 8855:     }),
 8856:     {
 8857:       headers: { "Content-Type": "application/json" },
 8858:     },
 8859:   );
 8860: });
 8861: </file>
