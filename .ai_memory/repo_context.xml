 7475: // src/pages/admin/bookings.astro
 7476: import AdminLayout from "../../layouts/AdminLayout.astro";
 7477: import { requirePlatformAdmin } from "../../lib/guards/platform";
 7478: import { createAdminClient } from "../../lib/supabase/server";
 7479: 
 7480: const { profile } = Astro.locals;
 7481: 
 7482: // 1. Sécurité : Vérification plateforme
 7483: try {
 7484:   await requirePlatformAdmin(profile);
 7485: } catch {
 7486:   return Astro.redirect("/login");
 7487: }
 7488: 
 7489: const supabaseAdmin = createAdminClient();
 7490: 
 7491: // 2. Paramètres de pagination et filtres
 7492: const PAGE_SIZE = 25;
 7493: const url = Astro.url;
 7494: const page = parseInt(url.searchParams.get("page") || "1");
 7495: const status = url.searchParams.get("status") || "";
 7496: const driver_id = url.searchParams.get("driver_id") || "";
 7497: const email = url.searchParams.get("email") || "";
 7498: const dateFrom = url.searchParams.get("from") || "";
 7499: const dateTo = url.searchParams.get("to") || "";
 7500: const minAmount = url.searchParams.get("min") || "";
 7501: const maxAmount = url.searchParams.get("max") || "";
 7502: 
 7503: const fromIndex = (page - 1) * PAGE_SIZE;
 7504: const toIndex = fromIndex + PAGE_SIZE - 1;
 7505: 
 7506: // 3. Construction de la requête principale via la VUE ADMIN
 7507: let query = supabaseAdmin
 7508:     .from("admin_bookings_full_view")
 7509:     .select("*", { count: "exact" });
 7510: 
 7511: if (status) query = query.eq("status", status);
 7512: if (driver_id) query = query.eq("driver_id", driver_id);
 7513: if (email) query = query.ilike("display_customer_email", `%${email}%`);
 7514: if (dateFrom) query = query.gte("created_at", `${dateFrom}T00:00:00`);
 7515: if (dateTo) query = query.lte("created_at", `${dateTo}T23:59:59`);
 7516: if (minAmount) query = query.gte("total_amount", parseFloat(minAmount));
 7517: if (maxAmount) query = query.lte("total_amount", parseFloat(maxAmount));
 7518: 
 7519: const { data: bookings, count, error } = await query
 7520:     .order("created_at", { ascending: false })
 7521:     .range(fromIndex, toIndex);
 7522: 
 7523: if (error) console.error("Admin Bookings Fetch Error:", error);
 7524: 
 7525: // 4. Données pour les filtres (chauffeurs)
 7526: const { data: drivers } = await supabaseAdmin
 7527:     .from("drivers")
 7528:     .select("id, first_name, last_name")
 7529:     .order("last_name");
 7530: 
 7531: const totalPages = count ? Math.ceil(count / PAGE_SIZE) : 0;
 7532: 
 7533: // Utilitaire pour construire les liens de pagination en gardant les filtres
 7534: const getPaginationUrl = (p: number) => {
 7535:     const params = new URLSearchParams(url.searchParams);
 7536:     params.set("page", p.toString());
 7537:     return `${url.pathname}?${params.toString()}`;
 7538: };
 7539: 
 7540: const getStatusBadge = (s: string) => {
 7541:     switch (s) {
 7542:         case 'pending': return 'bg-amber-500/10 text-amber-500 border-amber-500/20';
 7543:         case 'accepted': return 'bg-blue-500/10 text-blue-500 border-blue-500/20';
 7544:         case 'paid': return 'bg-emerald-500/10 text-emerald-500 border-emerald-500/20';
 7545:         case 'completed': return 'bg-indigo-500/10 text-indigo-500 border-indigo-500/20';
 7546:         case 'cancelled': return 'bg-red-500/10 text-red-500 border-red-500/20';
 7547:         case 'refunded': return 'bg-purple-500/10 text-purple-500 border-purple-500/20';
 7548:         default: return 'bg-slate-500/10 text-slate-500 border-slate-500/20';
 7549:     }
 7550: }
