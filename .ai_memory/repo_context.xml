246:     const toggleTabs = (mode: 'standard' | 'transfer') => {
247:         if (mode === 'standard') {
248:             btnStandard?.classList.add('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-600/20');
249:             btnStandard?.classList.remove('text-slate-500');
250:             btnTransfer?.classList.remove('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-600/20');
251:             btnTransfer?.classList.add('text-slate-500');
252: 
253:             secStandard?.classList.remove('hidden');
