 7753: // src/pages/admin/dashboard.astro
 7754: import KPIGrid from "../../components/admin/KPIGrid.astro";
 7755: import MonthlyChart from "../../components/admin/MonthlyChart.astro";
 7756: import AdminLayout from "../../layouts/AdminLayout.astro";
 7757: import { requirePlatformAdmin } from "../../lib/guards/platform";
 7758: import { createAdminClient } from "../../lib/supabase/server";
 7759: 
 7760: 
 7761: const { profile } = Astro.locals;
 7762: 
 7763: // Protection d'accès plateforme
 7764: try {
 7765:   await requirePlatformAdmin(profile);
 7766: } catch {
 7767:   return Astro.redirect("/login");
 7768: }
 7769: 
 7770: const supabaseAdmin = createAdminClient();
 7771: 
 7772: // Récupération des données via la nouvelle vue complète
 7773: const { data: latestBookings, error } = await supabaseAdmin
 7774:   .from('admin_bookings_full_view')
 7775:   .select('*')
 7776:   .order('created_at', { ascending: false })
 7777:   .limit(10);
 7778: 
 7779: if (error) console.error("Dashboard Fetch Error:", error);
 7780: 
 7781: // 1️⃣ KPIs Globaux (Source: Ledger)
 7782: const { data: globalStats } = await supabaseAdmin
 7783:     .from("financial_movements")
 7784:     .select(`
 7785:         gross_amount,
 7786:         net_amount,
 7787:         movement_type
 7788:     `);
 7789: 
 7790: const stats = (globalStats || []).reduce((acc, curr) => {
 7791:     if (curr.movement_type === 'payment') {
 7792:         acc.total_collected += Number(curr.gross_amount);
 7793:         acc.total_net += Number(curr.net_amount);
 7794:     } else if (curr.movement_type === 'refund') {
