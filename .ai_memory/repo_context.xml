17278: <script>
17279:     import { supabase } from "@/lib/supabase/client";
17280: 
17281:     const modal = document.getElementById('booking-modal');
17282:     const driverId = modal?.getAttribute('data-driver-id');
17283:     const closeBtns = document.querySelectorAll('.close-modal');
17284:     const overlay = document.querySelector('.modal-overlay');
17285: 
17286:     const toggleModal = () => {
17287:         modal?.classList.toggle('opacity-0');
17288:         modal?.classList.toggle('pointer-events-none');
17289:         modal?.querySelector('.relative')?.classList.toggle('scale-95');
17290:         document.body.classList.toggle('overflow-hidden');
17291:     };
17292: 
17293:     document.querySelectorAll('.booking-row').forEach(row => {
17294:         row.addEventListener('click', () => {
17295:             const booking = JSON.parse(row.getAttribute('data-booking') || '{}');
17296: 
17297:             // Populate Modal
17298:             const nameEl = document.getElementById('modal-client-name');
17299:             const emailEl = document.getElementById('modal-client-email');
17300:             const emailLinkEl = document.getElementById('modal-client-email-link') as HTMLAnchorElement;
17301:             const phoneEl = document.getElementById('modal-client-phone');
17302:             const phoneLinkEl = document.getElementById('modal-client-phone-link') as HTMLAnchorElement;
17303:             const pickupEl = document.getElementById('modal-pickup');
17304:             const dropoffEl = document.getElementById('modal-dropoff');
17305:             const passengersEl = document.getElementById('modal-passengers');
17306:             const luggageEl = document.getElementById('modal-luggage');
17307:             const notesEl = document.getElementById('modal-notes');
17308:             const timeEl = document.getElementById('modal-time');
17309:             const mapLinkEl = document.getElementById('modal-map-link') as HTMLAnchorElement;
17310:             const dateEl = document.getElementById('modal-date');
17311:             const amountEl = document.getElementById('modal-amount');
17312:             const refEl = document.getElementById('modal-booking-ref');
17313:             const typeEl = document.getElementById('modal-booking-type');
17314:             const statusEl = document.getElementById('modal-status-badge');
17315: 
17316:             const STATUS_LABELS_FR: Record<string, string> = {
17317:                 pending: "En attente",
17318:                 accepted: "Confirmée",
17319:                 accepted_pending_payment: "En attente de paiement",
17320:                 paid: "Payée",
17321:                 completed: "Terminée",
17322:                 cancelled: "Annulée",
17323:                 cancelled_pending_refund: "Remboursement en cours",
17324:                 cancelled_refunded: "Remboursée",
17325:                 cancelled_no_refund: "Annulée",
17326:                 deprecated_refunded: "Remboursée",
17327:                 no_show: "Non présentation",
17328:                 expired_payment: "Paiement expiré",
17329:                 refund_failed: "Échec remboursement"
17330:             };
17331: 
17332:             if (nameEl) nameEl.innerText = `${booking.customers.first_name} ${booking.customers.last_name}`;
17333: 
17334:             if (emailEl) emailEl.innerText = booking.customers.email;
17335:             if (emailLinkEl) emailLinkEl.href = `mailto:${booking.customers.email}`;
17336: 
17337:             if (phoneEl) phoneEl.innerText = booking.customers.phone || 'Non renseigné';
17338:             if (phoneLinkEl) {
17339:                 if (booking.customers.phone) {
17340:                     phoneLinkEl.href = `tel:${booking.customers.phone}`;
17341:                     phoneLinkEl.style.display = 'flex';
17342:                 } else {
17343:                     phoneLinkEl.style.display = 'none';
17344:                 }
17345:             }
17346: 
17347:             if (pickupEl) pickupEl.innerText = booking.pickup_address;
17348:             if (dropoffEl) dropoffEl.innerText = booking.dropoff_address || 'Non spécifiée';
17349:             if (passengersEl) passengersEl.innerText = booking.passenger_count?.toString() || '1';
17350:             if (luggageEl) luggageEl.innerText = booking.luggage_count?.toString() || '0';
17351:             if (notesEl) notesEl.innerText = booking.notes || 'Aucune note particulière.';
17352:             if (refEl) refEl.innerText = `REF: #${booking.id.split('-')[0].toUpperCase()}`;
17353:             if (statusEl) {
17354:                 const status = booking.status;
17355:                 statusEl.innerText = STATUS_LABELS_FR[status] || status;
17356: 
17357:                 // Optionnel: Couleur dynamique du badge status
17358:                 const statusColors: Record<string, string> = {
17359:                     pending: 'bg-amber-500/20 text-amber-500 border-amber-500/20',
17360:                     accepted: 'bg-emerald-500/20 text-emerald-500 border-emerald-500/20',
17361:                     paid: 'bg-indigo-500/20 text-indigo-400 border-indigo-500/20',
17362:                     completed: 'bg-slate-500/20 text-slate-400 border-slate-500/20',
17363:                     cancelled: 'bg-rose-500/20 text-rose-500 border-rose-500/20'
17364:                 };
17365:                 statusEl.className = `px-3 py-1.5 backdrop-blur-md rounded-lg border text-[9px] font-black uppercase tracking-widest ${statusColors[status] || 'bg-white/10 text-white border-white/10'}`;
17366: 
17367:                 // --- LOGIQUE BOUTON ACCEPTER ---
17368:                 const acceptBtn = document.getElementById('modal-accept-btn');
17369:                 if (acceptBtn) {
17370:                     if (status === 'paid') {
17371:                         acceptBtn.classList.remove('hidden');
17372: 
17373:                         if (!driverId) {
17374:                             acceptBtn.classList.add('opacity-50');
17375:                             acceptBtn.onclick = () => {
17376:                                 alert("Attention : Vous devez être enregistré comme chauffeur pour accepter cette course. Veuillez créer votre profil chauffeur dans la section 'Chauffeurs'.");
17377:                             };
17378:                         } else {
17379:                             acceptBtn.classList.remove('opacity-50');
17380:                             acceptBtn.onclick = async () => {
17381:                                 try {
17382:                                     acceptBtn.innerText = "Traitement...";
17383:                                     acceptBtn.setAttribute('disabled', 'true');
17384: 
17385:                                     // Appel de la fonction Edge Supabase accept-booking
17386:                                     const { error } = await supabase.functions.invoke('accept-booking', {
17387:                                         body: { booking_id: booking.id, driver_id: driverId }
17388:                                     });
17389: 
17390:                                     if (error) throw error;
17391: 
17392:                                     // Si OK, on reload
17393:                                     window.location.reload();
17394:                                 } catch (err) {
17395:                                     console.error("Erreur Accept Booking:", err);
17396:                                     alert("Une erreur est survenue lors de l'acceptation de la course.");
17397:                                     acceptBtn.innerText = "Accepter la course";
17398:                                     acceptBtn.removeAttribute('disabled');
17399:                                 }
17400:                             };
17401:                         }
17402:                     } else {
17403:                         acceptBtn.classList.add('hidden');
17404:                     }
17405:                 }
17406:             }
17407:             if (amountEl) amountEl.innerText = `${Number(booking.total_amount).toFixed(2)}€`;
17408:             if (mapLinkEl) mapLinkEl.href = `https://www.google.com/maps/dir/?api=1&origin=${encodeURIComponent(booking.pickup_address)}&destination=${encodeURIComponent(booking.dropoff_address || '')}`;
17409: 
17410:             if (typeEl) {
17411:                 const isHourly = (booking.booking_type as any) === 'hourly';
17412:                 typeEl.innerText = isHourly ? 'MISE À DISPOSITION' : 'TRANSFERT';
17413:                 typeEl.className = `px-2 py-0.5 rounded text-[8px] font-black uppercase tracking-widest border ${
17414:                     isHourly
17415:                     ? 'bg-amber-500/10 text-amber-500 border-amber-500/20'
17416:                     : 'bg-indigo-500/10 text-indigo-400 border-indigo-500/20'
17417:                 }`;
17418:             }
17419: 
17420:             const dateObj = new Date(booking.pickup_time);
17421:             if (timeEl) timeEl.innerText = dateObj.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
17422:             if (dateEl) dateEl.innerText = dateObj.toLocaleDateString('fr-FR', { day: '2-digit', month: 'long', year: 'numeric' });
17423: 
17424:             toggleModal();
17425:         });
17426:     });
17427: 
17428:     closeBtns.forEach(btn => btn.addEventListener('click', toggleModal));
17429:     overlay?.addEventListener('click', toggleModal);
17430: </script>
