 7439: export type TenantRole = "owner" | "manager" | "driver";
 7440: 
 7441: /**
 7442:  * Vérifie si le profil est un administrateur plateforme
 7443:  */
 7444: const PLATFORM_ROLES = ["super_admin", "platform_staff"];
 7445: 
 7446: export function isPlatform(profile: any) {
 7447:   return PLATFORM_ROLES.includes(profile?.platform_role);
 7448: }
 7449: /**
 7450:  * Vérifie si le profil appartient à un tenant
 7451:  */
 7452: export function isTenant(profile: any) {
 7453:   return !!profile?.tenant_id;
 7454: }
 7455: 
 7456: /**
 7457:  * Vérifie les permissions au sein d'un tenant
 7458:  */
 7459: export function requireTenantRole(profile: any, allowed: TenantRole[]) {
 7460:   if (!profile?.tenant_role || !allowed.includes(profile.tenant_role)) {
 7461:     throw new Error("Access denied: Insufficient permissions");
 7462:   }
 7463: }
 7464: 
 7465: /**
 7466:  * Utilitaire booléen pour l'UI
 7467:  */
 7468: export function hasTenantRole(profile: any, allowed: TenantRole[]): boolean {
 7469:   return !!(profile?.tenant_role && allowed.includes(profile.tenant_role));
 7470: }
