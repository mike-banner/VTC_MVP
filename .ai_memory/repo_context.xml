## File: supabase/functions/calculate-refund/index.ts
````typescript
 1: import { serve } from "https://deno.land/std@0.224.0/http/server.ts";
 2: import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
 3: serve(async (req) => {
 4:   const { booking_id, cancelled_at, reason } = await req.json();
 5:   if (!booking_id || !cancelled_at || !reason) {
 6:     return new Response("Missing params", { status: 400 });
 7:   }
 8:   const supabase = createClient(
 9:     Deno.env.get("SUPABASE_URL")!,
10:     Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!,
11:   );
12:   const { data: booking, error: bookingError } = await supabase
13:     .from("bookings")
14:     .select("*")
15:     .eq("id", booking_id)
16:     .maybeSingle();
17:   if (bookingError || !booking) {
18:     return new Response("Booking not found", { status: 404 });
19:   }
20:   if (!["paid", "refund_failed"].includes(booking.status)) {
21:     return new Response("Refund not allowed for this status", { status: 400 });
22:   }
23:   if (!booking.cancellation_policy_id) {
24:     return new Response("Missing cancellation policy", { status: 400 });
25:   }
26:   const { data: policy, error: policyError } = await supabase
27:     .from("cancellation_policies")
28:     .select("*")
29:     .eq("id", booking.cancellation_policy_id)
30:     .maybeSingle();
31:   if (policyError || !policy) {
32:     return new Response("Policy not found", { status: 400 });
33:   }
34:   const pickupTime = new Date(booking.pickup_time);
35:   const cancelTime = new Date(cancelled_at);
36:   if (isNaN(cancelTime.getTime())) {
37:     return new Response("Invalid cancellation date", { status: 400 });
38:   }
39:   const deltaHours =
40:     (pickupTime.getTime() - cancelTime.getTime()) / (1000 * 60 * 60);
41:   let refundRate = 0;
42:   if (reason === "driver_fault") {
43:     refundRate = policy.driver_fault_refund_rate;
44:   } else if (reason === "no_show") {
45:     refundRate = policy.no_show_refund_rate;
46:   } else if (deltaHours >= policy.hours_before_full_refund) {
47:     refundRate = 1;
48:   } else if (deltaHours >= policy.hours_before_partial_refund) {
49:     refundRate = policy.partial_refund_rate;
50:   }
51:   if (refundRate < 0) refundRate = 0;
52:   if (refundRate > 1) refundRate = 1;
53:   const refundAmount = Number(booking.total_amount) * refundRate;
54:   return new Response(
55:     JSON.stringify({
56:       refund_rate: refundRate,
57:       refund_amount: refundAmount,
58:     }),
59:     {
60:       headers: { "Content-Type": "application/json" },
61:     },
62:   );
63: });
````

