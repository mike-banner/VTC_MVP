15: <script define:vars={{ timeoutMs }}>
16:     import { supabase } from "@/lib/supabase/client";
17: 
18:     let inactivityTimer;
19: 
20:     const logout = async () => {
21:         console.log("Inactivité détectée. Déconnexion automatique...");
22:         await supabase.auth.signOut();
23:         window.location.href = "/login?reason=inactivity";
24:     };
25: 
26:     const resetTimer = () => {
27:         clearTimeout(inactivityTimer);
28:         inactivityTimer = setTimeout(logout, timeoutMs);
29:     };
30: 
31:     // Liste des événements à surveiller pour réinitialiser le timer
32:     const activityEvents = [
33:         'mousedown',
34:         'mousemove',
35:         'keypress',
36:         'scroll',
37:         'touchstart',
38:         'click'
39:     ];
40: 
41:     // Initialisation
42:     const initInactivityTracker = () => {
43:         // Ne pas tracker si on est sur la page de login ou d'accueil publique
44:         const currentPath = window.location.pathname;
45:         if (currentPath === '/login' || currentPath === '/') return;
