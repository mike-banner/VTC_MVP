 6502: 
 6503: declare
 6504:   new_tenant_id uuid := gen_random_uuid();
 6505:   new_driver_id uuid := gen_random_uuid();
 6506: 
 6507: begin
 6508: 
 6509:   -- onboarding must exist and be pending
 6510:   if not exists (
 6511:     select 1
 6512:     from onboarding
 6513:     where id = onboarding_uuid
 6514:       and status = 'pending'
 6515:   ) then
 6516:     raise exception 'Onboarding not found or already processed';
 6517:   end if;
 6518: 
 6519: 
 6520:   -- prevent double tenant creation
 6521:   if exists (
 6522:     select 1
 6523:     from profiles p
 6524:     join onboarding o on o.profile_id = p.id
 6525:     where o.id = onboarding_uuid
 6526:       and p.tenant_id is not null
 6527:   ) then
 6528:     raise exception 'Tenant already created for this profile';
 6529:   end if;
 6530: 
 6531: 
 6532:   -- create tenant
 6533:   insert into tenants (
 6534:     id,
 6535:     name,
 6536:     primary_domain,
 6537:     email,
 6538:     phone
 6539:   )
 6540:   select
 6541:     new_tenant_id,
 6542:     o.company_name,
 6543:     o.primary_domain,
 6544:     u.email,
 6545:     o.phone
 6546:   from onboarding o
 6547:   join profiles p on p.id = o.profile_id
 6548:   join auth.users u on u.id = p.id
 6549:   where o.id = onboarding_uuid;
 6550: 
 6551: 
 6552:   -- update profile
 6553:   update profiles p
 6554:   set
 6555:     tenant_id = new_tenant_id,
 6556:     tenant_role = 'owner',
 6557:     first_name = o.first_name,
 6558:     last_name = o.last_name
 6559:   from onboarding o
 6560:   where o.id = onboarding_uuid
 6561:     and p.id = o.profile_id;
 6562: 
 6563: 
 6564:   -- create driver only once
 6565:   insert into drivers (
 6566:     id,
 6567:     tenant_id,
 6568:     first_name,
 6569:     last_name,
 6570:     phone,
 6571:     license_number
 6572:   )
 6573:   select
 6574:     new_driver_id,
 6575:     new_tenant_id,
 6576:     o.first_name,
 6577:     o.last_name,
 6578:     o.phone,
 6579:     o.vtc_license_number
 6580:   from onboarding o
 6581:   where o.id = onboarding_uuid;
 6582: 
 6583: 
 6584:   -- create vehicle if exists
 6585:   insert into vehicles (
 6586:     tenant_id,
 6587:     driver_id,
 6588:     brand,
 6589:     model,
 6590:     plate_number
 6591:   )
 6592:   select
 6593:     new_tenant_id,
 6594:     new_driver_id,
 6595:     o.vehicle_brand,
 6596:     o.vehicle_model,
 6597:     o.plate_number
 6598:   from onboarding o
 6599:   where o.id = onboarding_uuid
 6600:     and o.vehicle_brand is not null;
 6601: 
 6602: 
 6603:   -- mark onboarding approved
 6604:   update onboarding
 6605:   set
 6606:     status = 'approved',
