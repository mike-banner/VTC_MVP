259:             btnTransfer?.classList.remove('text-slate-500');
260:             btnStandard?.classList.remove('bg-indigo-600', 'text-white', 'shadow-lg', 'shadow-indigo-600/20');
261:             btnStandard?.classList.add('text-slate-500');
262: 
263:             secTransfer?.classList.remove('hidden');
264:             secStandard?.classList.add('hidden');
265: 
266:             actTransfer?.classList.remove('hidden');
267:         }
