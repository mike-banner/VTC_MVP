12730: <file path="supabase/functions/approve_onboarding/index.ts">
12731: import { serve } from "https://deno.land/std@0.168.0/http/server.ts";
12732: import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
12733: 
12734: serve(async (req) => {
12735:   try {
12736:     const authHeader = req.headers.get("Authorization");
12737: 
12738:     if (!authHeader) {
12739:       return new Response("Unauthorized", { status: 401 });
12740:     }
12741: 
12742:     // client user
12743:     const supabaseUser = createClient(
12744:       Deno.env.get("SUPABASE_URL")!,
12745:       Deno.env.get("SUPABASE_ANON_KEY")!,
12746:       {
12747:         global: { headers: { Authorization: authHeader } },
12748:       },
12749:     );
12750: 
12751:     const { data: userData } = await supabaseUser.auth.getUser();
12752: 
12753:     if (!userData?.user) {
12754:       return new Response("Unauthorized", { status: 401 });
12755:     }
12756: 
12757:     // check role
12758:     const { data: profile, error: profileError } = await supabaseUser
12759:       .from("profiles")
12760:       .select("platform_role")
12761:       .eq("id", userData.user.id)
12762:       .single();
12763: 
12764:     if (profileError) {
12765:       return new Response("Profile error", { status: 400 });
12766:     }
12767: 
12768:     if (!["super_admin", "platform_staff"].includes(profile.platform_role)) {
12769:       return new Response("Forbidden", { status: 403 });
12770:     }
12771: 
12772:     // payload
12773:     const { onboarding_id } = await req.json();
12774: 
12775:     if (!onboarding_id) {
12776:       return new Response("Missing onboarding_id", { status: 400 });
12777:     }
12778: 
12779:     // service role
12780:     const supabaseAdmin = createClient(
12781:       Deno.env.get("SUPABASE_URL")!,
12782:       Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!,
12783:     );
12784: 
12785:     // ✅ only SQL transaction
12786:     const { error } = await supabaseAdmin.rpc("approve_onboarding_tx", {
12787:       onboarding_uuid: onboarding_id,
12788:     });
12789: 
12790:     if (error) {
12791:       console.error("RPC error:", error);
12792:       return new Response(JSON.stringify(error), { status: 400 });
12793:     }
12794: 
12795:     return new Response(
12796:       JSON.stringify({ success: true }),
12797:       { status: 200 }
12798:     );
12799: 
12800:   } catch (err) {
12801:     console.error("Approve error:", err);
12802: 
12803:     return new Response(
12804:       JSON.stringify({ error: err?.message ?? err }),
12805:       { status: 500 }
12806:     );
12807:   }
12808: });
12809: </file>
