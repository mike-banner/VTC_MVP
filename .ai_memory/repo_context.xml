15464: <script>
15465:     import { supabase } from "@/lib/supabase/client";
15466: 
15467:     let currentStep = 1;
15468:     const totalSteps = 3;
15469: 
15470:     const form = document.getElementById("onboarding-form") as HTMLFormElement;
15471:     const contents = document.querySelectorAll(".step-content");
15472:     const headers = document.querySelectorAll(".step-header");
15473:     const dots = document.querySelectorAll(".step-dot");
15474:     const progressBar = document.getElementById(
15475:         "progress-bar",
15476:     ) as HTMLDivElement;
15477:     const nextBtn = document.getElementById("next-btn") as HTMLButtonElement;
15478:     const prevBtn = document.getElementById("prev-btn") as HTMLButtonElement;
15479:     const finalBtn = document.getElementById("final-btn") as HTMLButtonElement;
15480:     const statusEl = document.getElementById("status-msg") as HTMLDivElement;
15481: 
15482:     function updateUI() {
15483:         // Content & Header visibility
15484:         [contents, headers].forEach((group) => {
15485:             group.forEach((el) => {
15486:                 const step = parseInt(el.getAttribute("data-step")!);
15487:                 if (step === currentStep) {
15488:                     el.classList.remove("hidden");
15489:                     setTimeout(() => el.classList.remove("opacity-0"), 50);
15490:                 } else {
15491:                     el.classList.add("hidden", "opacity-0");
15492:                 }
15493:             });
15494:         });
15495: 
15496:         // Dots & Progress
15497:         dots.forEach((dot) => {
15498:             const step = parseInt(dot.getAttribute("data-step")!);
15499:             if (step <= currentStep) {
15500:                 dot.classList.add("border-indigo-500", "text-indigo-400");
15501:             } else {
15502:                 dot.classList.remove("border-indigo-500", "text-indigo-400");
15503:             }
15504:         });
15505: 
15506:         const progress = ((currentStep - 1) / (totalSteps - 1)) * 100;
15507:         progressBar.style.width = `${progress}%`;
15508: 
15509:         // Buttons
15510:         prevBtn.style.opacity = currentStep === 1 ? "0" : "1";
15511:         prevBtn.style.pointerEvents = currentStep === 1 ? "none" : "auto";
15512: 
15513:         if (currentStep === totalSteps) {
15514:             nextBtn.classList.add("hidden");
15515:             finalBtn.classList.remove("hidden");
15516:         } else {
15517:             nextBtn.classList.remove("hidden");
15518:             finalBtn.classList.add("hidden");
15519:         }
15520:     }
15521: 
15522:     nextBtn.addEventListener("click", () => {
15523:         if (currentStep < totalSteps) {
15524:             currentStep++;
15525:             updateUI();
15526:         }
15527:     });
15528: 
15529:     prevBtn.addEventListener("click", () => {
15530:         if (currentStep > 1) {
15531:             currentStep--;
15532:             updateUI();
15533:         }
15534:     });
15535: 
15536:     // Checkbox styling toggle
15537:     const checkboxes = document.querySelectorAll('input[type="checkbox"]');
15538:     checkboxes.forEach((cb) => {
15539:         cb.addEventListener("change", (e: any) => {
15540:             const parent = (e.target as HTMLInputElement).parentElement;
15541:             if (e.target.checked) {
15542:                 parent?.classList.add(
15543:                     "bg-indigo-500/20",
15544:                     "border-indigo-500/50",
15545:                     "text-indigo-400",
15546:                 );
15547:             } else {
15548:                 parent?.classList.remove(
15549:                     "bg-indigo-500/20",
15550:                     "border-indigo-500/50",
15551:                     "text-indigo-400",
15552:                 );
15553:             }
15554:         });
15555:     });
15556: 
15557:     // --- Système de Sauvegarde Locale (Solution 1) ---
15558:     const STORAGE_KEY = "vtc_onboarding_draft";
15559: 
15560:     async function saveDraft() {
15561:         const {
15562:             data: { user },
15563:         } = await supabase.auth.getUser();
15564:         if (!user) return;
15565: 
15566:         const formData = new FormData(form);
15567:         const data: Record<string, any> = {
15568:             currentStep,
15569:         };
15570: 
15571:         formData.forEach((value, key) => {
15572:             if (key === "service_categories") {
15573:                 if (!data[key]) data[key] = [];
15574:                 data[key].push(value);
15575:             } else {
15576:                 data[key] = value;
15577:             }
15578:         });
15579: 
15580:         localStorage.setItem(`${STORAGE_KEY}_${user.id}`, JSON.stringify(data));
15581:     }
15582: 
15583:     async function fillForm(data: any) {
15584:         if (!data) return;
15585: 
15586:         if (data.currentStep) currentStep = data.currentStep;
15587: 
15588:         Object.entries(data).forEach(([key, value]) => {
15589:             // Cas spécial téléphone venant de la DB (champ 'phone')
15590:             if (key === 'phone' && typeof value === 'string' && value.startsWith('+')) {
15591:                 const prefixes = ["+33", "+32", "+41", "+352"];
15592:                 const foundPrefix = prefixes.find(p => value.startsWith(p));
15593:                 if (foundPrefix) {
15594:                     const number = value.replace(foundPrefix, "").trim();
15595:                     const pInput = form.elements.namedItem('phone_prefix') as any;
15596:                     const nInput = form.elements.namedItem('phone_number') as any;
15597:                     if (pInput) pInput.value = foundPrefix;
15598:                     if (nInput) nInput.value = number;
15599:                 }
15600:                 return;
15601:             }
15602: 
15603:             const input = form.elements.namedItem(key) as any;
15604:             if (!input) return;
15605: 
15606:             if (key === "service_categories" && Array.isArray(value)) {
15607:                 const checkboxes = form.querySelectorAll(
15608:                     `input[name="${key}"]`,
15609:                 );
15610:                 checkboxes.forEach((cb: any) => {
15611:                     if (value.includes(cb.value)) {
15612:                         cb.checked = true;
15613:                         cb.parentElement?.classList.add(
15614:                             "bg-indigo-500/20",
15615:                             "border-indigo-500/50",
15616:                             "text-indigo-400",
15617:                         );
15618:                     } else {
15619:                         // Nettoyer si on recharge
15620:                         cb.checked = false;
15621:                         cb.parentElement?.classList.remove(
15622:                             "bg-indigo-500/20",
15623:                             "border-indigo-500/50",
15624:                             "text-indigo-400",
15625:                         );
15626:                     }
15627:                 });
15628:             } else if (input.type === "checkbox") {
15629:                 input.checked = !!value;
15630:             } else if (input instanceof HTMLSelectElement || input instanceof HTMLInputElement) {
15631:                 input.value = value ? String(value) : "";
15632:             }
15633:         });
15634:         updateUI();
15635:     }
15636: 
15637:     async function loadData() {
15638:         const {
15639:             data: { user },
15640:         } = await supabase.auth.getUser();
15641:         if (!user) return;
15642: 
15643:         // Pré-remplir l'email
15644:         const emailInput = document.getElementById('auth-email') as HTMLInputElement;
15645:         if (emailInput && user.email) emailInput.value = user.email;
15646: 
15647:         // 1. Chercher d'abord en DB (Dossier déjà soumis mais pending)
15648:         const { data: dbOnboarding, error: dbError } = await supabase
15649:             .from("onboarding")
15650:             .select("*")
15651:             .eq("profile_id", user.id)
15652:             .eq("status", "pending")
15653:             .order("created_at", { ascending: false })
15654:             .limit(1)
15655:             .maybeSingle();
15656: 
15657:         if (dbOnboarding) {
15658:             console.log("Onboarding recharge: data found in DB", dbOnboarding);
15659:             fillForm(dbOnboarding);
15660:             // On force l'étape 3 si on recharge de la DB pour montrer qu'on a tout
15661:             currentStep = 3;
15662:             updateUI();
15663:             return;
15664:         }
15665: 
15666:         // 2. Fallback sur localStorage (Brouillon non soumis)
15667:         const saved = localStorage.getItem(`${STORAGE_KEY}_${user.id}`);
15668:         if (!saved) return;
15669: 
15670:         try {
15671:             const data = JSON.parse(saved);
15672:             console.log("Onboarding recharge: data found in LocalStorage", data);
