 2589: // src/pages/api/tenant/update-booking-status.ts
 2590: import type { APIRoute } from "astro";
 2591: import { createClient } from "@supabase/supabase-js";
 2592: 
 2593: /**
 2594:  * API pour mettre à jour le statut d'une course
 2595:  * Sécurisé par tenant_id pour éviter les modifications croisées
 2596:  */
 2597: export const POST: APIRoute = async ({ request, locals }) => {
 2598:   try {
 2599:     const { booking_id, new_status } = await request.json();
 2600:     const { user, profile } = locals as any;
 2601: 
 2602:     if (!user || !profile) {
 2603:       return new Response(JSON.stringify({ error: "Unauthorized" }), { status: 401 });
 2604:     }
 2605: 
 2606:     const supabase = createClient(
 2607:       import.meta.env.PUBLIC_SUPABASE_URL,
 2608:       import.meta.env.SUPABASE_SERVICE_ROLE_KEY
 2609:     );
 2610: 
 2611:     // Mise à jour sécurisée : on vérifie que la course appartient bien au tenant du profil
 2612:     const { error } = await supabase
 2613:       .from("bookings")
 2614:       .update({ status: new_status })
 2615:       .eq("id", booking_id)
 2616:       .eq("current_tenant_id", profile.tenant_id);
 2617: 
 2618:     if (error) {
 2619:       return new Response(JSON.stringify({ error: error.message }), { status: 500 });
 2620:     }
 2621: 
 2622:     return new Response(JSON.stringify({ success: true }), { status: 200 });
 2623: 
 2624:   } catch (err: any) {
 2625:     return new Response(JSON.stringify({ error: err.message }), { status: 500 });
 2626:   }
 2627: };
