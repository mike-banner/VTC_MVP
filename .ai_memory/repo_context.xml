15067:         const id = formData.get('rule_id');
15068:         const payload = {
15069:             tenant_id: tenantId,
15070:             service_category: String(formData.get('service_category') || '').toUpperCase(),
15071:             base_price: parseFloat(String(formData.get('base_price') || '0')),
15072:             price_per_km: parseFloat(String(formData.get('price_per_km') || '0')),
15073:             price_per_hour: parseFloat(String(formData.get('price_per_hour') || '0')),
15074:             minimum_fare: parseFloat(String(formData.get('minimum_fare') || '0')),
15075:             active: formData.get('active') === 'on'
15076:         };
