16862: // src/pages/app/dashboard.astro
16863: import { StripeConnectionCard } from "@/components/dashboard/StripeConnectionCard";
16864: import { supabase } from "@/lib/supabase/client";
16865: import AppLayout from "../../layouts/AppLayout.astro";
16866: 
16867: const { profile, supabase: supabaseAdmin } = Astro.locals;
16868: 
16869: if (!profile) return Astro.redirect("/login");
16870: 
16871: // 📅 Calcul des dates pour les KPIs
16872: const now = new Date();
16873: const startOfToday = new Date(
16874:     now.getFullYear(),
16875:     now.getMonth(),
16876:     now.getDate(),
16877: ).toISOString();
16878: const startOfMonth = new Date(
16879:     now.getFullYear(),
16880:     now.getMonth(),
16881:     1,
16882: ).toISOString();
16883: 
16884: // 1️⃣ Courses du mois (Métier)
16885: const { count: monthlyCount } = await supabaseAdmin
16886:     .from("bookings")
16887:     .select("*", { count: "exact", head: true })
16888:     .eq("current_tenant_id", profile.tenant_id!)
16889:     .gte("pickup_time", startOfMonth);
16890: 
16891: // 2️⃣ Données Financières (Source: Vue Ledger)
16892: const { data: kpi } = await supabaseAdmin
16893:     .from("tenant_dashboard_kpi")
16894:     .select("*")
16895:     .eq("tenant_id", profile.tenant_id!)
16896:     .limit(1)
16897:     .maybeSingle();
16898: 
16899: const monthlyRevenue = kpi?.monthly_net_revenue || 0;
16900: 
16901: // 3️⃣ Prochaines courses (Mise en avant)
16902: const { data: upcomingBookings } = await supabaseAdmin
16903:     .from("bookings")
16904:     .select("*, customers!inner(*)")
16905:     .eq("current_tenant_id", profile.tenant_id!)
16906:     .gte("pickup_time", now.toISOString())
16907:     .order("pickup_time", { ascending: true })
16908:     .limit(3);
16909: 
16910: // 4️⃣ Courses en attente de validation (Mise à dispo)
16911: const { data: validatingBookings } = await supabaseAdmin
16912:     .from("bookings")
16913:     .select("*, customers!inner(*)")
16914:     .eq("current_tenant_id", profile.tenant_id!)
16915:     .eq("status", "pending")
16916:     .order("created_at", { ascending: true });
16917: 
16918: // 5️⃣ Dernières courses (Historique court)
16919: const { data: pastBookings } = await supabaseAdmin
16920:     .from("bookings")
16921:     .select("*, customers!inner(*)")
16922:     .eq("current_tenant_id", profile.tenant_id!)
16923:     .lt("pickup_time", now.toISOString())
16924:     .neq("status", "cancelled")
16925:     .order("pickup_time", { ascending: false })
16926:     .limit(2);
16927: 
16928: // 6️⃣ Récupérer l'ID driver du profil actuel
16929: const { data: driver } = await supabaseAdmin
16930:     .from("drivers")
16931:     .select("id")
16932:     .eq("user_id", profile.id)
16933:     .maybeSingle();
16934: 
16935: const driverId = driver?.id;
16936: 
16937: // 7️⃣ Récupérer les infos du tenant pour le titre si besoin
16938: const { data: tenant } = await supabaseAdmin
16939:     .from("tenants")
16940:     .select("name")
16941:     .eq("id", profile.tenant_id!)
16942:     .maybeSingle();
16943: 
16944: const tenantName = tenant?.name || "VTC HUB";
