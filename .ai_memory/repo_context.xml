 8252:             // Remplissage data
 8253:             document.getElementById('det-company')!.textContent = ob.company_name || '-';
 8254:             document.getElementById('det-domain')!.textContent = ob.primary_domain ? `${ob.primary_domain}.vtchub.fr` : '-';
 8255:             document.getElementById('det-name')!.textContent = (ob.first_name || ob.last_name) ? `${ob.first_name || ''} ${ob.last_name || ''}`.trim() : 'N/A';
 8256:             document.getElementById('det-email')!.textContent = ob.auth_email || 'N/A';
 8257:             document.getElementById('det-phone')!.textContent = ob.phone || '-';
 8258:             document.getElementById('det-vehicle')!.textContent = (ob.vehicle_brand || ob.vehicle_model) ? `${ob.vehicle_brand || ''} ${ob.vehicle_model || ''}`.trim() : 'Non renseigné';
 8259:             document.getElementById('det-plate')!.textContent = ob.plate_number || '-';
 8260:             document.getElementById('det-vtc')!.textContent = ob.vtc_license_number || '-';
 8261:             document.getElementById('det-base')!.textContent = `${ob.default_base_price || 0}€`;
 8262:             document.getElementById('det-km')!.textContent = `${ob.default_price_per_km || 0}€`;
 8263:             document.getElementById('det-min')!.textContent = `${ob.default_minimum_fare || 0}€`;
 8264: 
 8265:             const catsContainer = document.getElementById('det-cats')!;
 8266:             catsContainer.innerHTML = (ob.service_categories || []).map((c: string) => `
 8267:                 <span class="px-3 py-1 bg-indigo-500/10 border border-indigo-500/20 rounded-full text-[8px] font-bold text-indigo-400 uppercase tracking-widest">${c}</span>
 8268:             `).join('');
 8269: 
 8270:             // Show animation
 8271:             detModal?.classList.remove('hidden');
 8272:             detModal?.classList.add('flex');
 8273:             requestAnimationFrame(() => {
 8274:                 detModal!.style.opacity = "1";
 8275:             });
 8276:         });
 8277:     });
 8278: 
 8279:     closeDet?.addEventListener('click', () => {
 8280:         detModal!.style.opacity = "0";
 8281:         setTimeout(() => detModal?.classList.add('hidden'), 300);
 8282:     });
 8283: 
 8284:     // --- GESTION APPROUVER / REFUSER ---
 8285:     const overlay = document.getElementById("modal-overlay");
 8286:     const mConfirm = document.getElementById("modal-confirm") as HTMLButtonElement;
 8287:     const approveBtns = document.querySelectorAll(".approve-btn");
 8288:     const rejectBtns = document.querySelectorAll(".reject-btn");
 8289: 
 8290:     let activeAction: 'approve' | 'reject' | null = null;
 8291:     let targetId: string | null = null;
 8292:     let currentBtn: HTMLButtonElement | null = null;
 8293: 
 8294:     function showConfirm(id: string, action: 'approve' | 'reject', btn: HTMLButtonElement) {
 8295:         targetId = id;
 8296:         activeAction = action;
 8297:         currentBtn = btn;
 8298: 
 8299:         const mTitle = document.getElementById('modal-title')!;
 8300:         const mText = document.getElementById('modal-text')!;
 8301:         const mIcon = document.getElementById('modal-icon')!;
 8302: 
 8303:         if (action === 'approve') {
 8304:             mTitle.textContent = "Approuver Dossier";
 8305:             mText.textContent = "Voulez-vous vraiment activer ce chauffeur ? Ses accès seront créés immédiatement.";
 8306:             mConfirm.className = "flex-1 px-6 py-3 bg-emerald-600 hover:bg-emerald-500 text-white text-[10px] font-black uppercase tracking-widest rounded-xl shadow-lg transition-all";
 8307:         } else {
 8308:             mTitle.textContent = "Refuser Dossier";
 8309:             mText.textContent = "Voulez-vous rejeter cette demande d'onboarding ? Le dossier sera marqué comme refusé.";
 8310:             mConfirm.className = "flex-1 px-6 py-3 bg-red-600 hover:bg-red-500 text-white text-[10px] font-black uppercase tracking-widest rounded-xl shadow-lg transition-all";
 8311:         }
 8312: 
 8313:         overlay?.classList.remove('hidden');
 8314:         overlay?.classList.add('flex');
 8315:         requestAnimationFrame(() => overlay!.style.opacity = "1");
 8316:     }
 8317: 
 8318:     approveBtns.forEach(btn => btn.addEventListener('click', () => showConfirm(btn.getAttribute('data-id')!, 'approve', btn as HTMLButtonElement)));
 8319:     rejectBtns.forEach(btn => btn.addEventListener('click', () => showConfirm(btn.getAttribute('data-id')!, 'reject', btn as HTMLButtonElement)));
 8320: 
 8321:     mConfirm?.addEventListener("click", async () => {
 8322:         if (!targetId || !activeAction || !currentBtn) return;
 8323: 
 8324:         mConfirm.disabled = true;
 8325:         mConfirm.textContent = "TRAITEMENT...";
 8326: 
 8327:         const endpoint = activeAction === 'approve' ? '/api/admin/approve' : '/api/admin/reject';
 8328: 
 8329:         try {
 8330:             const response = await fetch(endpoint, {
 8331:                 method: "POST",
 8332:                 headers: { "Content-Type": "application/json" },
 8333:                 body: JSON.stringify({ onboarding_id: targetId }),
 8334:             });
 8335: 
 8336:             if (response.ok) {
 8337:                 window.location.reload();
 8338:             } else {
 8339:                 const res = await response.json();
 8340:                 alert("Erreur : " + res.error);
 8341:             }
 8342:         } catch (err) {
 8343:             alert("Erreur réseau");
 8344:         } finally {
 8345:             mConfirm.disabled = false;
 8346:         }
 8347:     });
 8348: 
 8349:     document.getElementById('modal-cancel')?.addEventListener('click', () => {
 8350:         overlay!.style.opacity = "0";
 8351:         setTimeout(() => overlay?.classList.add('hidden'), 300);
 8352:     });
 8353: </script>
