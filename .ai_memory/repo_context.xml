17776: <file path="src/middleware.ts">
17777: // src/middleware.ts
17778: import { createServerClient, parseCookieHeader } from "@supabase/ssr";
17779: import { defineMiddleware } from "astro:middleware";
17780: 
17781: export const onRequest = defineMiddleware(
17782:   async ({ cookies, request, redirect, locals }, next) => {
17783:     const url = new URL(request.url);
17784:     const path = url.pathname;
17785: 
17786:     // Initialisation Supabase (SSR)
17787:     const supabase = createServerClient(
17788:       import.meta.env.PUBLIC_SUPABASE_URL,
17789:       import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
17790:       {
17791:         cookies: {
17792:           getAll: () =>
17793:             parseCookieHeader(request.headers.get("Cookie") ?? "").map((c) => ({
17794:               name: c.name,
17795:               value: c.value ?? "",
17796:             })),
17797:           setAll: (cookiesToSet) =>
17798:             cookiesToSet.forEach(({ name, value, options }) =>
17799:               cookies.set(name, value, options as any),
17800:             ),
17801:         },
17802:       },
17803:     );
17804: 
17805:     locals.supabase = supabase;
17806:     const {
17807:       data: { user },
17808:     } = await supabase.auth.getUser();
17809: 
17810:     // Mapping des types de routes
17811:     const isLoginPage = path === "/login";
17812:     const isSignupPage = path === "/signup";
17813:     const isAuthPage = isLoginPage || isSignupPage;
17814: 
17815:     const isAppRoute = path.startsWith("/app");
17816:     const isAdminRoute = path.startsWith("/admin");
17817:     const isOnboardingRoute = path.startsWith("/onboarding");
17818:     const isDashboardBase = path === "/dashboard";
17819:     const isSaaSRoute =
17820:       isAppRoute || isAdminRoute || isOnboardingRoute || isDashboardBase;
17821: 
17822:     // 1. CAS : Utilisateur NON connecté
17823:     if (!user) {
17824:       if (isSaaSRoute && !isAuthPage) {
17825:         return redirect("/login");
17826:       }
17827:       return next();
17828:     }
17829: 
17830:     locals.user = user;
17831: 
17832:     // 2. CAS : Utilisateur connecté -> Récupérer profil
17833:     const { data: profile } = await supabase
17834:       .from("profiles")
17835:       .select("*")
17836:       .eq("id", user.id)
17837:       .maybeSingle();
17838: 
17839:     locals.profile = profile || null;
17840: 
17841:     // 3. LOGIQUE DE REDIRECTION (Pour connectés sur Login/Dashboard/Apps)
17842:     if (isSaaSRoute || isAuthPage) {
17843:       // --- PRIORITÉ : ADMIN Plateforme ---
17844:       if (profile?.platform_role) {
17845:         // Toujours vers l'admin dashboard
17846:         if (!isAdminRoute) {
17847:           return redirect("/admin/onboardings");
17848:         }
17849:         return next();
17850:       }
17851: 
17852:       // --- PRIORITÉ : Flow Onboarding (Pending) ---
17853:       if (profile?.tenant_role === "pending") {
17854:         // Vérifier s'il a déjà soumis un dossier
17855:         const { data: onboarding } = await supabase
17856:           .from("onboarding")
17857:           .select("status")
17858:           .eq("profile_id", user.id)
17859:           .eq("status", "pending")
17860:           .order("created_at", { ascending: false })
17861:           .limit(1)
17862:           .maybeSingle();
17863: 
17864:         // S'il a un dossier pending, il va sur waiting-approval, SAUF s'il demande explicitement /onboarding?edit=true
17865:         const isWaitingApprovalPage = path === "/waiting-approval";
17866:         const isEditingOnboarding =
17867:           path === "/onboarding" && url.searchParams.get("edit") === "true";
17868: 
17869:         if (onboarding && !isWaitingApprovalPage && !isEditingOnboarding) {
17870:           return redirect("/waiting-approval");
17871:         }
17872: 
17873:         if (!onboarding && !isOnboardingRoute) {
17874:           return redirect("/onboarding");
17875:         }
17876: 
17877:         return next();
17878:       }
17879: 
17880:       // --- PRIORITÉ : Chauffeur Actif (Onboardé) ---
17881:       if (profile?.tenant_id) {
17882:         if (!isAppRoute) {
17883:           return redirect("/app/dashboard");
17884:         }
17885:         return next();
17886:       }
17887: 
17888:       // --- CAS : Nouveau connecté sans rôle défini (Sécurité) ---
17889:       if (isSaaSRoute && !isOnboardingRoute && !isAdminRoute) {
17890:         return redirect("/onboarding");
17891:       }
17892:     }
17893: 
17894:     return next();
17895:   },
17896: );
17897: </file>
17898: 
17899: </files>
````

