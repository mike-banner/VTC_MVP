13660:     <script>
13661:         import { supabase } from "@/lib/supabase/client";
13662: 
13663:         const container = document.getElementById('settings-page');
13664:         const confirmationPhrase = container?.getAttribute('data-confirmation-phrase');
13665: 
13666:         const openBtn = document.getElementById('open-delete-modal');
13667:         const modal = document.getElementById('delete-modal');
13668:         const cancelBtn = document.getElementById('cancel-delete');
13669:         const confirmBtn = document.getElementById('confirm-delete-btn') as HTMLButtonElement;
13670:         const input = document.getElementById('confirmation-input') as HTMLInputElement;
13671:         const overlay = document.querySelector('.modal-overlay');
13672: 
13673:         // --- GESTION LOGO ---
13674:         const logoInput = document.getElementById('logo-input') as HTMLInputElement;
13675:         const saveLogoBtn = document.getElementById('save-logo-btn') as HTMLButtonElement;
13676:         const logoPreviewOld = document.getElementById('logo-preview');
13677:         const logoPlaceholder = document.getElementById('logo-placeholder');
13678:         const logoPreviewNew = document.getElementById('logo-preview-new') as HTMLImageElement;
13679:         let selectedLogoFile = null;
13680: 
13681:         logoInput?.addEventListener('change', (e) => {
13682:             const target = e.target as HTMLInputElement;
13683:             const file = target.files?.[0];
13684:             if (!file) return;
13685: 
13686:             if (file.size > 2 * 1024 * 1024) {
13687:                 alert("Le fichier est trop volumineux (Max 2Mo)");
13688:                 return;
13689:             }
13690: 
13691:             selectedLogoFile = file;
13692:             const url = URL.createObjectURL(file);
13693: 
13694:             if (logoPreviewOld) logoPreviewOld.classList.add('hidden');
13695:             if (logoPlaceholder) logoPlaceholder.classList.add('hidden');
13696: 
13697:             if (logoPreviewNew) {
13698:                 logoPreviewNew.src = url;
13699:                 logoPreviewNew.classList.remove('hidden');
13700:             }
13701: 
13702:             if (saveLogoBtn) saveLogoBtn.classList.remove('hidden');
13703:         });
13704: 
13705:         saveLogoBtn?.addEventListener('click', async () => {
13706:             if (!selectedLogoFile) return;
13707: 
13708:             saveLogoBtn.disabled = true;
13709:             saveLogoBtn.innerText = "TÉLÉCHARGEMENT...";
13710:             console.log("[Logo] Start upload for:", selectedLogoFile.name);
13711: 
13712:             try {
13713:                 const { data: { user } } = await supabase.auth.getUser();
13714:                 if (!user) throw new Error("Session introuvable");
13715: 
13716:                 const { data: profileData, error: profileErr } = await supabase
13717:                     .from('profiles')
13718:                     .select('tenant_id')
13719:                     .eq('id', user.id)
13720:                     .single();
13721: 
13722:                 if (profileErr) throw profileErr;
13723:                 const tid = profileData?.tenant_id;
13724:                 if (!tid) throw new Error("ID Entreprise non trouvé (Tenant ID)");
13725: 
13726:                 const fileExt = selectedLogoFile.name.split('.').pop()?.toLowerCase();
13727:                 const fileName = `logos/${tid}/logo.${fileExt}`;
13728: 
13729:                 // 1. Upload to Storage
13730:                 const { error: uploadError } = await supabase.storage
13731:                     .from('assets')
13732:                     .upload(fileName, selectedLogoFile, {
13733:                         upsert: true,
13734:                         contentType: selectedLogoFile.type
13735:                     });
13736: 
13737:                 if (uploadError) throw uploadError;
13738: 
13739:                 // 2. Get Public URL with cache buster
13740:                 const { data: { publicUrl } } = supabase.storage
13741:                     .from('assets')
13742:                     .getPublicUrl(fileName);
13743: 
13744:                 const finalUrl = `${publicUrl}?t=${Date.now()}`;
13745: 
13746:                 // 3. Update Tenant
13747:                 const { error: updateError } = await supabase
13748:                     .from('tenants')
13749:                     .update({ logo_url: finalUrl })
13750:                     .eq('id', tid);
13751: 
13752:                 if (updateError) throw updateError;
13753: 
13754:                 console.log("[Logo] Success! New URL:", finalUrl);
13755:                 alert("Logo mis à jour avec succès !");
13756:                 window.location.reload();
13757:             } catch (err) {
13758:                 console.error("[Logo] Error:", err);
13759:                 alert("Erreur lors du téléchargement du logo : " + err.message);
13760:                 saveLogoBtn.disabled = false;
13761:                 saveLogoBtn.innerText = "Enregistrer le logo";
13762:             }
13763:         });
13764: 
13765:         const toggleModal = () => {
13766:             modal?.classList.toggle('is-active');
13767:             document.body.classList.toggle('overflow-hidden');
13768:             if (modal?.classList.contains('is-active')) {
13769:                 input.value = '';
13770:                 confirmBtn.disabled = true;
13771:                 confirmBtn.classList.add('bg-red-600/20', 'text-red-600/40');
13772:                 confirmBtn.classList.remove('bg-red-600', 'text-white', 'hover:bg-red-500');
13773:             }
13774:         };
13775: 
13776:         openBtn?.addEventListener('click', toggleModal);
13777:         cancelBtn?.addEventListener('click', toggleModal);
13778:         overlay?.addEventListener('click', toggleModal);
13779: 
13780:         input?.addEventListener('input', (e) => {
13781:             const target = e.target as HTMLInputElement;
13782:             const val = target.value;
13783:             if (val === confirmationPhrase) {
13784:                 confirmBtn.disabled = false;
13785:                 confirmBtn.classList.remove('bg-red-600/20', 'text-red-600/40');
13786:                 confirmBtn.classList.add('bg-red-600', 'text-white', 'hover:bg-red-500');
13787:             } else {
13788:                 confirmBtn.disabled = true;
13789:                 confirmBtn.classList.add('bg-red-600/20', 'text-red-600/40');
13790:                 confirmBtn.classList.remove('bg-red-600', 'text-white', 'hover:bg-red-500');
13791:             }
13792:         });
13793: 
13794:         confirmBtn?.addEventListener('click', async () => {
13795:             confirmBtn.disabled = true;
13796:             confirmBtn.innerText = "SUPPRESSION...";
13797: 
13798:             try {
13799:                 const { data, error } = await supabase.functions.invoke('delete-tenant-account');
13800: 
13801:                 if (error) throw error;
13802: 
13803:                 alert("Compte supprimé avec succès.");
13804:                 await supabase.auth.signOut();
13805:                 window.location.href = "/";
13806:             } catch (err) {
13807:                 console.error(err);
13808:                 alert("Une erreur est survenue lors de la suppression.");
13809:                 confirmBtn.disabled = false;
13810:                 confirmBtn.innerText = "Supprimer définitivement";
13811:             }
13812:         });
13813: 
13814:         // Close on Escape
13815:         window.addEventListener('keydown', (e) => {
13816:             if (e.key === 'Escape' && modal?.classList.contains('is-active')) {
13817:                 toggleModal();
13818:             }
13819:         });
13820:     </script>
