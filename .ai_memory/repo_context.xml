12811: <file path="supabase/functions/create_checkout_session/index.ts">
12812: import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
12813: import Stripe from "https://esm.sh/stripe@12.18.0?target=deno&no-check";
12814: 
12815: const corsHeaders = {
12816:   "Access-Control-Allow-Origin": "*",
12817:   "Access-Control-Allow-Headers":
12818:     "authorization, x-client-info, apikey, content-type",
12819: };
12820: 
12821: const stripe = new Stripe(Deno.env.get("STRIPE_SECRET_KEY")!, {
12822:   apiVersion: "2024-06-20",
12823: });
12824: 
12825: const supabaseAdmin = createClient(
12826:   Deno.env.get("SUPABASE_URL")!,
12827:   Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")!,
12828:   {
12829:     auth: {
12830:       persistSession: false,
12831:       autoRefreshToken: false,
12832:     },
12833:     global: {
12834:       headers: {
12835:         Authorization: `Bearer ${Deno.env.get("SUPABASE_SERVICE_ROLE_KEY")}`,
12836:       },
12837:     },
12838:   },
12839: );
12840: 
12841: Deno.serve(async (req) => {
12842:   if (req.method === "OPTIONS") {
12843:     return new Response("ok", { headers: corsHeaders });
12844:   }
12845: 
12846:   try {
12847:     const body = await req.json();
12848: 
12849:     console.log("BODY =", body);
12850: 
12851:     const customer_data = body.customer_data;
12852:     const booking_data = body.booking_data;
12853: 
12854:     if (!booking_data) throw new Error("booking_data missing");
12855:     if (!booking_data.type) throw new Error("booking_type missing");
12856:     if (!booking_data.tenant_id) throw new Error("tenant_id missing");
12857: 
12858:     const tenantId = booking_data.tenant_id;
12859: 
12860:     const total = Number(
12861:       booking_data?.total_amount ?? booking_data?.total ?? 0,
12862:     );
12863: 
12864:     const safeTotal = total > 0 ? total : 1;
12865: 
12866:     console.log("TOTAL =", total);
12867:     console.log("SAFE TOTAL =", safeTotal);
12868: 
12869:     // =========================
12870:     // CUSTOMER UPSERT
12871:     // =========================
12872: 
12873:     console.log("UPSERT CUSTOMER INPUT", {
12874:       tenantId,
12875:       email: customer_data?.email,
12876:     });
12877: 
12878:     const { data: customer, error: cErr } = await supabaseAdmin
12879:       .from("customers")
12880:       .upsert(
12881:         {
12882:           tenant_id: tenantId,
12883:           email: customer_data.email,
12884:           first_name: customer_data.first_name,
12885:           last_name: customer_data.last_name,
12886:           phone: customer_data.phone,
12887:         },
12888:         {
12889:           onConflict: "tenant_id,email",
12890:         },
12891:       )
12892:       .select()
12893:       .single();
12894: 
12895:     if (cErr) {
12896:       console.log("CUSTOMERS ERROR =", cErr);
12897:       throw new Error(cErr.message);
12898:     }
12899: 
12900:     if (!customer) {
12901:       console.log("CUSTOMER NULL");
12902:       throw new Error("customer null");
12903:     }
12904: 
12905:     // =========================
12906:     // VEHICLE CHECK
12907:     // =========================
12908: 
12909:     const vehicleId = booking_data.vehicle_id;
12910: 
12911:     if (!vehicleId) {
12912:       throw new Error("vehicle_id required");
12913:     }
12914: 
12915:     const { data: vehicle, error: vErr } = await supabaseAdmin
12916:       .from("vehicles")
12917:       .select("tenant_id,status")
12918:       .eq("id", vehicleId)
12919:       .single();
12920: 
12921:     if (vErr) {
12922:       console.log("VEHICLE ERROR =", vErr);
12923:       throw new Error(vErr.message);
12924:     }
12925: 
12926:     if (!vehicle) throw new Error("vehicle not found");
12927: 
12928:     if (vehicle.status !== "active") {
12929:       throw new Error("vehicle inactive");
12930:     }
12931: 
12932:     if (vehicle.tenant_id !== tenantId) {
12933:       throw new Error("vehicle tenant mismatch");
12934:     }
12935: 
12936:     // =========================
12937:     // TENANT
12938:     // =========================
12939: 
12940:     const { data: tenant, error: tErr } = await supabaseAdmin
12941:       .from("tenants")
12942:       .select("stripe_account_id, platform_fee_rate")
12943:       .eq("id", tenantId)
12944:       .single();
12945: 
12946:     if (tErr) {
12947:       console.log("TENANT ERROR =", tErr);
12948:       throw new Error(tErr.message);
12949:     }
12950: 
12951:     if (!tenant) throw new Error("tenant not found");
12952: 
12953:     if (!tenant.stripe_account_id) {
12954:       throw new Error("stripe not connected");
12955:     }
12956: 
12957:     const account = await stripe.accounts.retrieve(tenant.stripe_account_id);
12958: 
12959:     if (!account.charges_enabled) {
12960:       throw new Error("stripe not ready");
12961:     }
12962: 
12963:     // =========================
12964:     // STRIPE SESSION
12965:     // =========================
12966: 
12967:     const amountInCents = Math.round(safeTotal * 100);
12968: 
12969:     const feeRate = tenant.platform_fee_rate ?? 0;
12970: 
12971:     const feeInCents = Math.round((feeRate / 100) * amountInCents);
12972: 
12973:     const session = await stripe.checkout.sessions.create({
12974:       mode: "payment",
12975: 
12976:       customer_email: customer.email,
12977: 
12978:       metadata: {
12979:         tenant_id: tenantId,
12980:         booking_type: booking_data.type,
12981:         pickup_address: booking_data.pickup_address,
12982:         dropoff_address: booking_data.dropoff_address,
12983:         pickup_time: booking_data.pickup_time,
12984:         vehicle_id: booking_data.vehicle_id,
12985:         total_amount: safeTotal,
12986:         customer_id: customer.id,
12987:       },
12988: 
12989:       line_items: [
12990:         {
12991:           price_data: {
12992:             currency: "eur",
12993:             product_data: {
12994:               name: "Course VTC",
12995:             },
12996:             unit_amount: amountInCents,
12997:           },
12998:           quantity: 1,
12999:         },
13000:       ],
13001: 
13002:       payment_intent_data: {
13003:         application_fee_amount: feeInCents > 0 ? feeInCents : undefined,
13004: 
13005:         transfer_data: {
13006:           destination: tenant.stripe_account_id,
13007:         },
13008: 
13009:         on_behalf_of: tenant.stripe_account_id,
13010:       },
13011: 
13012:       success_url: `${req.headers.get("origin")}/success?session_id={CHECKOUT_SESSION_ID}`,
13013:       cancel_url: `${req.headers.get("origin")}/transfert`,
13014:     });
13015: 
13016:     await supabaseAdmin.from("stripe_events").insert({
13017:       session_id: session.id,
13018:       status: "checkout_created",
13019:       tenant_id: tenantId,
13020:       booking_type: booking_data.type,
13021:       amount: safeTotal,
13022:       metadata: {
13023:         customer_id: customer.id,
13024:         vehicle_id: booking_data.vehicle_id,
13025:       },
13026:     });
13027: 
13028:     return new Response(JSON.stringify({ url: session.url }), {
