````typescript
  1: import { createClient } from "@supabase/supabase-js";
  2: import type { APIRoute } from "astro";
  3: export const POST: APIRoute = async ({ request, locals }) => {
  4:   try {
  5:     const body = await request.json();
  6:     const {
  7:       pickup,
  8:       dropoff,
  9:       distance_km,
 10:       pickup_time,
 11:       client_name,
 12:       client_email,
 13:       payment_mode,
 14:     } = body;
 15:     const supabase = createClient(
 16:       import.meta.env.PUBLIC_SUPABASE_URL,
 17:       import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
 18:     );
 19:     const { user, profile } = locals as any;
 20:     if (!user || !profile) {
 21:       return new Response(JSON.stringify({ error: "Unauthorized" }), {
 22:         status: 401,
 23:       });
 24:     }
 25:     const normalizedEmail = client_email.trim().toLowerCase();
 26:     const tenantId = profile.tenant_id;
 27:     let { data: existingCustomer } = await supabase
 28:       .from("customers")
 29:       .select("id")
 30:       .eq("tenant_id", tenantId)
 31:       .eq("email", normalizedEmail)
 32:       .maybeSingle();
 33:     let customerId = existingCustomer?.id;
 34:     if (!customerId) {
 35:       const { data: newCustomer, error: customerError } = await supabase
 36:         .from("customers")
 37:         .insert({
 38:           tenant_id: tenantId,
 39:           email: normalizedEmail,
 40:           first_name: client_name.split(" ")[0],
 41:           last_name: client_name.split(" ").slice(1).join(" ") || "",
 42:           type: "individual",
 43:         })
 44:         .select("id")
 45:         .limit(1)
 46:         .maybeSingle();
 47:       if (customerError) throw customerError;
 48:       if (!newCustomer) throw new Error("Erreur lors de la création du client");
 49:       customerId = newCustomer.id;
 50:     }
 51:     const { data: pricing, error: pricingError } = await supabase
 52:       .from("pricing_rules")
 53:       .select("*")
 54:       .eq("tenant_id", tenantId)
 55:       .eq("active", true)
 56:       .order("created_at", { ascending: false })
 57:       .limit(1)
 58:       .maybeSingle();
 59:     if (pricingError || !pricing) {
 60:       return new Response(
 61:         JSON.stringify({
 62:           error: "Aucune règle tarifaire active trouvée pour ce tenant.",
 63:         }),
 64:         { status: 400 },
 65:       );
 66:     }
 67:     let total =
 68:       Number(pricing.base_price) +
 69:       Number(pricing.price_per_km) * Number(distance_km);
 70:     if (total < Number(pricing.minimum_fare)) {
 71:       total = Number(pricing.minimum_fare);
 72:     }
 73:     const { data: booking, error: insertError } = await supabase
 74:       .from("bookings")
 75:       .insert({
 76:         original_tenant_id: tenantId,
 77:         current_tenant_id: tenantId,
 78:         customer_id: customerId,
 79:         pickup_address: pickup,
 80:         dropoff_address: dropoff,
 81:         pickup_time,
 82:         total_amount: total,
 83:         status: "pending",
 84:         payment_mode: payment_mode || "cash",
 85:       })
 86:       .select()
 87:       .limit(1)
 88:       .maybeSingle();
 89:     if (insertError) {
 90:       console.error("Insert booking error:", insertError);
 91:       return new Response(JSON.stringify({ error: insertError.message }), {
 92:         status: 500,
 93:       });
 94:     }
 95:     if (!booking) {
 96:       return new Response(
 97:         JSON.stringify({
 98:           error: "Erreur lors de la création de la réservation",
 99:         }),
100:         {
101:           status: 500,
102:         },
103:       );
104:     }
105:     return new Response(
106:       JSON.stringify({
107:         success: true,
108:         booking_id: booking.id,
109:         total_price: total,
110:       }),
111:       { status: 200 },
112:     );
113:   } catch (err: any) {
114:     console.error("Create booking crash:", err);
115:     return new Response(JSON.stringify({ error: err.message }), {
116:       status: 500,
117:     });
118:   }
119: };
