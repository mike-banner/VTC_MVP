10188: <file path="src/pages/api/tenant/bookings.ts">
10189: // src/pages/api/tenant/bookings.ts
10190: import { createServerClient, parseCookieHeader } from "@supabase/ssr";
10191: import type { APIRoute } from "astro";
10192: 
10193: export const GET: APIRoute = async ({ request, locals, cookies }) => {
10194:   try {
10195:     const { user, profile } = locals as any;
10196: 
10197:     // 🛡️ Securité de base : Authentification requise
10198:     if (!user || !profile) {
10199:       return new Response(JSON.stringify({ error: "Unauthorized" }), {
10200:         status: 401,
10201:       });
10202:     }
10203: 
10204:     const supabase = createServerClient(
10205:       import.meta.env.PUBLIC_SUPABASE_URL,
10206:       import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
10207:       {
10208:         cookies: {
10209:           getAll: () =>
10210:             parseCookieHeader(request.headers.get("Cookie") ?? "").map((c) => ({
10211:               name: c.name,
10212:               value: c.value ?? "",
10213:             })),
10214:           setAll: (cookiesToSet) =>
10215:             cookiesToSet.forEach(({ name, value, options }) =>
10216:               cookies.set(name, value, options),
10217:             ),
10218:         },
10219:       },
10220:     );
10221: 
10222:     // 🎯 Filtrage par Tenant (Isolation multi-entreprise)
10223:     let query = supabase
10224:       .from("bookings")
10225:       .select("*, customers(*)")
10226:       .eq("current_tenant_id", profile.tenant_id);
10227: 
10228:     // 👮 PERMISSIONS FINES :
10229:     // - owner / manager -> voient toutes les bookings du tenant
10230:     // - driver -> voit uniquement ses bookings
10231:     if (profile.tenant_role === "driver") {
10232:       const { data: driver } = await supabase
10233:         .from("drivers")
10234:         .select("id")
10235:         .eq("user_id", user.id)
10236:         .eq("tenant_id", profile.tenant_id!)
10237:         .limit(1)
10238:         .maybeSingle();
10239: 
10240:       if (driver) {
10241:         query = query.eq("driver_id", driver.id);
10242:       } else {
10243:         // Si pas de profil chauffeur trouvé, on ne retourne rien (sécurité)
10244:         return new Response(JSON.stringify([]), { status: 200 });
10245:       }
10246:     }
10247: 
10248:     const { data, error } = await query.order("created_at", {
10249:       ascending: false,
10250:     });
10251: 
10252:     if (error) {
10253:       console.error("Fetch bookings error:", error);
10254:       throw error;
10255:     }
10256: 
10257:     return new Response(JSON.stringify(data), {
10258:       status: 200,
10259:       headers: { "Content-Type": "application/json" },
10260:     });
10261:   } catch (err: any) {
10262:     return new Response(JSON.stringify({ error: err.message }), {
10263:       status: 500,
10264:     });
10265:   }
10266: };
10267: </file>
