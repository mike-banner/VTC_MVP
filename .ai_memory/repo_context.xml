342:             return;
343:         }
344: 
345:         saveBtn.disabled = true;
346:         saveBtn.innerText = "SAUVEGARDE...";
347: 
348:         const formData = new FormData(form);
349:         const id = formData.get('rule_id');
350:         const payload = {
351:             tenant_id: tenantId,
352:             service_category: String(formData.get('service_category') || '').toUpperCase(),
353:             base_price: parseFloat(String(formData.get('base_price') || '0')),
354:             price_per_km: parseFloat(String(formData.get('price_per_km') || '0')),
355:             price_per_hour: parseFloat(String(formData.get('price_per_hour') || '0')),
356:             minimum_fare: parseFloat(String(formData.get('minimum_fare') || '0')),
357:             active: formData.get('active') === 'on'
358:         };
359: 
360:         try {
361:             let error;
362:             if (id) {
363:                 const { error: err } = await supabase.from('pricing_rules').update(payload).eq('id', String(id));
364:                 error = err;
365:             } else {
366:                 const { error: err } = await supabase.from('pricing_rules').insert(payload);
367:                 error = err;
368:             }
369: 
370:             if (error) throw error;
371:             window.location.reload();
372:         } catch (err) {
373:             console.error(err);
374:             alert("Erreur lors de la sauvegarde.");
375:             saveBtn.disabled = false;
376:             saveBtn.innerText = "Sauvegarder";
377:         }
