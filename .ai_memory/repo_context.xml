 1: import { createAdminClient } from "../supabase/server";
 2: const PLATFORM_ROLES = ["super_admin", "platform_staff"];
 3: export async function requirePlatformAdmin(profile: any) {
 4:   if (!profile?.id) {
 5:     throw new Error("Unauthorized");
 6:   }
 7:   const supabaseAdmin = createAdminClient();
 8:   const { data, error } = await supabaseAdmin
 9:     .from("profiles")
10:     .select("platform_role")
11:     .eq("id", profile.id)
12:     .maybeSingle();
13:   if (error || !data || !PLATFORM_ROLES.includes(data.platform_role)) {
14:     throw new Error("Unauthorized");
15:   }
16:   return true;
17: }
