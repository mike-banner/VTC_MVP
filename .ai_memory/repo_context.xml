10269: <file path="src/pages/api/tenant/create-booking.ts">
10270: // src/pages/api/tenant/create-booking.ts
10271: import { createClient } from "@supabase/supabase-js";
10272: import type { APIRoute } from "astro";
10273: 
10274: /**
10275:  * API pour créer une course avec calcul de prix automatisé côté serveur
10276:  */
10277: export const POST: APIRoute = async ({ request, locals }) => {
10278:   try {
10279:     const body = await request.json();
10280:     const {
10281:       pickup,
10282:       dropoff,
10283:       distance_km,
10284:       pickup_time,
10285:       client_name,
10286:       client_email,
10287:       payment_mode,
10288:     } = body;
10289: 
10290:     // Utilisation de la SERVICE_ROLE_KEY pour bypass RLS et calculs critiques
10291:     const supabase = createClient(
10292:       import.meta.env.PUBLIC_SUPABASE_URL,
10293:       import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
10294:     );
10295: 
10296:     const { user, profile } = locals as any;
10297:     if (!user || !profile) {
10298:       return new Response(JSON.stringify({ error: "Unauthorized" }), {
10299:         status: 401,
10300:       });
10301:     }
10302: 
10303:     // 1️⃣ Normalisation email
10304:     const normalizedEmail = client_email.trim().toLowerCase();
10305:     const tenantId = profile.tenant_id;
10306: 
10307:     // 2️⃣ Chercher customer existant
10308:     let { data: existingCustomer } = await supabase
10309:       .from("customers")
10310:       .select("id")
10311:       .eq("tenant_id", tenantId)
10312:       .eq("email", normalizedEmail)
10313:       .maybeSingle();
10314: 
10315:     let customerId = existingCustomer?.id;
10316: 
10317:     // 3️⃣ Créer si absent
10318:     if (!customerId) {
10319:       const { data: newCustomer, error: customerError } = await supabase
10320:         .from("customers")
10321:         .insert({
10322:           tenant_id: tenantId,
10323:           email: normalizedEmail,
10324:           first_name: client_name.split(" ")[0],
10325:           last_name: client_name.split(" ").slice(1).join(" ") || "",
10326:           type: "individual",
10327:         })
10328:         .select("id")
10329:         .limit(1)
10330:         .maybeSingle();
10331: 
10332:       if (customerError) throw customerError;
10333:       if (!newCustomer) throw new Error("Erreur lors de la création du client");
10334:       customerId = newCustomer.id;
10335:     }
10336: 
10337:     // 2️ (Suite) Récupérer les règles tarifaires actives du tenant
10338:     const { data: pricing, error: pricingError } = await supabase
10339:       .from("pricing_rules")
10340:       .select("*")
10341:       .eq("tenant_id", tenantId)
10342:       .eq("active", true)
10343:       .order("created_at", { ascending: false })
10344:       .limit(1)
10345:       .maybeSingle();
10346: 
10347:     if (pricingError || !pricing) {
10348:       return new Response(
10349:         JSON.stringify({
10350:           error: "Aucune règle tarifaire active trouvée pour ce tenant.",
10351:         }),
10352:         { status: 400 },
10353:       );
10354:     }
10355: 
10356:     // 3️⃣ Calcul du prix (Logique V1)
10357:     let total =
10358:       Number(pricing.base_price) +
10359:       Number(pricing.price_per_km) * Number(distance_km);
10360:     if (total < Number(pricing.minimum_fare)) {
10361:       total = Number(pricing.minimum_fare);
10362:     }
10363: 
10364:     // 4️⃣ Insertion de la réservation
10365:     const { data: booking, error: insertError } = await supabase
10366:       .from("bookings")
10367:       .insert({
10368:         original_tenant_id: tenantId,
10369:         current_tenant_id: tenantId,
10370:         customer_id: customerId, // Utilisation de l'ID normalisé
10371:         pickup_address: pickup,
10372:         dropoff_address: dropoff,
10373:         pickup_time,
10374:         total_amount: total,
10375:         status: "pending",
10376:         payment_mode: payment_mode || "cash",
10377:       })
10378:       .select()
10379:       .limit(1)
10380:       .maybeSingle();
10381: 
10382:     if (insertError) {
10383:       console.error("Insert booking error:", insertError);
10384:       return new Response(JSON.stringify({ error: insertError.message }), {
10385:         status: 500,
10386:       });
10387:     }
10388: 
10389:     if (!booking) {
10390:       return new Response(
10391:         JSON.stringify({
10392:           error: "Erreur lors de la création de la réservation",
10393:         }),
10394:         {
10395:           status: 500,
10396:         },
10397:       );
10398:     }
10399: 
10400:     return new Response(
10401:       JSON.stringify({
10402:         success: true,
10403:         booking_id: booking.id,
10404:         total_price: total,
10405:       }),
10406:       { status: 200 },
10407:     );
10408:   } catch (err: any) {
10409:     console.error("Create booking crash:", err);
10410:     return new Response(JSON.stringify({ error: err.message }), {
10411:       status: 500,
10412:     });
10413:   }
10414: };
10415: </file>
